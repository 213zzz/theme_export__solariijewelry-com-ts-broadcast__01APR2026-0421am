{%- liquid
  assign mobile_head = mobile_head | default: false
  assign points_per_dollar = block.settings.points_per_dollar | default: 3
  assign redeem_points = block.settings.redeem_points | default: 100
  assign redeem_amount_dollars = block.settings.redeem_amount_dollars | default: 1
  assign current_variant = product.selected_or_first_available_variant
  assign current_total_cents = current_variant.price | default: product.price | default: 0
  assign earned_points = current_total_cents | times: points_per_dollar | divided_by: 100.0 | round
  assign redeem_amount_money = redeem_amount_dollars | times: 100 | money_without_trailing_zeros
-%}

<div
  class="product__block block-padding{% if mobile_head %} sg-mobile-loyalty-block{% endif %}"
  {{ block.shopify_attributes }}
  {{ block_style }}
>
  <div class="sg-loyalty-points" data-loyalty-points data-points-per-dollar="{{ points_per_dollar }}">
    {%- if block.settings.show_icon -%}
      <span class="sg-loyalty-points__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path
            d="M12 3.25l2.7 5.47 6.04.88-4.37 4.26 1.03 6.02L12 17.04 6.6 19.88l1.03-6.02-4.37-4.26 6.04-.88L12 3.25z"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.6"
          />
        </svg>
      </span>
    {%- endif -%}

    <p class="sg-loyalty-points__text">
      Earn
      <strong class="sg-loyalty-points__value" data-loyalty-points-earned>{{ earned_points }}</strong>
      Points with This Order
      <span class="sg-loyalty-points__divider" aria-hidden="true">•</span>
      Redeem {{ redeem_points }} Points for {{ redeem_amount_money }} Off
    </p>
  </div>
</div>
