      padding: 0; margin: 0;
    }
    #{{ uniq_id }} .lg-help-btn:hover { border-color: #111111; color: #111111; }

    /* ── Drawer ── */
    .lg-drawer-overlay {
      position: fixed; inset: 0; z-index: 999999;
      background: rgba(0,0,0,.45);
      opacity: 0; visibility: hidden;
      transition: opacity .3s ease, visibility .3s ease;
    }
    .lg-drawer-overlay.is-open { opacity: 1; visibility: visible; }
    .lg-drawer-overlay__close {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(255,255,255,.15); border: 1.5px solid rgba(255,255,255,.4);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background .2s ease;
      backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    }
    .lg-drawer-overlay__close:hover { background: rgba(255,255,255,.28); }
    .lg-drawer-overlay__close svg { width: 20px; height: 20px; stroke: #fff; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

    .lg-drawer {
      position: fixed; top: 0; right: 0; bottom: 0; z-index: 1000000;
      width: 370px; max-width: 92vw;
      background: #ffffff;
      box-shadow: -4px 0 24px rgba(0,0,0,.1);
      transform: translateX(100%);
      transition: transform .35s cubic-bezier(.22,.61,.36,1);
      display: flex; flex-direction: column;
      overflow: hidden;
    }
    .lg-drawer.is-open { transform: translateX(0); }
    .lg-drawer__header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 24px 16px; border-bottom: 1px solid #e5e5e5; flex: 0 0 auto;
    }
    .lg-drawer__title { font-size: 16px; font-weight: 700; color: #1c1917; line-height: 1.2; margin: 0; }
    .lg-drawer__close {
      width: 32px; height: 32px; flex: 0 0 32px; border-radius: 50%;
      background: #f5f5f5; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background .2s ease;
    }
    .lg-drawer__close:hover { background: #e5e5e5; }
    .lg-drawer__close svg { width: 16px; height: 16px; stroke: #111111; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .lg-drawer__body { flex: 1; overflow-y: auto; padding: 24px; -webkit-overflow-scrolling: touch; }
    .lg-drawer__image { width: 100%; border-radius: 12px; margin-bottom: 20px; display: block; }
    .lg-drawer__body .rte { font-size: 14px; line-height: 1.7; color: #404040; }
    .lg-drawer__body .rte h1, .lg-drawer__body .rte h2, .lg-drawer__body .rte h3,
    .lg-drawer__body .rte h4, .lg-drawer__body .rte h5, .lg-drawer__body .rte h6 {
      color: #1c1917; margin: 0 0 12px; line-height: 1.3;
    }
    .lg-drawer__body .rte p { margin: 0 0 14px; }
    .lg-drawer__body .rte ul, .lg-drawer__body .rte ol { padding-left: 20px; margin: 0 0 14px; }
    .lg-drawer__body .rte li { margin-bottom: 6px; }
    .lg-drawer__body .rte strong { color: #1c1917; }

    #{{ uniq_id }} .lg-pills { display: flex; flex-wrap: wrap; gap: 6px; }
    #{{ uniq_id }} .lg-pill {
      min-height: 34px; padding: 0 14px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      font-family: inherit; font-size: 12px; font-weight: 500; color: #111111; cursor: pointer; position: relative; overflow: hidden;
      background: #ffffff;
      border: 1px solid #d4d4d4; box-shadow: none;
      transition: border-color .2s ease, background .2s ease, color .2s ease;
