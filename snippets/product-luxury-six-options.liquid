    #{{ uniq_id }} .lg-panel {
      position: absolute; left: 0; right: 0; top: calc(100% + 6px); z-index: 50; border-radius: 14px; overflow: hidden;
      background: #ffffff;
      backdrop-filter: none; -webkit-backdrop-filter: none;
      border: 1px solid #d4d4d4;
      box-shadow: none;
      max-height: 0; padding: 0 20px; opacity: 0; visibility: hidden; transform: translateY(-6px) scale(.98);
      transition: max-height .35s cubic-bezier(.34,1.56,.64,1), padding .3s ease, opacity .25s ease, transform .35s cubic-bezier(.34,1.56,.64,1);
      pointer-events: none;
    }
    #{{ uniq_id }} .lg-panel::before { display: none; }
    #{{ uniq_id }} .lg-row.is-open .lg-panel { max-height: 420px; padding: 14px; opacity: 1; visibility: visible; transform: translateY(0) scale(1); pointer-events: auto; overflow-y: auto; }

    #{{ uniq_id }} .lg-panel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    #{{ uniq_id }} .lg-panel-title { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #737373; }
    #{{ uniq_id }} .lg-panel-note { font-size: 11px; color: #737373; }
