    }
    #{{ uniq_id }} .lg-pill:hover { transform: none; border-color: #111111; }
    #{{ uniq_id }} .lg-pill.is-selected { border-color: #111111; background: #111111; color: #ffffff; font-weight: 600; box-shadow: none; }
    #{{ uniq_id }} .lg-pill.is-selected::after { display: none; }
    #{{ uniq_id }} .lg-pill.is-disabled { opacity: .3; pointer-events: none; }
    #{{ uniq_id }} .lg-pill.is-locked { opacity: .55; color: #737373; }
