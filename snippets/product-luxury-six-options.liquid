{%- liquid
  assign current_variant = current_variant | default: product.selected_or_first_available_variant
  assign uniq_id = 'lg-' | append: section.id | append: '-' | append: block.id
  assign plating_lines = block.settings.plating_options | newline_to_br | split: '<br />'
  assign engraving_lines = block.settings.engraving_options | newline_to_br | split: '<br />'
  assign note_max = block.settings.note_max | default: 200
  assign stone_material_options = 'Simulated Diamonds|Moissanite' | split: '|'
  assign plating_enabled_label = '925 Sterling Silver'
  assign plating_icon = block.settings.plating_icon
  assign color_icon = block.settings.color_icon
  assign stone_icon = block.settings.stone_icon
  assign size_icon = block.settings.size_icon
  assign engraving_icon = block.settings.engraving_icon
  assign note_icon = block.settings.note_icon

  assign color_option = nil
  assign stone_option = nil
  assign size_option = nil

  for option in product.options_with_values
    assign option_handle = option.name | downcase
    if option_handle == 'color' or option_handle == 'colour' or option_handle == 'metal' or option_handle == 'material'
      assign color_option = option
      assign color_index = forloop.index0
    elsif option_handle contains 'stone' or option_handle contains 'gem'
      assign stone_option = option
      assign stone_index = forloop.index0
    elsif option_handle == 'size' or option_handle == 'ring size'
      assign size_option = option
      assign size_index = forloop.index0
    endif
  endfor
-%}

<div
  id="{{ uniq_id }}"
  class="product__block block-padding"
  {{ block_style }}
  {{ block.shopify_attributes }}
  data-section-id="{{ section.id }}"
>
  <style>
    #{{ uniq_id }},
    #{{ uniq_id }} *,
    #{{ uniq_id }} *::before,
    #{{ uniq_id }} *::after { box-sizing: border-box; }

    #{{ uniq_id }} { position: relative; overflow: visible; }
    #{{ uniq_id }} .lg-list { display: grid; gap: 6px; position: relative; overflow: visible; }
    #{{ uniq_id }} .lg-divider { border: none; height: 1px; background: #e5e5e5; margin: 4px 0; }
    #{{ uniq_id }} .lg-section-title { font-size: 11px; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; color: #737373; padding-left: 4px; margin: 0; }
    #{{ uniq_id }} .lg-row { position: relative; z-index: 1; overflow: visible; }
    #{{ uniq_id }} .lg-row.is-open { z-index: 60; }

    #{{ uniq_id }} .lg-trigger {
      width: 100%; min-height: 52px; display: flex; align-items: center; justify-content: space-between; gap: 10px;
      padding: 8px 14px; border: none; border-radius: 16px; cursor: pointer; font-family: inherit; text-align: left;
      position: relative; z-index: 1;
      transition: border-color .2s ease, background .2s ease;
      background: #ffffff;
      backdrop-filter: none; -webkit-backdrop-filter: none;
      border: 1px solid #d4d4d4;
      box-shadow: none;
    }
    #{{ uniq_id }} .lg-trigger::before { display: none; }
    #{{ uniq_id }} .lg-trigger:hover { border-color: #111111; transform: none; box-shadow: none; }
    #{{ uniq_id }} .lg-row.is-open .lg-trigger { transform: none; border-color: #111111; box-shadow: none; }

    #{{ uniq_id }} .lg-left { display: flex; align-items: center; gap: 10px; min-width: 0; flex: 1; }
    #{{ uniq_id }} .lg-icon {
      width: 36px; height: 36px; flex: 0 0 36px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;
      background: #ffffff;
      border: 1px solid #d4d4d4; box-shadow: none;
    }
    #{{ uniq_id }} .lg-icon svg { width: 17px; height: 17px; stroke: #111111; fill: none; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
    #{{ uniq_id }} .lg-icon img,
    #{{ uniq_id }} .lg-icon .lg-icon-image { width: 100%; height: 100%; display: block; object-fit: cover; border-radius: inherit; }
    #{{ uniq_id }} .lg-icon--swatch { border-radius: 50%; border: 1px solid #d4d4d4; }
    #{{ uniq_id }} .lg-icon--swatch .lg-swatch-fill { width: 100%; height: 100%; border-radius: inherit; display: block; }
    #{{ uniq_id }} .lg-icon--gold { background: #ffffff; }
    #{{ uniq_id }} .lg-icon--stone { background: #ffffff; }
    #{{ uniq_id }} .lg-icon--media { padding: 0; background: #ffffff; }

    #{{ uniq_id }} .lg-meta { min-width: 0; display: grid; gap: 2px; }
    #{{ uniq_id }} .lg-label { font-size: 14px; font-weight: 600; color: #1c1917; line-height: 1.2; }
    #{{ uniq_id }} .lg-sub {
      display: block;
      max-width: 100%;
      font-size: 12px;
      color: #404040;
      line-height: 1.35;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #{{ uniq_id }} .lg-sub.is-placeholder { color: #a3a3a3; }
    #{{ uniq_id }} .lg-right { display: flex; align-items: center; gap: 0; flex: 0 0 auto; }
    #{{ uniq_id }} .lg-value {
      max-width: 200px; padding: 4px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; line-height: 1.2; color: #3d352d;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      background: #ffffff;
      border: 1px solid #d4d4d4; box-shadow: none;
    }
    #{{ uniq_id }} .lg-value.is-placeholder { font-weight: 500; color: #a3a3a3; }
    #{{ uniq_id }} .lg-price { font-size: 13px; font-weight: 600; color: #1c1917; white-space: nowrap; margin-right: 4px; }
    #{{ uniq_id }} .lg-chevron {
      width: 24px; height: 24px; flex: 0 0 24px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      background: #ffffff; border: 1px solid #d4d4d4;
      transition: transform .35s cubic-bezier(.34,1.56,.64,1), background .25s;
