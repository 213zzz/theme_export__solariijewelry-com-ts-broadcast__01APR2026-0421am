  <script>
    (function() {
      var root = document.getElementById({{ uniq_id | json }});
      if (!root || root.dataset.ready === 'true') return;
      root.dataset.ready = 'true';

      var productInfo = root.closest('product-info');
      var sectionId = root.getAttribute('data-section-id') || '';
      var defaultStoneValue = 'Simulated Diamonds';
      var initialOptions = {{ current_variant.options | json }};

      /* Parse variant JSON for image switching */
      var variantsData = [];
      try {
        var jsonEl = root.querySelector('[data-lg-variants]');
        if (jsonEl) variantsData = JSON.parse(jsonEl.textContent);
      } catch(e) {}

      function $$(scope, sel) { return Array.prototype.slice.call(scope.querySelectorAll(sel)); }
      function getHiddenPicker() { return productInfo ? productInfo.querySelector('[data-luxury-hidden-variants]') : null; }
      function getSelectedVariantScript() {
        var hiddenPicker = getHiddenPicker();
        if (hiddenPicker) {
          var hiddenSelected = hiddenPicker.querySelector('[data-selected-variant]');
          if (hiddenSelected) return hiddenSelected;
        }
        return productInfo ? productInfo.querySelector('variant-selects [data-selected-variant]') : null;
      }
      function getSourceGroup(position) { var hp = getHiddenPicker(); if (!hp) return null; return hp.querySelector('[data-option-position="' + position + '"]'); }
      function findRadioByValue(group, value) { return group ? $$(group, 'input[type="radio"]').find(function(i) { return i.value === value; }) : null; }
      function findDropdownOptionByValue(group, value) { return group ? $$(group, '[data-popout-option]').find(function(el) { return (el.getAttribute('data-value') || '') === value; }) : null; }
      function getGroupValue(group) { if (!group) return ''; var checked = group.querySelector('input[type="radio"]:checked'); if (checked) return checked.value; var toggle = group.querySelector('[data-popout-toggle-text]'); return toggle ? toggle.textContent.trim() : ''; }
      function getStoneRow() { return root.querySelector('[data-lg-stone-row]'); }
      function getSizeRow() { return root.querySelector('[data-row-type="size"]'); }
      function ensureSizeGuidePortal() {
        var existingPortal = root.querySelector('[data-lg-size-guide-portal]');
        if (existingPortal) return existingPortal;
        var hiddenPicker = getHiddenPicker();
        if (!hiddenPicker) return null;
        var sourcePopup = hiddenPicker.querySelector('popup-component');
        if (!sourcePopup) return null;
        var portal = document.createElement('div');
        portal.className = 'lg-size-guide-portal';
        portal.setAttribute('data-lg-size-guide-portal', '');
        portal.appendChild(sourcePopup.cloneNode(true));
        root.appendChild(portal);
        return portal;
      }
      function getSizeGuideTrigger() {
        var portal = ensureSizeGuidePortal();
        if (portal) {
          var portalTrigger = portal.querySelector('[data-popup-open]');
          if (portalTrigger) return portalTrigger;
        }
        var hiddenPicker = getHiddenPicker();
        return hiddenPicker ? hiddenPicker.querySelector('[data-popup-open]') : null;
      }
      function getVariantById(variantId) {
        var targetId = String(variantId || '');
        if (!targetId) return null;
        for (var i = 0; i < variantsData.length; i++) {
          if (String(variantsData[i].id) === targetId) return variantsData[i];
        }
        return null;
      }
      function getSelectedVariantData() {
        var script = getSelectedVariantScript();
        if (!script) return null;
        try {
          return JSON.parse(script.textContent || '{}');
        } catch (e) {
          return null;
        }
      }
      function getCurrentVariantId() {
        var variant = getSelectedVariantData();
        return variant && variant.id ? String(variant.id) : '';
      }
      function findVariantByOptions(options) {
        if (!options || !options.length) return null;
        for (var i = 0; i < variantsData.length; i++) {
          var variant = variantsData[i];
          var match = true;
          for (var j = 0; j < options.length; j++) {
            if (variant.options[j] !== options[j]) { match = false; break; }
          }
          if (match) return variant;
        }
        return null;
      }
      function getCurrentOptions() {
        var selectedVariant = getSelectedVariantData();
        if (selectedVariant && selectedVariant.options && selectedVariant.options.length) return selectedVariant.options.slice();
        var variant = getVariantById(getCurrentVariantId()) || getMatchedVariant();
        if (variant && variant.options && variant.options.length) return variant.options.slice();
        return initialOptions.slice();
      }

      function selectSourceValue(position, value) {
        var group = getSourceGroup(position);
        if (!group) return;
        var radio = findRadioByValue(group, value);
        if (radio) {
          radio.checked = true;
          radio.dispatchEvent(new Event('input', { bubbles: true }));
          radio.dispatchEvent(new Event('change', { bubbles: true }));
          return;
        }
        var dOpt = findDropdownOptionByValue(group, value);
        if (dOpt) dOpt.click();
      }

      function getMatchedVariant() {
        var hp = getHiddenPicker();
        if (!hp) return null;

        var selectedOptions = [];
        var groups = $$(hp, '[data-option-position]');
        groups.forEach(function(g) {
          selectedOptions.push(getGroupValue(g));
        });

        for (var i = 0; i < variantsData.length; i++) {
          var v = variantsData[i];
          var match = true;
          for (var j = 0; j < selectedOptions.length; j++) {
            if (v.options[j] !== selectedOptions[j]) { match = false; break; }
          }
          if (match) return v;
        }

        return null;
      }

      function navigateToMediaId(featuredMediaId) {
        if (!featuredMediaId) return;
        featuredMediaId = String(featuredMediaId);
        var mediaId = sectionId + '-' + featuredMediaId;
        var scope = productInfo || document;
        var desktopSlider = scope.querySelector('[data-sg-slider]');
        var mobileSwiper = scope.querySelector('[data-sg-mob-swiper]');

        if (desktopSlider) {
          desktopSlider.dispatchEvent(new CustomEvent('solarii:media-select', {
            bubbles: true,
            detail: { mediaId: featuredMediaId }
          }));
        }

        if (mobileSwiper) {
          mobileSwiper.dispatchEvent(new CustomEvent('solarii:media-select', {
            bubbles: true,
            detail: { mediaId: featuredMediaId }
          }));
        }

        var isDesktop = window.innerWidth > 1024;
        var nativeMobileMedia = !isDesktop ? scope.querySelector('.sg-native-mobile-media') : null;

        if (nativeMobileMedia && window.getComputedStyle(nativeMobileMedia).display !== 'none') {
          var nativeSlide = nativeMobileMedia.querySelector('[data-image-id="' + featuredMediaId + '"]');
          var nativeMediaList = nativeMobileMedia.querySelector('[data-product-media-list]');

          if (nativeSlide) {
            nativeSlide.dispatchEvent(new CustomEvent('theme:media:select', {
              bubbles: true,
              detail: { id: mediaId }
            }));

            nativeMobileMedia.setAttribute('data-active-media', mediaId);

            if (nativeMediaList && typeof nativeMediaList.scrollTo === 'function') {
              nativeMediaList.scrollTo({
                left: nativeSlide.offsetLeft,
                behavior: 'smooth'
              });
            }

            return;
          }
        }

        if (isDesktop) {
          var desktopThumb = scope.querySelector('[data-sg-thumb][data-media-id="' + featuredMediaId + '"]');
          if (desktopThumb) {
            desktopThumb.click();
            return;
          }
        } else {
          var mobileDot = scope.querySelector('.sg-mob-dot[data-media-id="' + featuredMediaId + '"]');
          if (mobileDot) {
            mobileDot.click();
            return;
          }
        }

        var fallbackSlide = scope.querySelector((isDesktop ? '.sg-slide' : '.sg-mob-slide') + '[data-gallery-media-id="' + featuredMediaId + '"]');
        if (fallbackSlide) {
          var idx = parseInt(fallbackSlide.getAttribute('data-index'), 10);
          if (!isNaN(idx)) {
            if (isDesktop) {
              var track = scope.querySelector('[data-sg-track]');
              if (track) track.style.transform = 'translateX(-' + (idx * 100) + '%)';
              $$(scope, '[data-sg-thumb]').forEach(function(t) {
                t.classList.toggle('is-active', String(t.dataset.index) === String(idx));
              });
            } else {
              var mobTrack = scope.querySelector('[data-sg-mob-track]');
              if (mobTrack) {
                mobTrack.style.transition = 'transform .4s cubic-bezier(.22,.61,.36,1)';
                mobTrack.style.transform = 'translateX(-' + (idx * 100) + '%)';
              }
              $$(scope, '.sg-mob-dot').forEach(function(dot, dotIndex) {
                dot.classList.toggle('is-active', dotIndex === idx);
              });
            }
            return;
          }
        }

        var thumbLink = scope.querySelector('[data-thumb-link][data-media-id="' + mediaId + '"]');
        if (thumbLink) thumbLink.click();

        var mediaSlide = scope.querySelector('[data-media-id="' + mediaId + '"][data-slide]');
        if (mediaSlide) {
          var productImages = mediaSlide.closest('product-images');
          if (productImages && productImages.setAttribute) {
            productImages.setAttribute('data-active-media', mediaId);
          }
        }
      }
      function getMobileSwiper() {
        var scope = productInfo || document;
        return scope.querySelector('[data-sg-mob-swiper]');
      }
      function clearPinnedMobileMedia() {
        var mobileSwiper = getMobileSwiper();
        if (mobileSwiper && mobileSwiper.dataset.sgUserPinnedMediaId) {
          delete mobileSwiper.dataset.sgUserPinnedMediaId;
        }
      }
      function shouldPreservePinnedMobileMedia(forceNavigate) {
        if (forceNavigate || window.innerWidth > 1024) return false;
        var mobileSwiper = getMobileSwiper();
        return !!(mobileSwiper && mobileSwiper.dataset.sgUserPinnedMediaId);
      }
      /* ── Navigate gallery to variant's featured image ── */
      function navigateToVariantImage(preferredVariantId, forceNavigate) {
        if (shouldPreservePinnedMobileMedia(forceNavigate)) return;
        var matchedVariant = getVariantById(preferredVariantId) || getVariantById(getCurrentVariantId()) || getMatchedVariant();
        if (!matchedVariant || !matchedVariant.featured_media_id) return;
        navigateToMediaId(matchedVariant.featured_media_id);
      }
      function previewVariantImageForSelection(position, value) {
        var pos = parseInt(position, 10);
        if (isNaN(pos) || pos < 1) return;
        var options = getCurrentOptions();
        if (!options.length || pos > options.length) return;
        options[pos - 1] = value;
        var variant = findVariantByOptions(options);
        if (variant && variant.featured_media_id) navigateToMediaId(variant.featured_media_id);
      }

      function syncVariantThenNavigate(previousVariantId, callback, forceNavigate) {
        var attempts = 0;
        var maxAttempts = 15;

        function check() {
          attempts += 1;
          var currentVariantId = getCurrentVariantId();
          if ((currentVariantId && currentVariantId !== String(previousVariantId || '')) || attempts >= maxAttempts) {
            updateNativeRows();
            navigateToVariantImage(currentVariantId, forceNavigate);
            if (typeof callback === 'function') callback();
            return;
          }
          window.setTimeout(check, 60);
        }

        window.setTimeout(check, 60);
      }

      function closeStoneSubRows(stoneRow, exceptSubRow) {
        if (!stoneRow) return;
        $$(stoneRow, '[data-lg-stone-subrow].is-open').forEach(function(subrow) {
          if (exceptSubRow && subrow === exceptSubRow) return;
          subrow.classList.remove('is-open');
          var trigger = subrow.querySelector('[data-lg-stone-sub-trigger]');
          if (trigger) trigger.setAttribute('aria-expanded', 'false');
        });
      }

      function closeAll(exceptRow) {
        $$(root, '.lg-row.is-open').forEach(function(row) {
          if (exceptRow && row === exceptRow) return;
          row.classList.remove('is-open');
          closeStoneSubRows(row);
          var trigger = row.querySelector('[data-lg-trigger]');
          if (trigger) trigger.setAttribute('aria-expanded', 'false');
        });
      }

      function setTriggerVisual(row, btn) {
        if (!row) return;
        var visual = row.querySelector('[data-lg-trigger-visual]');
        if (!visual || row.getAttribute('data-row-type') !== 'color') return;
        if (visual.getAttribute('data-lg-visual-locked') === 'true') return;
        var vType = btn ? (btn.getAttribute('data-visual-type') || '') : '';
        var vImage = btn ? (btn.getAttribute('data-visual-image') || '') : '';
        var vColor = btn ? (btn.getAttribute('data-visual-color') || '') : '';
        visual.classList.add('lg-icon--swatch');
        visual.innerHTML = '';
        if (vType === 'image' && vImage) { var img = document.createElement('img'); img.className = 'lg-swatch-fill'; img.src = vImage; visual.appendChild(img); }
        else if (vType === 'color' && vColor) { var fill = document.createElement('span'); fill.className = 'lg-swatch-fill'; fill.style.background = vColor; visual.appendChild(fill); }
        else { visual.classList.remove('lg-icon--swatch'); visual.innerHTML = '<svg viewBox="0 0 24 24"><path d="M6 12a6 6 0 0 1 12 0c0 4-6 9-6 9s-6-5-6-9Z"></path><path d="M9 10.5c1.4-1.8 4.6-1.8 6 0"></path></svg>'; }
      }

      function syncStoneRow() {
        var stoneRow = getStoneRow();
        if (!stoneRow) return;

        var group = getSourceGroup(stoneRow.getAttribute('data-option-position'));
        var mainValue = getGroupValue(group) || '';
        var summary = stoneRow.querySelector('[data-lg-selected]');
        var mainSelected = stoneRow.querySelector('[data-lg-stone-main-selected]');
        var sideInput = stoneRow.querySelector('[data-lg-stone-side-input]');

        if (sideInput && !sideInput.value) sideInput.value = mainValue || defaultStoneValue;
        var sideValue = sideInput ? sideInput.value : '';

        if (summary) {
          var summaryText = mainValue || defaultStoneValue;
          if (sideValue && sideValue !== summaryText) summaryText = summaryText + ' / ' + sideValue;
          summary.textContent = summaryText;
          summary.classList.remove('is-placeholder');
        }

        if (mainSelected) {
          mainSelected.textContent = mainValue || defaultStoneValue;
          mainSelected.classList.remove('is-placeholder');
        }

        $$(stoneRow, '[data-lg-stone-main-choice]').forEach(function(btn) {
          var btnValue = btn.getAttribute('data-value') || '';
          var radio = findRadioByValue(group, btnValue);
          var dropdownOption = findDropdownOptionByValue(group, btnValue);
          var disabled = false;

          if (radio) disabled = radio.classList.contains('disabled') || radio.disabled;
          else if (dropdownOption) disabled = dropdownOption.classList.contains('unavailable');
          else disabled = true;

          btn.classList.toggle('is-disabled', !!disabled);
          btn.classList.toggle('is-selected', btnValue === mainValue);
        });

        var sideSelected = stoneRow.querySelector('[data-lg-stone-side-selected]');
        if (sideSelected) {
          sideSelected.textContent = sideValue || defaultStoneValue;
          sideSelected.classList.remove('is-placeholder');
        }

        $$(stoneRow, '[data-lg-stone-side-choice]').forEach(function(btn) {
          var btnValue = btn.getAttribute('data-value') || '';
          btn.classList.toggle('is-selected', btnValue === sideValue);
        });
      }

      function syncSizeRow() {
        var sizeRow = getSizeRow();
        if (!sizeRow) return;

        var group = getSourceGroup(sizeRow.getAttribute('data-option-position'));
        var value = getGroupValue(group) || '';
        var selectedText = sizeRow.querySelector('[data-lg-selected]');
        var customBox = sizeRow.querySelector('[data-lg-size-custom-box]');
        var customField = sizeRow.querySelector('[data-lg-size-custom-field]');
        var customInput = sizeRow.querySelector('[data-lg-size-custom-input]');
        var customValue = customField ? customField.value.trim() : '';
        var forceOpen = customBox && customBox.getAttribute('data-open') === 'true';

        if (customInput) customInput.value = customValue;

        if (selectedText) {
          selectedText.textContent = customValue || value;
          selectedText.classList.remove('is-placeholder');
        }

        if (customBox) customBox.classList.toggle('is-open', !!customValue || !!forceOpen);
      }

      function updateNativeRows() {
        $$(root, '[data-lg-native-row]').forEach(function(row) {
          var pos = row.getAttribute('data-option-position');
          var group = getSourceGroup(pos);
          if (!group) return;
          var value = getGroupValue(group);
          var selectedText = row.querySelector('[data-lg-selected]');
          if (selectedText) { selectedText.textContent = value; selectedText.classList.remove('is-placeholder'); }
          var matchedButton = null;
          $$(row, '[data-lg-native-choice]').forEach(function(btn) {
            var btnValue = btn.getAttribute('data-value') || '';
            var selected = btnValue === value;
            btn.classList.toggle('is-selected', selected);
            if (selected) matchedButton = btn;
            var disabled = false;
            var radio = findRadioByValue(group, btnValue);
            if (radio) { disabled = radio.classList.contains('disabled') || radio.disabled; }
            else {
              var d = findDropdownOptionByValue(group, btnValue);
              if (d) disabled = d.classList.contains('unavailable');
              else disabled = true;
            }
            btn.classList.toggle('is-disabled', !!disabled);
          });
          if (matchedButton) setTriggerVisual(row, matchedButton);
        });
        syncStoneRow();
        syncSizeRow();
      }

      /* Toggle */
      $$(root, '[data-lg-trigger]').forEach(function(trigger) {
        trigger.addEventListener('click', function(e) {
          e.stopPropagation();
          var row = trigger.closest('.lg-row');
          var willOpen = !row.classList.contains('is-open');
          closeAll(row);
          closeStoneSubRows(row);
          row.classList.toggle('is-open', willOpen);
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      });
      $$(root, '[data-lg-stone-sub-trigger]').forEach(function(trigger) {
        trigger.addEventListener('click', function(e) {
          e.stopPropagation();
          var stoneRow = trigger.closest('[data-lg-stone-row]');
          var subrow = trigger.closest('[data-lg-stone-subrow]');
          var willOpen = !subrow.classList.contains('is-open');
          closeStoneSubRows(stoneRow, subrow);
          subrow.classList.toggle('is-open', willOpen);
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      });
      $$(root, '[data-lg-panel]').forEach(function(panel) { panel.addEventListener('click', function(e) { e.stopPropagation(); }); });
      $$(root, '[data-lg-stone-sub-panel]').forEach(function(panel) { panel.addEventListener('click', function(e) { e.stopPropagation(); }); });

      var sizeRow = getSizeRow();
      if (sizeRow) {
        var sizeCustomBox = sizeRow.querySelector('[data-lg-size-custom-box]');
        var sizeCustomField = sizeRow.querySelector('[data-lg-size-custom-field]');
        var sizeCustomToggle = sizeRow.querySelector('[data-lg-size-custom-toggle]');
        var sizeCustomClear = sizeRow.querySelector('[data-lg-size-custom-clear]');
        var sizeGuideLink = sizeRow.querySelector('[data-lg-size-guide-link]');

        if (sizeCustomToggle && sizeCustomBox) {
          sizeCustomToggle.addEventListener('click', function(e) {
            e.preventDefault();
            sizeCustomBox.setAttribute('data-open', sizeCustomBox.getAttribute('data-open') === 'true' ? 'false' : 'true');
            syncSizeRow();
            if (sizeCustomBox.classList.contains('is-open') && sizeCustomField) sizeCustomField.focus();
          });
        }

        if (sizeCustomField) {
          sizeCustomField.addEventListener('input', syncSizeRow);
          sizeCustomField.addEventListener('click', function(e) { e.stopPropagation(); });
        }

        if (sizeCustomClear && sizeCustomField && sizeCustomBox) {
          sizeCustomClear.addEventListener('click', function(e) {
            e.preventDefault();
            sizeCustomField.value = '';
            sizeCustomBox.setAttribute('data-open', 'false');
            syncSizeRow();
          });
        }

        if (sizeGuideLink) {
          sizeGuideLink.addEventListener('click', function(e) {
            var guideTrigger = getSizeGuideTrigger();
            if (guideTrigger) {
              e.preventDefault();
              guideTrigger.click();
            }
          });
        }
      }

      /* Native choices — select variant + navigate image */
      $$(root, '[data-lg-native-choice]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.classList.contains('is-disabled')) return;
          var stoneRow = btn.closest('[data-lg-stone-row]');
          var stoneSubrow = btn.closest('[data-lg-stone-subrow]');
          var previousVariantId = getCurrentVariantId();
          clearPinnedMobileMedia();
          previewVariantImageForSelection(btn.getAttribute('data-option-position'), btn.getAttribute('data-value') || '');
          selectSourceValue(btn.getAttribute('data-option-position'), btn.getAttribute('data-value') || '');
          syncVariantThenNavigate(previousVariantId, function() {
            if (stoneRow && stoneSubrow) closeStoneSubRows(stoneRow);
            else closeAll();
          }, true);
        });
      });

      /* Side stone choice */
      $$(root, '[data-lg-stone-side-choice]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.classList.contains('is-disabled')) return;
          var stoneRow = btn.closest('[data-lg-stone-row]');
          var sideInput = stoneRow ? stoneRow.querySelector('[data-lg-stone-side-input]') : null;
          if (sideInput) sideInput.value = btn.getAttribute('data-value') || '';
          syncStoneRow();
          closeStoneSubRows(stoneRow);
        });
      });

      /* Custom choices */
      $$(root, '[data-lg-custom-choice]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.classList.contains('is-disabled')) return;
          var key = btn.getAttribute('data-custom-key');
          var value = btn.getAttribute('data-value') || '';
          var row = btn.closest('.lg-row');
          var input = root.querySelector('[data-lg-custom-input="' + key + '"]');
          var selectedText = row.querySelector('[data-lg-selected]');
          if (input) input.value = value;
          if (selectedText) { selectedText.textContent = value; selectedText.classList.remove('is-placeholder'); }
          $$(row, '[data-lg-custom-choice]').forEach(function(item) { item.classList.remove('is-selected'); });
          btn.classList.add('is-selected');
          closeAll();
        });
      });

      /* Note */
      var noteInput = root.querySelector('[data-lg-note]');
      if (noteInput) {
        var noteCount = root.querySelector('[data-lg-note-count]');
        var notePreview = root.querySelector('[data-lg-note-preview]');
        function syncNote() {
          var value = noteInput.value || '';
          if (noteCount) noteCount.textContent = value.length;
          if (notePreview) {
            if (value.trim()) { notePreview.textContent = value.trim().length > 22 ? value.trim().slice(0, 22) + '…' : value.trim(); notePreview.classList.remove('is-placeholder'); }
            else { notePreview.textContent = {{ block.settings.note_placeholder | json }}; notePreview.classList.add('is-placeholder'); }
          }
        }
        noteInput.addEventListener('input', syncNote);
        syncNote();
      }

      var engravingInput = root.querySelector('[data-lg-engraving-note]');
      if (engravingInput) {
        var engravingCount = root.querySelector('[data-lg-engraving-count]');
        var engravingPreview = root.querySelector('[data-lg-engraving-preview]');
        function syncEngraving() {
          var value = engravingInput.value || '';
          if (engravingCount) engravingCount.textContent = value.length;
          if (engravingPreview) {
            if (value.trim()) { engravingPreview.textContent = value.trim().length > 22 ? value.trim().slice(0, 22) + '…' : value.trim(); engravingPreview.classList.remove('is-placeholder'); }
            else { engravingPreview.textContent = {{ block.settings.engraving_placeholder | json }}; engravingPreview.classList.add('is-placeholder'); }
          }
        }
        engravingInput.addEventListener('input', syncEngraving);
        syncEngraving();
      }

      document.addEventListener('click', function() { closeAll(); });

      /* ── Help Drawer (mount to body to escape stacking context) ── */
      var drawerOverlay, drawer, drawerTitle, drawerBody;
      (function mountDrawer() {
        var tpl = root.querySelector('[data-lg-drawer-tpl]');
        if (!tpl) return;
        var existing = document.body.querySelector('[data-lg-drawer-root]');
        if (existing) {
          drawerOverlay = existing.querySelector('[data-lg-drawer-overlay]');
          drawer = existing.querySelector('[data-lg-drawer]');
        } else {
          var wrapper = document.createElement('div');
          wrapper.setAttribute('data-lg-drawer-root', '');
          wrapper.appendChild(tpl.content.cloneNode(true));
          document.body.appendChild(wrapper);
          drawerOverlay = wrapper.querySelector('[data-lg-drawer-overlay]');
          drawer = wrapper.querySelector('[data-lg-drawer]');
        }
        drawerTitle = drawer ? drawer.querySelector('[data-lg-drawer-title]') : null;
        drawerBody = drawer ? drawer.querySelector('[data-lg-drawer-body]') : null;
      })();

      function openDrawer(title) {
        if (!drawer || !drawerOverlay) return;
        if (drawerTitle) drawerTitle.textContent = title || '';
        drawer.classList.add('is-open');
        drawerOverlay.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        if (!drawer || !drawerOverlay) return;
        drawer.classList.remove('is-open');
        drawerOverlay.classList.remove('is-open');
        document.body.style.overflow = '';
      }

      /* ? button click */
      var drawerDefaultTitle = {{ block.settings.drawer_title | default: 'Metal' | json }};
      $$(root, '[data-lg-help]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          openDrawer(drawerDefaultTitle);
        });
      });

      /* Close buttons (both panel X and overlay X) */
      var drawerRoot = document.body.querySelector('[data-lg-drawer-root]');
      if (drawerRoot) {
        $$(drawerRoot, '[data-lg-drawer-close]').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            closeDrawer();
          });
        });
      }

      /* Click overlay background to close */
      if (drawerOverlay) {
        drawerOverlay.addEventListener('click', function(e) {
          if (e.target === drawerOverlay) closeDrawer();
        });
      }

      /* Esc key to close */
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && drawer && drawer.classList.contains('is-open')) closeDrawer();
      });

      function initSync() {
        ensureSizeGuidePortal();
        updateNativeRows();
        var hp = getHiddenPicker();
        if (!hp) return;
        hp.addEventListener('change', function() { updateNativeRows(); navigateToVariantImage(null, false); });
        hp.addEventListener('input', function() { updateNativeRows(); navigateToVariantImage(null, false); });
        var obs = new MutationObserver(function() { updateNativeRows(); });
        obs.observe(hp, { subtree: true, childList: true, attributes: true, attributeFilter: ['class', 'checked', 'aria-current', 'value'] });
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initSync);
      else initSync();
    })();
  </script>
</div>
