    #{{ uniq_id }} .lg-foot-link { font-size: 12px; color: #1c1917; text-decoration: underline; text-underline-offset: 3px; background: none; border: none; padding: 0; cursor: pointer; font-family: inherit; }
    #{{ uniq_id }} .lg-foot-link--muted { color: #525252; }
    #{{ uniq_id }} .lg-foot-link--mini { font-size: 11px; color: #525252; }
    #{{ uniq_id }} .lg-custom-size-box { display: none; gap: 8px; margin-top: 12px; }
    #{{ uniq_id }} .lg-custom-size-box.is-open { display: grid; }
    #{{ uniq_id }} .lg-custom-size-input {
      width: 100%; min-height: 44px; border-radius: 14px; padding: 0 14px;
      font: inherit; font-size: 14px; color: #1c1917; outline: none;
      background: #ffffff; border: 1px solid #d4d4d4;
      transition: border-color .22s ease;
    }
    #{{ uniq_id }} .lg-custom-size-input::placeholder { color: #a3a3a3; }
    #{{ uniq_id }} .lg-custom-size-input:focus { border-color: #111111; box-shadow: none; }
    #{{ uniq_id }} .lg-size-guide-portal { position: absolute; inset: 0 auto auto 0; width: 0; height: 0; overflow: visible; z-index: 0; }
    #{{ uniq_id }} .lg-size-guide-portal [data-popup-open] {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0, 0, 0, 0); clip-path: inset(50%); white-space: nowrap; border: 0;
    }

    #{{ uniq_id }} .lg-note-box { display: grid; gap: 8px; }
    #{{ uniq_id }} .lg-note {
      width: 100%; min-height: 96px; border-radius: 16px; padding: 14px 16px;
      font: inherit; font-size: 14px; line-height: 1.5; color: #1c1917; resize: vertical; outline: none;
      background: #ffffff; border: 1px solid #d4d4d4;
      transition: border-color .22s ease;
    }
    #{{ uniq_id }} .lg-note::placeholder { color: #a3a3a3; }
    #{{ uniq_id }} .lg-note:focus { border-color: #111111; box-shadow: none; }
    #{{ uniq_id }} .lg-note-foot { display: flex; align-items: center; justify-content: space-between; font-size: 11px; color: #737373; }

    #{{ uniq_id }} .lg-stone-grid { display: grid; gap: 8px; }
    #{{ uniq_id }} .lg-row--stone .lg-panel { overflow: visible; }
    #{{ uniq_id }} .lg-row--stone.is-open .lg-panel { max-height: 520px; overflow: visible; }
    #{{ uniq_id }} .lg-stone-subrow { position: relative; z-index: 1; }
    #{{ uniq_id }} .lg-stone-subrow.is-open { z-index: 12; }
    #{{ uniq_id }} .lg-stone-subtrigger {
      min-height: 46px;
      padding: 6px 12px;
      border-radius: 14px;
      box-shadow: none;
    }
    #{{ uniq_id }} .lg-stone-subtrigger::before { border-radius: 14px; }
    #{{ uniq_id }} .lg-stone-subrow.is-open .lg-stone-subtrigger { box-shadow: none; }
    #{{ uniq_id }} .lg-stone-subrow.is-open > .lg-stone-subtrigger .lg-chevron {
      transform: rotate(180deg);
      background: #ffffff;
    }
    #{{ uniq_id }} .lg-stone-subpanel {
      position: absolute; left: 0; right: 0; top: calc(100% + 6px); z-index: 8; border-radius: 14px;
      background: #ffffff;
      backdrop-filter: none; -webkit-backdrop-filter: none;
      border: 1px solid #d4d4d4;
      box-shadow: none;
      max-height: 0; padding: 0 16px; opacity: 0; visibility: hidden; transform: translateY(-6px) scale(.98);
      transition: max-height .35s cubic-bezier(.34,1.56,.64,1), padding .3s ease, opacity .25s ease, transform .35s cubic-bezier(.34,1.56,.64,1);
      pointer-events: none; overflow: hidden;
    }
    #{{ uniq_id }} .lg-stone-subpanel::before { display: none; }
    #{{ uniq_id }} .lg-stone-subrow.is-open .lg-stone-subpanel { max-height: 210px; padding: 12px; opacity: 1; visibility: visible; transform: translateY(0) scale(1); pointer-events: auto; }
    #{{ uniq_id }} .lg-stone-subpanel .lg-panel-head { margin-bottom: 10px; }

    #{{ uniq_id }} .lg__hidden { display: none !important; }

    @media (max-width: 749px) {
      #{{ uniq_id }} .lg-trigger { min-height: 46px; padding: 7px 10px; border-radius: 12px; }
      #{{ uniq_id }} .lg-trigger::before { border-radius: 12px; }
      #{{ uniq_id }} .lg-icon { width: 32px; height: 32px; flex-basis: 32px; border-radius: 8px; }
      #{{ uniq_id }} .lg-label { font-size: 13px; }
      #{{ uniq_id }} .lg-value { max-width: 110px; font-size: 11px; padding: 3px 10px; }
      #{{ uniq_id }} .lg-price { font-size: 12px; }
      #{{ uniq_id }} .lg-chevron { width: 22px; height: 22px; flex-basis: 22px; }
      #{{ uniq_id }} .lg-panel {
        position: absolute;
        left: -4px;
        right: -4px;
        top: calc(100% + 6px);
        margin-top: 0;
        border-radius: 12px;
      }
      #{{ uniq_id }} .lg-pill { min-height: 32px; padding: 0 12px; font-size: 11px; }
      #{{ uniq_id }} .lg-row--stone.is-open .lg-panel { max-height: 520px; overflow: visible; }
      #{{ uniq_id }} .lg-stone-grid { gap: 8px; padding: 0 6px; }
      #{{ uniq_id }} .lg-stone-subrow { padding: 0; }
      #{{ uniq_id }} .lg-stone-subtrigger { min-height: 42px; padding: 6px 10px; border-radius: 12px; }
      #{{ uniq_id }} .lg-stone-subtrigger::before { border-radius: 12px; }
      #{{ uniq_id }} .lg-stone-subtrigger .lg-left { gap: 8px; }
      #{{ uniq_id }} .lg-stone-subtrigger .lg-right { gap: 6px; }
      #{{ uniq_id }} .lg-stone-subtrigger .lg-value { max-width: 100px; }
      #{{ uniq_id }} .lg-stone-subpanel {
        position: absolute;
        left: -4px;
        right: -4px;
        top: calc(100% + 6px);
        margin-top: 0;
        border-radius: 12px;
      }
    }
  </style>

  {%- comment -%} Variant JSON for image switching {%- endcomment -%}
  <script type="application/json" data-lg-variants>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id }},
          "options": {{ variant.options | json }},
          "featured_media_id": {% if variant.featured_media %}{{ variant.featured_media.id }}{% else %}null{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  <div class="lg-list">

    {%- comment -%} ══════ 1. 镀层 ══════ {%- endcomment -%}
    <div class="lg-row" data-lg-dd data-lg-custom-row="plating">
      <button type="button" class="lg-trigger" data-lg-trigger aria-expanded="false">
        <span class="lg-left">
          <span class="lg-icon lg-icon--gold{% if plating_icon != blank %} lg-icon--media{% endif %}">
            {%- if plating_icon != blank -%}
              {{ plating_icon | image_url: width: 120 | image_tag: class: 'lg-icon-image', alt: block.settings.plating_label }}
            {%- else -%}
              <svg viewBox="0 0 24 24"><path d="M5 8h14"/><path d="M6 8l2 10h8l2-10"/><path d="M9 8V5h6v3"/></svg>
            {%- endif -%}
          </span>
          <span class="lg-meta"><span class="lg-label">{{ block.settings.plating_label }}</span><span class="lg-sub" data-lg-selected>{{ plating_enabled_label }}</span></span>
        </span>
        <span class="lg-right">
          <span class="lg-chevron"><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></span>
        </span>
      </button>
      <div class="lg-panel" data-lg-panel>
        <div class="lg-panel-head"><span class="lg-panel-title">Select {{ block.settings.plating_label }}</span><button type="button" class="lg-help-btn" data-lg-help="plating" aria-label="Help">?</button></div>
        <div class="lg-pills">
          <button type="button" class="lg-pill is-selected" data-lg-custom-choice data-custom-key="plating" data-value="{{ plating_enabled_label | escape }}"><span>{{ plating_enabled_label }}</span></button>
          {%- for item in plating_lines -%}{%- assign ic = item | strip -%}{%- if ic != blank and ic != plating_enabled_label -%}
            <button type="button" class="lg-pill is-disabled is-locked" aria-disabled="true" tabindex="-1" data-lg-custom-choice data-custom-key="plating" data-value="{{ ic | escape }}"><span>{{ ic }}</span></button>
          {%- endif -%}{%- endfor -%}
        </div>
      </div>
      <input type="hidden" class="lg__hidden" form="{{ product_form_id }}" name="properties[{{ block.settings.plating_label | escape }}]" value="{{ plating_enabled_label }}" data-lg-custom-input="plating">
    </div>

    {%- comment -%} ══════ 2. Color ══════ {%- endcomment -%}
    {%- if color_option -%}
      {%- assign option = color_option -%}
      {%- assign current_value = current_variant.options[color_index] -%}
      {%- assign selected_swatch_color = '' -%}{%- assign selected_swatch_image = '' -%}
      {%- for value in option.values -%}{%- if current_value == value -%}{%- if value.swatch.image -%}{%- assign selected_swatch_image = value.swatch.image | image_url: width: 120 -%}{%- elsif value.swatch.color -%}{%- assign selected_swatch_color = value.swatch.color -%}{%- endif -%}{%- endif -%}{%- endfor -%}

      <div class="lg-row" data-lg-dd data-lg-native-row data-option-position="{{ option.position }}" data-row-type="color">
        <button type="button" class="lg-trigger" data-lg-trigger aria-expanded="false">
          <span class="lg-left">
            <span class="lg-icon{% if color_icon != blank %} lg-icon--media{% else %} lg-icon--swatch{% endif %}" data-lg-trigger-visual{% if color_icon != blank %} data-lg-visual-locked="true"{% endif %}>
              {%- if color_icon != blank -%}
                {{ color_icon | image_url: width: 120 | image_tag: class: 'lg-icon-image', alt: option.name }}
              {%- elsif selected_swatch_image != blank -%}<img class="lg-swatch-fill" src="{{ selected_swatch_image }}" alt="{{ current_value | escape }}">
              {%- elsif selected_swatch_color != blank -%}<span class="lg-swatch-fill" style="background:{{ selected_swatch_color }};"></span>
