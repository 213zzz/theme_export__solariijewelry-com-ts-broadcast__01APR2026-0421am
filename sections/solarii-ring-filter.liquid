<script>
(function(){
  // ── State ──
  var state = {
    'filter.p.m.custom.plating_color': { val: '', label: 'All', labelEl: 'smfMetalLabel' },
    'filter.p.m.custom.stone_shape':   { val: '', label: 'All', labelEl: 'smfShapeLabel' },
    'filter.p.m.custom.carat':         { val: '', label: 'All', labelEl: 'smfCaratLabel' },
    'filter.p.m.custom.stone_color':   { val: '', label: 'All', labelEl: 'smfColorLabel' }
  };

  // ── Sort ──
  var activeSortBy = '';
  window.smfToggleSort = function(e) {
    e.stopPropagation();
    document.getElementById('smfSortDropdown').classList.toggle('open');
  };
  document.querySelectorAll('.smf-sort-opt').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      activeSortBy = btn.dataset.sort;
      // Update label
      document.getElementById('smfSortLabel').textContent = btn.textContent.trim();
      // Mark active
      document.querySelectorAll('.smf-sort-opt').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      // Close dropdown
      document.getElementById('smfSortDropdown').classList.remove('open');
      // Apply
      smfApplyWithSort();
    });
  });
  // Close sort on outside click
  document.addEventListener('click', function() {
    var dd = document.getElementById('smfSortDropdown');
    if (dd) dd.classList.remove('open');
  });

  var smfFetchController = null;

  function smfApplyWithSort() {
    var params = [];
    Object.keys(state).forEach(function(k) {
      if (state[k].val !== '') params.push(encodeURIComponent(k) + '=' + encodeURIComponent(state[k].val));
    });
    if (activeSortBy) params.push('sort_by=' + encodeURIComponent(activeSortBy));
    var url = window.location.pathname + (params.length ? '?' + params.join('&') : '');
    history.pushState({}, '', url);

    var grid = document.querySelector('#CollectionProductGrid, .collection__products, .product-grid, [class*="collection-grid"]');
    if (!grid) { window.location.href = url; return; }

    // 取消上一个还未完成的请求
    if (smfFetchController) {
      smfFetchController.abort();
    }
    smfFetchController = new AbortController();

    grid.style.opacity = '0.4';
    fetch(url, {
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      signal: smfFetchController.signal
    })
      .then(function(r){ return r.text(); })
      .then(function(html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newGrid = doc.querySelector('#CollectionProductGrid, .collection__products, .product-grid, [class*="collection-grid"]');
        if (newGrid) grid.innerHTML = newGrid.innerHTML;
        grid.style.opacity = '1';
        smfFetchController = null;
      })
      .catch(function(err){
        // AbortError 是主动取消，不需要恢复透明度
        if (err.name !== 'AbortError') {
          grid.style.opacity = '1';
        }
        smfFetchController = null;
      });
  }

  // ── Carousel scroll ──
  window.smfScroll = function(rowId, dir) {
    var row = document.getElementById(rowId);
    if (row) row.scrollBy({ left: dir * 180, behavior: 'smooth' });
  };

  // ── Open / Close ──
  window.smfOpen = function() {
    document.getElementById('smfOverlay').classList.add('open');
    document.getElementById('smfSheet').classList.add('open');
    document.body.style.overflow = 'hidden';
  };
  window.smfClose = function() {
    document.getElementById('smfOverlay').classList.remove('open');
    document.getElementById('smfSheet').classList.remove('open');
    document.body.style.overflow = '';
  };

  // ── Pick item ──
  document.querySelectorAll('[data-key]').forEach(function(el) {
    el.addEventListener('click', function() {
      var key   = el.dataset.key;
      var val   = el.dataset.val;
      var label = el.dataset.label || val || 'All';
      // deselect group
      el.closest('[id]').querySelectorAll('[data-key="' + key + '"]').forEach(function(b){ b.classList.remove('active'); });
      el.classList.add('active');
      state[key].val   = val;
      state[key].label = label;
      document.getElementById(state[key].labelEl).textContent = label;
      updateBadge();
    });
  });

  // ── Update badges + chips ──
  function updateBadge() {
    var count = 0;
    var chips = [];
    Object.keys(state).forEach(function(k) {
      if (state[k].val !== '') {
        count++;
        chips.push({ key: k, label: state[k].label });
      }
    });
    ['smfTopBadge','smfFloatBadge','smfSheetBadge'].forEach(function(id){
      var el = document.getElementById(id);
      if (el) el.textContent = count;
    });
    // render chips
    var chipsEl = document.getElementById('smfChips');
    chipsEl.innerHTML = '';
    chips.forEach(function(c) {
      var chip = document.createElement('div');
      chip.className = 'smf-chip';
      chip.innerHTML = c.label + ' <span class="smf-chip-x">×</span>';
      chip.addEventListener('click', function() { removeFilter(c.key); });
      chipsEl.appendChild(chip);
    });
  }

  function removeFilter(key) {
    // Update state
    state[key].val = '';
    state[key].label = 'All';

    // Safely update sheet label (might not be visible)
    try {
      var labelEl = document.getElementById(state[key].labelEl);
      if (labelEl) labelEl.textContent = 'All';
    } catch(e) {}

    // Reset active state in sheet rows
    try {
      var allBtn = document.querySelector('[data-key="' + key + '"][data-val=""]');
      if (allBtn) {
        allBtn.closest('.smf-metal-row, .smf-shape-row, .smf-carat-wrap, .smf-color-wrap').querySelectorAll('[data-key="' + key + '"]').forEach(function(b){ b.classList.remove('active'); });
        allBtn.classList.add('active');
      }
    } catch(e) {}

    // Rebuild chips and badges
    updateBadge();

    // Apply filters immediately
    smfApplyWithSort();
  }

  // ── Reset ──
  document.getElementById('smfResetBtn').addEventListener('click', function() {
    Object.keys(state).forEach(function(k) {
      state[k].val = '';
      state[k].label = 'All';
      try {
        var labelEl = document.getElementById(state[k].labelEl);
        if (labelEl) labelEl.textContent = 'All';
        var allBtn = document.querySelector('[data-key="' + k + '"][data-val=""]');
        if (allBtn) {
          allBtn.closest('.smf-metal-row, .smf-shape-row, .smf-carat-wrap, .smf-color-wrap').querySelectorAll('[data-key="' + k + '"]').forEach(function(b){ b.classList.remove('active'); });
          allBtn.classList.add('active');
        }
      } catch(e) {}
    });
    updateBadge();
    smfApplyWithSort();
  });

  // ── View Results → trigger Shopify native AJAX filter ──
  document.getElementById('smfViewBtn').addEventListener('click', function() {
    smfClose();

    var params = [];
    Object.keys(state).forEach(function(k) {
      if (state[k].val !== '') params.push(encodeURIComponent(k) + '=' + encodeURIComponent(state[k].val));
    });
    if (activeSortBy) params.push('sort_by=' + encodeURIComponent(activeSortBy));
    var url = window.location.pathname + (params.length ? '?' + params.join('&') : '');

    // Update browser URL
    history.pushState({}, '', url);

    // Find product grid and replace via fetch
    var grid = document.querySelector('#CollectionProductGrid, .collection__products, .product-grid, [class*="collection-grid"]');
    if (!grid) { window.location.href = url; return; }

    grid.style.opacity = '0.4';
    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r){ return r.text(); })
      .then(function(html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newGrid = doc.querySelector('#CollectionProductGrid, .collection__products, .product-grid, [class*="collection-grid"]');
        if (newGrid) { grid.innerHTML = newGrid.innerHTML; }
        grid.style.opacity = '1';
      })
      .catch(function(){ grid.style.opacity = '1'; });
  });

  // ── Scroll: show/hide float button ──
  var floatEl = document.getElementById('smfFloat');
  var barEl   = document.getElementById('smfFilterBar');
  function onScroll() {
    if (!barEl || !floatEl) return;
    var gone = barEl.getBoundingClientRect().bottom < 0;
    floatEl.classList.toggle('visible', gone);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>



