{% comment %}
  ============================================================
  Section: Solarii Mobile Filter
  File:    sections/solarii-mobile-filter.liquid

  手机端筛选模块：
  - Hero 标题区
  - 顶部 sticky Filter Bar（Filters按钮 + Sort）
  - 激活筛选 chips 行
  - 浮动 Filters 按钮（滚动后出现）
  - 底部上滑抽屉（Metal / Shape / Carat / Stone Color）

  点击 View Results → 触发原生 Shopify AJAX 筛选
  把此 section 放在 Collection products section 上方
  ============================================================
{% endcomment %}

<style>
/* ── HERO ── */
.smf-hero{text-align:center;padding:28px 16px 16px;background:#fafaf8}
.smf-hero-title{font-family:var(--font-heading-family,'Playfair Display',serif);font-size:26px;font-weight:400;margin-bottom:8px;letter-spacing:.01em}
.smf-hero-sub{font-size:12px;color:#888;line-height:1.6}

/* ── STICKY FILTER BAR ── */
.smf-filter-bar{display:flex;align-items:center;gap:8px;padding:10px 16px;background:#fff;border-bottom:1px solid #eee;position:sticky;top:0;z-index:20}
.smf-filter-btn{display:flex;align-items:center;gap:6px;height:34px;padding:0 14px;border:1px solid #ccc;border-radius:8px;background:#fff;font-family:inherit;font-size:13px;cursor:pointer;transition:border-color .15s}
.smf-filter-btn:hover{border-color:#888}
.smf-filter-badge{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;background:#111;color:#fff;border-radius:50%;font-size:10px;font-weight:700}
/* ── SORT DROPDOWN ── */
.smf-sort-wrap{position:relative;margin-left:auto}
.smf-sort-btn{display:flex;align-items:center;gap:5px;height:34px;padding:0 12px;border:1px solid #ccc;border-radius:8px;background:#fff;font-family:inherit;font-size:13px;cursor:pointer;white-space:nowrap;transition:border-color .15s}
.smf-sort-btn:hover{border-color:#888}
.smf-sort-dropdown{position:absolute;top:calc(100% + 6px);right:0;background:#fff;border:1px solid #e0e0e0;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.12);min-width:190px;z-index:30;opacity:0;pointer-events:none;transform:translateY(6px);transition:opacity .18s,transform .18s}
.smf-sort-dropdown.open{opacity:1;pointer-events:all;transform:translateY(0)}
.smf-sort-opt{display:block;width:100%;text-align:left;padding:11px 16px;background:none;border:none;font-family:inherit;font-size:13px;color:#333;cursor:pointer;transition:background .15s}
.smf-sort-opt:first-child{border-radius:12px 12px 0 0}
.smf-sort-opt:last-child{border-radius:0 0 12px 12px}
.smf-sort-opt:hover{background:#f5f5f3}
.smf-sort-opt.active{font-weight:600;color:#111}

/* ── ACTIVE CHIPS ── */
.smf-chips{display:flex;gap:8px;padding:8px 16px;overflow-x:auto;background:#fff;border-bottom:1px solid #f0f0f0;scrollbar-width:none;min-height:0;transition:min-height .2s}
.smf-chips:empty,.smf-chips.hidden{display:none}
.smf-chips::-webkit-scrollbar{display:none}
.smf-chip{display:flex;align-items:center;gap:5px;height:28px;padding:0 10px;border:1px solid #ccc;border-radius:20px;font-size:12px;white-space:nowrap;background:#fff;cursor:pointer;flex-shrink:0}
.smf-chip-x{color:#aaa;font-size:14px;line-height:1}

/* ── FLOATING BUTTON ── */
.smf-float{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);z-index:50;opacity:0;pointer-events:none;transition:transform .32s cubic-bezier(.32,1,.24,1),opacity .28s ease}
.smf-float.visible{transform:translateX(-50%) translateY(0);opacity:1;pointer-events:all}
.smf-float-btn{display:flex;align-items:center;gap:8px;height:46px;padding:0 26px;background:#111;color:#fff;border:none;border-radius:999px;font-family:inherit;font-size:14px;font-weight:500;letter-spacing:.04em;cursor:pointer;box-shadow:0 6px 24px rgba(0,0,0,.28);transition:background .18s}
.smf-float-btn:hover{background:#333}
.smf-float-btn:active{transform:scale(.97)}
.smf-float-badge{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;background:#fff;color:#111;border-radius:50%;font-size:11px;font-weight:700}

/* ── OVERLAY ── */
.smf-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:100;opacity:0;pointer-events:none;transition:opacity .3s}
.smf-overlay.open{opacity:1;pointer-events:all}

/* ── BOTTOM SHEET ── */
.smf-sheet{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:20px 20px 0 0;z-index:101;transform:translateY(100%);transition:transform .35s cubic-bezier(.32,1,.24,1);display:flex;flex-direction:column;max-height:75vh;min-height:200px}
.smf-sheet.open{transform:translateY(0)}
.smf-handle{width:36px;height:4px;background:#ddd;border-radius:2px;margin:12px auto 0;flex-shrink:0}
.smf-sheet-header{display:flex;align-items:center;padding:12px 16px;border-bottom:1px solid #f0f0f0;flex-shrink:0}
.smf-sheet-reset{font-size:12px;color:#888;background:none;border:none;font-family:inherit;cursor:pointer;display:flex;align-items:center;gap:4px}
.smf-sheet-title{flex:1;text-align:center;font-size:14px;font-weight:500}
.smf-sheet-close{width:28px;height:28px;border-radius:50%;border:1px solid #ddd;background:none;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:#666;line-height:1}
.smf-sheet-body{overflow-y:auto;flex:1;-webkit-overflow-scrolling:touch}
.smf-section{padding:16px 16px 12px}
.smf-section-label{font-size:13px;color:#888;margin-bottom:12px}
.smf-section-label strong{color:#161616;font-weight:500}
.smf-divider{height:1px;background:#f0f0f0}

/* Metal scroll */
.smf-metal-row{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding:2px 2px 4px;scroll-snap-type:x mandatory}
.smf-metal-row::-webkit-scrollbar{display:none}
.smf-metal-card{display:flex;flex-direction:column;align-items:center;gap:6px;padding:10px 12px;border-radius:12px;border:1.5px solid #eee;cursor:pointer;flex-shrink:0;scroll-snap-align:start;transition:border-color .15s;min-width:78px}
.smf-metal-card.active{border-color:#111;background:#fafaf8}
.smf-metal-circle{width:38px;height:38px;border-radius:50%;border:1.5px solid #ddd}
/* ── Image override for filter items ── */
.smf-item-img{width:38px;height:38px;border-radius:50%;object-fit:cover;border:1.5px solid #eee;display:block}
.smf-shape-img{width:38px;height:38px;object-fit:contain;display:block}
.smf-metal-img{width:38px;height:38px;border-radius:50%;object-fit:cover;display:block}
.smf-color-img{width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid transparent;transition:border-color .15s}
.smf-color-item.active .smf-color-img{border-color:#111;box-shadow:0 0 0 2px #fff,0 0 0 3.5px #111}

.smf-metal-card span{font-size:11px;color:#333;text-align:center;white-space:nowrap}

/* Shape scroll */
.smf-shape-row{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding:2px 2px 4px;scroll-snap-type:x mandatory}
.smf-shape-row::-webkit-scrollbar{display:none}
.smf-shape-card{display:flex;flex-direction:column;align-items:center;gap:5px;padding:10px 10px;border-radius:12px;border:1.5px solid #eee;cursor:pointer;flex-shrink:0;scroll-snap-align:start;transition:border-color .15s;min-width:68px}
.smf-shape-card.active{border-color:#111;background:#fafaf8}
.smf-shape-card svg path,.smf-shape-card svg polygon,.smf-shape-card svg rect{fill:none!important;stroke:#111!important;stroke-width:1px!important}
.smf-shape-card span{font-size:10.5px;color:#333;white-space:nowrap}

/* Carat pills */
.smf-carat-wrap{display:flex;flex-wrap:wrap;gap:6px}
.smf-carat-pill{height:30px;padding:0 12px;border-radius:8px;border:1.5px solid #eee;background:#fff;font-family:inherit;font-size:11.5px;color:#444;cursor:pointer;transition:border-color .15s,background .15s}
.smf-carat-pill.active{border-color:#111;background:#111;color:#fff;font-weight:500}

/* Color dots */
.smf-color-wrap{display:flex;flex-wrap:wrap;gap:10px}
.smf-color-item{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;min-width:44px}
.smf-color-dot{width:34px;height:34px;border-radius:50%;border:2px solid transparent;transition:border-color .15s}
.smf-color-item.active .smf-color-dot{border-color:#111;box-shadow:0 0 0 2px #fff,0 0 0 3.5px #111}
.smf-color-item span{font-size:9.5px;color:#555;text-align:center}

/* Carousel wrap with arrow buttons */
.smf-carousel-wrap{display:flex;align-items:center;gap:4px}
.smf-carr-btn{
  width:28px;height:28px;min-width:28px;
  border-radius:50%;
  border:1px solid #e0e0e0;
  background:#fff;
  box-shadow:0 2px 6px rgba(0,0,0,.12);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
  font-size:16px;line-height:1;
  color:#444;
  padding:0;
  flex-shrink:0;
  transition:box-shadow .15s;
  -webkit-tap-highlight-color:transparent;
}
.smf-carr-btn:hover{box-shadow:0 3px 10px rgba(0,0,0,.2)}
.smf-carousel-wrap .smf-metal-row,
.smf-carousel-wrap .smf-shape-row{flex:1;min-width:0}

/* Sheet footer */
.smf-view-btn{width:100%;height:50px;background:#111;color:#fff;border:none;border-radius:14px;font-family:inherit;font-size:15px;font-weight:500;cursor:pointer;letter-spacing:.02em;transition:background .2s}
.smf-view-btn:hover{background:#333}

/* Desktop: hide this whole section */
@media (min-width: 768px) {
  .smf-hero,.smf-filter-bar,.smf-chips,.smf-float,.smf-overlay,.smf-sheet{display:none!important}
}
</style>

<!-- ── HERO ── -->
<div class="smf-hero" style="padding-top:{{ section.settings.padding_top }}px;zoom:{{ section.settings.mobile_font_scale | divided_by: 100.0 }};max-width:{{ section.settings.mobile_max_width }}px;margin-left:auto;margin-right:auto">
  <h2 class="smf-hero-title">{{ section.settings.title | default: 'Engagement Rings' }}</h2>
  <p class="smf-hero-sub">{{ section.settings.subtitle | default: 'Discover our collection of made to order engagement rings and customize it to your preference' }}</p>
</div>

<!-- ── STICKY FILTER BAR ── -->
<div class="smf-filter-bar" id="smfFilterBar" style="zoom:{{ section.settings.mobile_font_scale | divided_by: 100.0 }};max-width:{{ section.settings.mobile_max_width }}px;margin-left:auto;margin-right:auto">
  <button class="smf-filter-btn" type="button" onclick="smfOpen()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#444" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
    Filters <span class="smf-filter-badge" id="smfTopBadge">0</span>
  </button>

  <!-- Sort dropdown -->
  <div class="smf-sort-wrap" id="smfSortWrap">
    <button class="smf-sort-btn" type="button" onclick="smfToggleSort(event)">
      <span id="smfSortLabel">Sort By</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="smf-sort-dropdown" id="smfSortDropdown">
      <button class="smf-sort-opt" data-sort="" type="button">Featured</button>
      <button class="smf-sort-opt" data-sort="best-selling" type="button">Best selling</button>
      <button class="smf-sort-opt" data-sort="title-ascending" type="button">Alphabetically, A-Z</button>
      <button class="smf-sort-opt" data-sort="title-descending" type="button">Alphabetically, Z-A</button>
      <button class="smf-sort-opt" data-sort="price-ascending" type="button">Price, low to high</button>
      <button class="smf-sort-opt" data-sort="price-descending" type="button">Price, high to low</button>
      <button class="smf-sort-opt" data-sort="created-ascending" type="button">Date, old to new</button>
      <button class="smf-sort-opt" data-sort="created-descending" type="button">Date, new to old</button>
    </div>
  </div>
</div>

<!-- ── ACTIVE CHIPS ── -->
<div class="smf-chips" id="smfChips"></div>
<div style="padding-bottom:{{ section.settings.padding_bottom }}px"></div>

<!-- ── FLOATING BUTTON ── -->
<div class="smf-float" id="smfFloat">
  <button class="smf-float-btn" type="button" onclick="smfOpen()">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
    Filters
    <span class="smf-float-badge" id="smfFloatBadge">0</span>
  </button>
</div>

<!-- ── OVERLAY ── -->
<div class="smf-overlay" id="smfOverlay" onclick="smfClose()"></div>

<!-- ── BOTTOM SHEET ── -->
<div class="smf-sheet" id="smfSheet" style="zoom:{{ section.settings.mobile_font_scale | divided_by: 100.0 }};max-width:{{ section.settings.mobile_max_width }}px">
  <div class="smf-handle"></div>
  <div class="smf-sheet-header">
    <button class="smf-sheet-reset" type="button" id="smfResetBtn">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
      Reset
    </button>
    <span class="smf-sheet-title">Filters <span id="smfSheetBadge">0</span></span>
    <button class="smf-sheet-close" type="button" onclick="smfClose()">×</button>
  </div>

  <div class="smf-sheet-body">

    <!-- Metal -->
    <div class="smf-section">
      <div class="smf-section-label">Metal : <strong id="smfMetalLabel">All</strong></div>
      <div class="smf-carousel-wrap">
        <button class="smf-carr-btn smf-carr-prev" onclick="smfScroll('smfMetalRow',-1)" type="button"><svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M7 1L1 7L7 13" stroke="#444" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="smf-metal-row" id="smfMetalRow">
        <div class="smf-metal-card active" data-key="filter.p.m.custom.plating_color" data-val="" data-label="All">
          <div class="smf-metal-circle" style="background:linear-gradient(135deg,#d8d8d8 50%,#d4a820 50%)"></div>
          <span>All</span>
        </div>
        {%- assign plating_list = section.settings.plating_values | split: ',' -%}
        {%- assign dot_styles = 'radial-gradient(circle at 35% 35%,#fff 0%,#d8d8d8 55%,#aaa 100%)|radial-gradient(circle at 35% 35%,#fff5a0 0%,#d4a820 55%,#a07010 100%)|radial-gradient(circle at 35% 35%,#ffd8c8 0%,#d07860 55%,#a04030 100%)|linear-gradient(135deg,#d4a820 50%,#d8d8d8 50%)|radial-gradient(circle at 35% 35%,#555 0%,#222 55%,#000 100%)' | split: '|' -%}
        {%- assign metal_img_ids = 'img_white_gold|img_yellow_gold|img_rose_gold|img_two_tone|img_black_gold' | split: '|' -%}
        {%- for metal in plating_list -%}
          {%- assign m = metal | strip -%}
          {%- assign img_id = metal_img_ids[forloop.index0] -%}
          {%- assign img = section.settings[img_id] -%}
          <div class="smf-metal-card" data-key="filter.p.m.custom.plating_color" data-val="{{ m }}" data-label="{{ m }}">
            {%- if img -%}
              <img src="{{ img | image_url: width: 160 }}" alt="{{ m }}" class="smf-metal-img" width="38" height="38">
            {%- else -%}
              <div class="smf-metal-circle" style="background:{{ dot_styles[forloop.index0] }}"></div>
            {%- endif -%}
            <span>{{ m }}</span>
          </div>
        {%- endfor -%}
      </div>
      <button class="smf-carr-btn smf-carr-next" onclick="smfScroll('smfMetalRow',1)" type="button"><svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1L7 7L1 13" stroke="#444" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      </div>
    </div>
    <div class="smf-divider"></div>

    <!-- Shape -->
