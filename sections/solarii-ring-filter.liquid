</div>

<script>
(function () {
  // ── 当前激活的筛选值
  var activeFilters = {
    'filter.p.m.custom.stone_shape':   '',
    'filter.p.m.custom.carat':         '',
    'filter.p.m.custom.stone_color':   '',
    'filter.p.m.custom.plating_color': ''
  };

  // ── 找到 Collection products 的产品容器
  // TS Broadcast 主题一般用 #CollectionProductGrid 或 .collection-product-grid 或 product-grid
  function getProductGrid() {
    return document.querySelector('#CollectionProductGrid')
      || document.querySelector('.collection__products')
      || document.querySelector('.product-grid')
      || document.querySelector('[data-id][class*="collection"]')
      || null;
  }

  // ── 构建带筛选参数的 URL
  function buildFilterUrl() {
    var params = [];
    Object.keys(activeFilters).forEach(function (key) {
      if (activeFilters[key] !== '') {
        params.push(encodeURIComponent(key) + '=' + encodeURIComponent(activeFilters[key]));
      }
    });
    if (desktopSortBy) {
      params.push('sort_by=' + encodeURIComponent(desktopSortBy));
    }
    var base = window.location.pathname;
    return params.length > 0 ? base + '?' + params.join('&') : base;
  }

  // ── fetch 并替换产品网格
  var srfFetchController = null;

  function applyFilters() {
    var url = buildFilterUrl();
    var grid = getProductGrid();
    var loading = document.getElementById('srfLoading');

    history.pushState({}, '', url);

    // 取消上一个未完成的请求
    if (srfFetchController) srfFetchController.abort();
    srfFetchController = new AbortController();

    if (loading) loading.style.display = 'flex';
    if (grid) grid.style.opacity = '0.4';

    fetch(url, {
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      signal: srfFetchController.signal
    })
      .then(function (res) { return res.text(); })
      .then(function (html) {
        var parser = new DOMParser();
        var doc = parser.parseFromString(html, 'text/html');

        var selectors = [
          '#CollectionProductGrid',
          '.collection__products',
          '.product-grid',
          '[data-id][class*="collection"]',
          '.collection-product-grid'
        ];
        var newGrid = null;
        for (var i = 0; i < selectors.length; i++) {
          newGrid = doc.querySelector(selectors[i]);
          if (newGrid) break;
        }

        if (newGrid && grid) {
          grid.innerHTML = newGrid.innerHTML;
          grid.style.opacity = '1';
          if (window.Shopify && window.Shopify.loadFeatures) {
            document.querySelectorAll('img[data-src]').forEach(function(img) { img.src = img.dataset.src; });
          }
        } else if (grid) {
          grid.style.opacity = '1';
        }

        var countEl = doc.querySelector('.collection__product-count, [data-product-count], .product-count');
        var srfCount = document.getElementById('srfCount');
        if (countEl && srfCount) srfCount.textContent = countEl.textContent.trim();

        if (loading) loading.style.display = 'none';
        updateResetBar();
        srfFetchController = null;
      })
      .catch(function (err) {
        if (err.name !== 'AbortError') {
          if (grid) grid.style.opacity = '1';
          if (loading) loading.style.display = 'none';
        }
        srfFetchController = null;
      });
  }

  // ── 检查是否有激活的筛选
  function hasActiveFilters() {
    return Object.values(activeFilters).some(function (v) { return v !== ''; });
  }

  function updateResetBar() {
    var resetBtn = document.getElementById('srfResetBtn');
    if (resetBtn) resetBtn.style.display = hasActiveFilters() ? 'inline-block' : 'none';
  }

  // ── Desktop Sort ──
  var desktopSortBy = '';
  window.srfToggleDesktopSort = function(e) {
    e.stopPropagation();
    var dd = document.getElementById('srfSortDropdown');
    var btn = document.getElementById('srfSortBtn');
    dd.classList.toggle('open');
    btn.classList.toggle('open');
  };
  document.querySelectorAll('.srf-sort-opt').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      desktopSortBy = btn.dataset.sort;
      document.getElementById('srfDesktopSortLabel').textContent = btn.textContent.trim();
      document.querySelectorAll('.srf-sort-opt').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      document.getElementById('srfSortDropdown').classList.remove('open');
      document.getElementById('srfSortBtn').classList.remove('open');
      applyFilters();
    });
  });
  document.addEventListener('click', function() {
    var dd = document.getElementById('srfSortDropdown');
    var btn = document.getElementById('srfSortBtn');
    if (dd) dd.classList.remove('open');
    if (btn) btn.classList.remove('open');
  });

  // ── 绑定所有筛选按钮
  document.querySelectorAll('[data-filter-key]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var key = btn.dataset.filterKey;
      var val = btn.dataset.filterVal;
      var group = btn.closest('.srf-row-tabs, .srf-metal-bar');
      if (group) {
        group.querySelectorAll('[data-filter-key="' + key + '"]').forEach(function (b) {
          b.classList.remove('active');
        });
      }
      btn.classList.add('active');
      activeFilters[key] = val;
      applyFilters();
    });
  });

  // ── Reset 按钮
  document.getElementById('srfResetBtn') && document.getElementById('srfResetBtn').addEventListener('click', function () {
    Object.keys(activeFilters).forEach(function (k) { activeFilters[k] = ''; });
    document.querySelectorAll('[data-filter-key]').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.filterVal === '');
    });
    applyFilters();
  });

  // ── Mobile sheet open/close ──
  window.srfOpenSheet = function() {
    document.getElementById('srfOverlay').classList.add('open');
    document.getElementById('srfSheet').classList.add('open');
    document.body.style.overflow = 'hidden';
  };
  window.srfCloseSheet = function() {
    document.getElementById('srfOverlay').classList.remove('open');
    document.getElementById('srfSheet').classList.remove('open');
    document.body.style.overflow = '';
  };

  // ── Mobile: show/hide floating button on scroll ──
  var srfFloatWrap = document.getElementById('srfFloatWrap');
  if (srfFloatWrap) {
    function srfCheckScroll() {
      var scrollY = window.scrollY || window.pageYOffset || document.documentElement.scrollTop;
      srfFloatWrap.classList.toggle('srf-float-visible', scrollY > 80);
    }
    window.addEventListener('scroll', srfCheckScroll, { passive: true });
    srfCheckScroll();
  }

  // ── Mobile: sync sheet selections with activeFilters ──
  document.querySelectorAll('[data-sheet-filter-key]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = btn.dataset.sheetFilterKey;
      var val = btn.dataset.sheetFilterVal;
      var label = btn.dataset.sheetLabel || val || 'All';

      btn.closest('.srf-sheet-row-tabs').querySelectorAll('[data-sheet-filter-key="' + key + '"]').forEach(function(b) {
        b.classList.remove('active');
      });
      btn.classList.add('active');
      activeFilters[key] = val;

      // update label
      var labelEl = document.getElementById('srfSheetLabel_' + key.split('.').pop());
      if (labelEl) labelEl.textContent = label;

      // sync desktop tabs
      document.querySelectorAll('[data-filter-key="' + key + '"]').forEach(function(b) {
        b.classList.toggle('active', b.dataset.filterVal === val);
      });

      srfUpdateMobileBadge();
    });
  });

  function srfUpdateMobileBadge() {
    var count = Object.values(activeFilters).filter(function(v){ return v !== ''; }).length;
    var badge = document.getElementById('srfFloatBadge');
    var sheetBadge = document.getElementById('srfSheetBadge');
    if (badge) { badge.textContent = count; badge.style.display = count > 0 ? 'inline-flex' : 'none'; }
    if (sheetBadge) sheetBadge.textContent = count;
  }

  // Reset from sheet
  document.getElementById('srfSheetReset') && document.getElementById('srfSheetReset').addEventListener('click', function() {
    Object.keys(activeFilters).forEach(function(k) { activeFilters[k] = ''; });
    document.querySelectorAll('[data-filter-key],[data-sheet-filter-key]').forEach(function(btn) {
      var val = btn.dataset.filterVal || btn.dataset.sheetFilterVal;
      btn.classList.toggle('active', val === '');
    });
    ['stone_shape','carat','stone_color','plating_color'].forEach(function(k) {
      var el = document.getElementById('srfSheetLabel_' + k);
      if (el) el.textContent = 'All';
    });
    srfUpdateMobileBadge();
    applyFilters();
  });

  srfUpdateMobileBadge();

})();
</script>

