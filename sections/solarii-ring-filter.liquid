          <button class="srf-sort-opt" data-sort="best-selling" type="button">Best selling</button>
          <button class="srf-sort-opt" data-sort="title-ascending" type="button">Alphabetically, A-Z</button>
          <button class="srf-sort-opt" data-sort="title-descending" type="button">Alphabetically, Z-A</button>
          <button class="srf-sort-opt" data-sort="price-ascending" type="button">Price, low to high</button>
          <button class="srf-sort-opt" data-sort="price-descending" type="button">Price, high to low</button>
          <button class="srf-sort-opt" data-sort="created-ascending" type="button">Date, old to new</button>
