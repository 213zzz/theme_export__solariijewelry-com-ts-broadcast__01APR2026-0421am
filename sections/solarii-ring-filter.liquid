        {% if section.settings.img_shape_round %}<div class="smf-shape-card" data-key="filter.p.m.custom.stone_shape" data-val="Round Cut" data-label="Round"><img class="smf-shape-img" src="{{ section.settings.img_shape_round | image_url: width: 160 }}" alt="Round" loading="lazy"><span>Round</span></div>{% else %}<div class="smf-shape-card" data-key="filter.p.m.custom.stone_shape" data-val="Round Cut" data-label="Round"><svg viewBox="0 0 40 40" width="36" height="36"><path fill-rule="evenodd" d="M31.458 20C31.458 26.318 26.318 31.458 20 31.458C13.682 31.458 8.542 26.318 8.542 20C8.542 13.682 13.682 8.542 20 8.542C26.318 8.542 31.458 13.682 31.458 20ZM26.09 22.529L26.095 17.482L22.529 13.91L17.482 13.905L13.91 17.471L13.905 22.518L17.471 26.09L22.518 26.095Z" fill="black"/></svg><span>Round</span></div>{% endif %}
        {% if section.settings.img_shape_oval %}<div class="smf-shape-card" data-key="filter.p.m.custom.stone_shape" data-val="Oval Cut" data-label="Oval"><img class="smf-shape-img" src="{{ section.settings.img_shape_oval | image_url: width: 160 }}" alt="Oval" loading="lazy"><span>Oval</span></div>{% else %}<div class="smf-shape-card" data-key="filter.p.m.custom.stone_shape" data-val="Oval Cut" data-label="Oval"><svg viewBox="0 0 40 40" width="36" height="36"><path fill-rule="evenodd" d="M30.5 20C30.5 27.732 25.799 34 20 34C14.201 34 9.5 27.732 9.5 20C9.5 12.268 14.201 6 20 6C25.799 6 30.5 12.268 30.5 20ZM23.981 25.761L25.689 20L23.981 14.24L20 11.934L16.019 14.24L14.312 20L16.019 25.761L20 28.067Z" fill="black"/></svg><span>Oval</span></div>{% endif %}
        {% if section.settings.img_shape_pear %}<div class="smf-shape-card" data-key="filter.p.m.custom.stone_shape" data-val="Pear Cut" data-label="Pear"><img class="smf-shape-img" src="{{ section.settings.img_shape_pear | image_url: width: 160 }}" alt="Pear" loading="lazy"><span>Pear</span></div>{% else %}<div class="smf-shape-card" data-key="filter.p.m.custom.stone_shape" data-val="Pear Cut" data-label="Pear"><svg viewBox="0 0 40 40" width="36" height="36"><path fill="none" stroke="black" stroke-width="1.4" d="M20 5C10 11 10 21 10 21C10 28 14.5 33 20 33C25.5 33 30 28 30 21C30 21 30 11 20 5Z"/><path fill="black" d="M24.6 22L22.5 15.1L20 12.3L17.5 15.1L15.4 22L16.9 26L20 27.3L23.1 26Z"/></svg><span>Pear</span></div>{% endif %}
