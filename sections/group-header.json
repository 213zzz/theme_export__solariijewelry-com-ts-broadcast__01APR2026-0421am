-item\">⭐ 10,000+ 5-Star Reviews<\/div>\n      <div class=\"mg-slider-item\">Orders $99+ Get a Free Gift<\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<script>\n(function(){\n  \/* 倒计时 *\/\n  var el = document.getElementById('mgCountdown');\n  if (el) {\n    var end = new Date(el.getAttribute('data-end')).getTime();\n    function updateTimer() {\n      var d = Math.max(0, end - Date.now());\n      var h = Math.floor(d \/ 36e5), m = Math.floor(d % 36e5 \/ 6e4), s = Math.floor(d % 6e4 \/ 1e3);\n      document.getElementById('mgHours').textContent = h < 10 ? '0' + h : h;\n      document.getElementById('mgMins').textContent = m < 10 ? '0' + m : m;\n      document.getElementById('mgSecs').textContent = s < 10 ? '0' + s : s;\n      if (d > 0) setTimeout(updateTimer, 1000);\n    }\n    updateTimer();\n  }\n\n  \/* 右侧文字轮播 *\/\n  var slider = document.getElementById('mgSlider');\n  if (!slider) return;\n  var items = slider.querySelectorAll('.mg-slider-item');\n  if (items.length <= 1) return;\n\n  var current = 0;\n  var total = items.length;\n  var isAnimating = false;\n\n  setInterval(function() {\n    if (isAnimating) return;\n    isAnimating = true;\n\n    var next = (current + 1) % total;\n    var currentItem = items[current];\n    var nextItem = items[next];\n\n    \/* 当前项：向左滑出，到白线处被裁剪消失 *\/\n    currentItem.classList.remove('mg-active');\n    currentItem.classList.add('mg-exit');\n\n    \/* 下一项：从右边滑入 *\/\n    nextItem.style.transform = 'translateX(100%)';\n    nextItem.style.opacity = '0';\n    nextItem.classList.remove('mg-exit');\n\n    \/* 小延迟让浏览器注册初始位置 *\/\n    requestAnimationFrame(function() {\n      requestAnimationFrame(function() {\n        nextItem.classList.add('mg-enter');\n        nextItem.style.transform = '';\n        nextItem.style.opacity = '';\n      });\n    });\n\n    setTimeout(function() {\n      currentItem.classList.remove('mg-exit');\n      currentItem.style.transform = 'translateX(100%)';\n      currentItem.style.opacity = '0';\n\n      nextItem.classList.remove('mg-enter');\n      nextItem.classList.add('mg-active');\n\n      current = next;\n      isAnimating = false;\n    }, 600);\n\n  }, 3000);\n})();\n<\/script>","width":"wrapper","color_scheme":"","padding_top":0,"padding_bottom":0}},"mg_announcement_bar_VqUm9W":{"type":"mg-announcement-bar","blocks":{"slide_Be84jf":{"type":"slide","settings":{"text":"<p>Fast & Free Shipping<\/p>"}},"slide_VgpiBA":{"type":"slide","settings":{"text":"<p>Lifetime Warranty + Easy Returns<\/p>"}},"slide_G7Mwax":{"type":"slide","settings":{"text":"<p>⭐ 10,000+ 5-Star Reviews<\/p>"}}},"block_order":["slide_Be84jf","slide_VgpiBA","slide_G7Mwax"],"name":"✨ Announcement bar","settings":{"left_text":"<p>Get 20% Off ✨ Code: <strong>SAVE20<\/strong><\/p>","show_countdown":true,"end_date":"2026-12-31","end_time":"11:59","period":"pm","label_hours":"HR","label_mins":"MIN","label_secs":"SEC","slide_speed":3,"slider_width":280,"bg_color":"#000000","text_color":"#ffffff","sep_color":"#000000","font_size":13,"padding_top":8,"padding_bottom":8}},"header":{"type":"header","blocks":{"mega_icon_tMxDNa":{"type":"mega_icon","settings":{"menu_item_title":"PRINCESS CUT","custom_image":"shopify:\/\/shop_images\/8913d390-cdf2-4c7b-b7aa-bdb740f88024.png"}},"mega_icon_BXXpCA":{"type":"mega_icon","settings":{"menu_item_title":"MARQUISE CUT","custom_image":"shopify:\/\/shop_images\/7064fe1d-fa2b-48c4-a11b-c2508bf72dee.png"}},"mega_icon_V6qRjX":{"type":"mega_icon","settings":{"menu_item_title":"HEART CUT","custom_image":"shopify:\/\/shop_images\/6d1742f4-e0e8-41f9-9085-63c8043d988f.png"}},"mega_icon_YHAPEp":{"type":"mega_icon","settings":{"menu_item_title":"CUSHION CUT","custom_image":"shopify:\/\/shop_images\/d75a23cf-74de-44c9-ad64-2d8623b43d9b.png"}},"mega_icon_ybqYFq":{"type":"mega_icon","settings":{"menu_item_title":"EMERALD CUT","custom_image":"shopify:\/\/shop_images\/cac351ea-c807-4eb8-b73f-2552cca049c1.png"}},"mega_icon_TPGgkt":{"type":"mega_icon","settings":{"menu_item_title":"PEAR CUT"