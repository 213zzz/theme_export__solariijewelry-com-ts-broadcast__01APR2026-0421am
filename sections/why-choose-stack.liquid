  <script>
    (function() {
      var section = document.getElementById('{{ section_id }}');
      if (!section) return;

      var desktopItems = Array.prototype.slice.call(section.querySelectorAll('.spc-stack .spc-item'));
      var mobileRoot = section.querySelector('[data-mobile-stack]');
      var mobileItems = mobileRoot ? Array.prototype.slice.call(mobileRoot.querySelectorAll('.spc-mobile-item')) : [];

      var desktopMQ = window.matchMedia('(min-width: 990px)');
      var mobileMQ = window.matchMedia('(max-width: 989px)');
      var ticking = false;

      function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
      }

      function ease(t) {
        return 1 - Math.pow(1 - t, 3);
      }

      function getHeaderOffset() {
        var selectors = [
          'sticky-header',
          '#shopify-section-header',
          '.shopify-section-group-header-group',
          '.shopify-section-header-sticky',
          '[data-sticky-header]',
          '.header-wrapper',
          'header.header',
          'header'
        ];

        var maxBottom = 0;

        selectors.forEach(function(selector) {
          document.querySelectorAll(selector).forEach(function(el) {
            if (!el || !el.getBoundingClientRect) return;

            var rect = el.getBoundingClientRect();
            if (rect.width <= 0 || rect.height <= 0) return;

            var style = window.getComputedStyle(el);
            var pos = style.position;
            var stickyLike = pos === 'sticky' || pos === 'fixed';
            var nearTop = rect.top <= 5 && rect.bottom > 0;

            if ((stickyLike || nearTop) && rect.bottom > maxBottom) {
              maxBottom = rect.bottom;
            }
          });
        });

        return Math.max(0, Math.round(maxBottom));
      }

      function updateHeaderOffset() {
        var headerOffset = getHeaderOffset();
        section.style.setProperty('--spc-header-offset', headerOffset + 'px');
      }

      function resetDesktop() {
        desktopItems.forEach(function(item) {
          var card = item.querySelector('.spc-card');
          var content = item.querySelector('.spc-content');
          var media = item.querySelector('.spc-media img, .spc-media svg');

          if (card) {
            card.style.setProperty('--spc-desktop-shrink', '0');
            card.style.setProperty('--spc-desktop-lift', '0px');
          }
          if (content) {
            content.style.transform = '';
          }
          if (media) {
            media.style.transform = '';
          }
        });
      }

      function updateDesktop() {
        if (!desktopMQ.matches) {
          resetDesktop();
          return;
        }

        var style = getComputedStyle(section);
        var stickyBase = parseFloat(style.getPropertyValue('--spc-sticky-top-base')) || 24;
        var stickyExtra = parseFloat(style.getPropertyValue('--spc-sticky-extra')) || 0;
        var headerOffset = parseFloat(style.getPropertyValue('--spc-header-offset')) || 0;
        var stickyTop = stickyBase + stickyExtra + headerOffset;

        var gap = parseFloat(style.getPropertyValue('--spc-card-gap')) || 24;
        var maxShrink = clamp(parseFloat(style.getPropertyValue('--spc-desktop-shrink-setting')) || 0.10, 0.05, 0.25);
        var liftBase = Math.min(parseFloat(style.getPropertyValue('--spc-stack-offset')) || 26, 28);

        desktopItems.forEach(function(item, index) {
          var card = item.querySelector('.spc-card');
          var content = item.querySelector('.spc-content');
          var media = item.querySelector('.spc-media img, .spc-media svg');

          if (!card) return;

          var shrink = 0;
          var lift = 0;
          var contentShift = 0;
          var mediaScale = 1;

          if (index < desktopItems.length - 1) {
            var nextRect = desktopItems[index + 1].getBoundingClientRect();
            var cardRect = card.getBoundingClientRect();
            var triggerStart = stickyTop + cardRect.height + (gap * 0.9);
            var triggerEnd = stickyTop + 16;
            var denom = Math.max(1, triggerStart - triggerEnd);
            var pushProgress = clamp((triggerStart - nextRect.top) / denom, 0, 1);
            var pushEase = ease(pushProgress);

            shrink = maxShrink * pushEase;
            lift = -(liftBase * 0.45) * pushEase;
            contentShift = 10 * pushEase;
            mediaScale = 1 - (0.035 * pushEase);
          }

          card.style.setProperty('--spc-desktop-shrink', shrink.toFixed(4));
          card.style.setProperty('--spc-desktop-lift', lift.toFixed(2) + 'px');

          if (content) {
            content.style.transform = 'translate3d(0,' + contentShift.toFixed(2) + 'px,0)';
          }
          if (media) {
            media.style.transform = 'scale(' + mediaScale.toFixed(4) + ')';
          }
        });
      }

      function resetMobile() {
        mobileItems.forEach(function(item) {
          var card = item.querySelector('.spc-mobile-card');
          var content = item.querySelector('.spc-mobile-content');
          if (!card) return;
          card.style.setProperty('--spc-mobile-shrink', '0');
          card.style.setProperty('--spc-mobile-lift', '0px');
          if (content) {
            content.style.transform = '';
          }
        });
      }

      function setMobileLayoutVars() {
        if (!mobileMQ.matches || !mobileRoot) {
          resetMobile();
          return;
        }

        var style = getComputedStyle(section);
        var mobileBase = parseFloat(style.getPropertyValue('--spc-mobile-top-base')) || 104;
        var mobileExtra = parseFloat(style.getPropertyValue('--spc-mobile-extra')) || 0;
        var headerOffset = parseFloat(style.getPropertyValue('--spc-header-offset')) || 0;
        var stickyTop = mobileBase + mobileExtra + headerOffset;

        var gap = parseFloat(style.getPropertyValue('--spc-mobile-gap-setting')) || 96;

        mobileRoot.style.setProperty('--spc-mobile-top', stickyTop + 'px');
        mobileRoot.style.setProperty('--spc-mobile-gap', gap + 'px');
      }

      function updateMobile() {
        if (!mobileMQ.matches || !mobileRoot) return;

        var rootStyle = getComputedStyle(mobileRoot);
        var stickyTop = parseFloat(rootStyle.getPropertyValue('--spc-mobile-top')) || 78;
        var gap = parseFloat(rootStyle.getPropertyValue('--spc-mobile-gap')) || 96;
        var maxShrink = clamp(parseFloat(getComputedStyle(section).getPropertyValue('--spc-mobile-shrink-setting')) || 0.18, 0.05, 0.35);

        mobileItems.forEach(function(item, index) {
          var card = item.querySelector('.spc-mobile-card');
          var content = item.querySelector('.spc-mobile-content');
          if (!card) return;

          var lift = 0;
          var shrink = 0;
          var contentShift = 0;

          if (index < mobileItems.length - 1) {
            var nextRect = mobileItems[index + 1].getBoundingClientRect();
            var cardRect = card.getBoundingClientRect();
            var triggerStart = stickyTop + cardRect.height + (gap * 0.72);
            var triggerEnd = stickyTop + 12;
            var denom = Math.max(1, triggerStart - triggerEnd);
            var pushProgress = clamp((triggerStart - nextRect.top) / denom, 0, 1);
            var pushEase = ease(pushProgress);

            shrink = maxShrink * pushEase;
            lift = -10 * pushEase;
            contentShift = 8 * pushEase;
          }

          card.style.setProperty('--spc-mobile-shrink', shrink.toFixed(4));
          card.style.setProperty('--spc-mobile-lift', lift.toFixed(2) + 'px');

          if (content) {
            content.style.transform = 'translate3d(0,' + contentShift.toFixed(2) + 'px,0)';
          }
        });
      }

      function updateAll() {
        ticking = false;
        updateHeaderOffset();
        setMobileLayoutVars();
        updateDesktop();
        updateMobile();
      }

      function requestTick() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateAll);
      }

      function onResize() {
        updateAll();
      }

      if (desktopMQ.addEventListener) {
        desktopMQ.addEventListener('change', onResize);
        mobileMQ.addEventListener('change', onResize);
      } else if (desktopMQ.addListener) {
        desktopMQ.addListener(onResize);
        mobileMQ.addListener(onResize);
      }

      window.addEventListener('resize', onResize);
      window.addEventListener('orientationchange', onResize);
      window.addEventListener('scroll', requestTick, { passive: true });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          updateAll();
        }, { once: true });
      } else {
        updateAll();
      }
    })();
  </script>
</section>

