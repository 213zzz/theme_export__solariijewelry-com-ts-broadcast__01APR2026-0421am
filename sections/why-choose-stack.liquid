{% liquid
  assign section_id = 'stacked-project-cards-' | append: section.id

  assign section_bg_alpha = section.settings.section_bg_opacity | times: 0.01
  assign card_bg_alpha = section.settings.card_bg_opacity | times: 0.01
  assign tag_bg_alpha = section.settings.tag_bg_opacity | times: 0.01
  assign hover_orb_alpha = section.settings.hover_orb_opacity | times: 0.01
  assign hover_button_alpha = section.settings.hover_button_opacity | times: 0.01

  assign section_bg_color = section.settings.section_bg | color_modify: 'alpha', section_bg_alpha
  assign card_bg_color = section.settings.card_bg | color_modify: 'alpha', card_bg_alpha
  assign tag_bg_color = section.settings.tag_bg | color_modify: 'alpha', tag_bg_alpha
  assign hover_orb_color = section.settings.hover_orb_bg | color_modify: 'alpha', hover_orb_alpha
  assign hover_button_bg_color = section.settings.hover_button_bg | color_modify: 'alpha', hover_button_alpha
%}

<section
  id="{{ section_id }}"
  class="stacked-project-cards"
  style="
    --spc-bg: {{ section_bg_color }};
    --spc-card-bg: {{ card_bg_color }};
    --spc-text: {{ section.settings.text_color }};
    --spc-muted: {{ section.settings.muted_color }};
    --spc-tag-bg: {{ tag_bg_color }};
    --spc-tag-text: {{ section.settings.tag_text }};
    --spc-link: {{ section.settings.link_color }};
    --spc-hover-orb-bg: {{ hover_orb_color }};
    --spc-hover-button-bg: {{ hover_button_bg_color }};
    --spc-hover-button-icon: {{ section.settings.hover_button_icon }};
    --spc-default-arrow-color: {{ section.settings.default_arrow_color }};
    --spc-max-width: {{ section.settings.container_width }}px;
    --spc-pt: {{ section.settings.padding_top }}px;
    --spc-pb: {{ section.settings.padding_bottom }}px;
    --spc-card-radius: {{ section.settings.card_radius }}px;
    --spc-media-radius: {{ section.settings.media_radius }}px;

    --spc-sticky-top-base: {{ section.settings.sticky_top }}px;
    --spc-sticky-extra: {{ section.settings.desktop_header_extra_offset }}px;
    --spc-header-offset: 0px;

    --spc-stack-offset: {{ section.settings.stack_offset }}px;
    --spc-card-gap: {{ section.settings.card_gap }}px;
    --spc-card-min-height: {{ section.settings.card_min_height }}px;
    --spc-media-width: {{ section.settings.desktop_media_width }}px;
    --spc-heading-size: {{ section.settings.heading_size }}px;
    --spc-subheading-size: {{ section.settings.subheading_size }}px;
    --spc-title-size: {{ section.settings.card_title_size }}px;
    --spc-copy-size: {{ section.settings.card_text_size }}px;
    --spc-desktop-shrink-setting: {{ section.settings.desktop_shrink | times: 0.01 }};

    --spc-mobile-card-width: {{ section.settings.mobile_card_width }}vw;
    --spc-mobile-card-max-width: {{ section.settings.mobile_card_max_width }}px;
    --spc-mobile-top-base: {{ section.settings.mobile_top_offset }}px;
    --spc-mobile-extra: {{ section.settings.mobile_header_extra_offset }}px;
    --spc-mobile-gap-setting: {{ section.settings.mobile_gap }}px;
    --spc-mobile-bottom-buffer: {{ section.settings.mobile_bottom_buffer }}px;
    --spc-mobile-seam-cover: {{ section.settings.mobile_seam_cover }}px;
    --spc-mobile-shrink-setting: {{ section.settings.mobile_shrink | times: 0.01 }};
    --spc-mobile-card-padding: {{ section.settings.mobile_card_padding }}px;
    --spc-mobile-card-radius: {{ section.settings.mobile_card_radius }}px;
    --spc-mobile-media-radius: {{ section.settings.mobile_media_radius }}px;
    --spc-mobile-title-size: {{ section.settings.mobile_title_size }}px;
    --spc-mobile-text-size: {{ section.settings.mobile_text_size }}px;
  "
>
  <style>
    #{{ section_id }} {
      background: var(--spc-bg);
      padding-top: var(--spc-pt);
      padding-bottom: var(--spc-pb);
    }

    #{{ section_id }} .spc-shell {
      width: min(calc(100% - 40px), var(--spc-max-width));
      margin: 0 auto;
    }

    #{{ section_id }} .spc-head {
      margin-bottom: 28px;
      text-align: left;
    }

    #{{ section_id }} .spc-eyebrow {
      margin: 0 0 10px;
      font-size: 12px;
      line-height: 1.2;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--spc-muted);
    }

    #{{ section_id }} .spc-heading {
      margin: 0;
      font-size: var(--spc-heading-size);
      line-height: 1.05;
      color: var(--spc-text);
      letter-spacing: -0.03em;
    }

    #{{ section_id }} .spc-subheading {
      margin: 12px 0 0;
      max-width: 760px;
      font-size: var(--spc-subheading-size);
      line-height: 1.6;
      color: var(--spc-muted);
    }

    #{{ section_id }} .spc-stack {
      position: relative;
    }

    #{{ section_id }} .spc-item {
      position: relative;
      z-index: var(--card-z);
      margin-top: 0;
      margin-bottom: var(--spc-card-gap);
    }

    #{{ section_id }} .spc-card {
      display: grid;
      grid-template-columns: minmax(240px, var(--spc-media-width)) minmax(0, 1fr);
      align-items: center;
      gap: 28px;
      min-height: var(--spc-card-min-height);
      padding: 18px;
      border-radius: var(--spc-card-radius);
      background: var(--spc-card-bg);
      color: var(--spc-text);
      text-decoration: none;
      box-sizing: border-box;
      overflow: hidden;
      position: relative;
      isolation: isolate;
    }

    #{{ section_id }} .spc-item[data-media-position="right"] .spc-card {
      grid-template-columns: minmax(0, 1fr) minmax(240px, var(--spc-media-width));
    }

    #{{ section_id }} .spc-item[data-media-position="right"] .spc-media {
      order: 2;
    }

    #{{ section_id }} .spc-item[data-media-position="right"] .spc-content {
      order: 1;
    }

    #{{ section_id }} .spc-media,
    #{{ section_id }} .spc-mobile-media {
      width: 100%;
      overflow: hidden;
      background: rgba(0, 0, 0, 0.04);
    }

    #{{ section_id }} .spc-media {
      height: 100%;
      min-height: 240px;
      border-radius: var(--spc-media-radius);
    }

    #{{ section_id }} .spc-media img,
    #{{ section_id }} .spc-media svg,
    #{{ section_id }} .spc-mobile-media img,
    #{{ section_id }} .spc-mobile-media svg {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    #{{ section_id }} .spc-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-width: 0;
      padding: 6px 120px 6px 0;
    }

    #{{ section_id }} .spc-tags,
    #{{ section_id }} .spc-mobile-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    #{{ section_id }} .spc-tag,
    #{{ section_id }} .spc-mobile-tag {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      padding: 4px 10px;
      border-radius: 999px;
      background: var(--spc-tag-bg);
      color: var(--spc-tag-text);
      font-size: 11px;
      line-height: 1;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    #{{ section_id }} .spc-kicker,
    #{{ section_id }} .spc-mobile-kicker {
      margin: 0 0 6px;
      font-size: 13px;
      line-height: 1.4;
      color: var(--spc-muted);
    }

    #{{ section_id }} .spc-title,
    #{{ section_id }} .spc-mobile-title {
      margin: 0;
      font-size: var(--spc-title-size);
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: var(--spc-text);
      word-break: break-word;
    }

    #{{ section_id }} .spc-text,
    #{{ section_id }} .spc-mobile-text {
      margin: 16px 0 0;
      max-width: 520px;
      font-size: var(--spc-copy-size);
      line-height: 1.65;
      color: var(--spc-muted);
    }

    #{{ section_id }} .spc-link-wrap,
    #{{ section_id }} .spc-mobile-link-wrap {
      margin-top: 18px;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 14px;
    }

    #{{ section_id }} .spc-link-label,
    #{{ section_id }} .spc-mobile-link-label {
      font-size: 14px;
      line-height: 1.3;
      color: var(--spc-link);
    }

    #{{ section_id }} .spc-arrow,
    #{{ section_id }} .spc-mobile-arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 999px;
      color: var(--spc-link);
      flex: 0 0 auto;
      transition: transform 0.28s ease, opacity 0.28s ease;
      opacity: 0.92;
    }

    #{{ section_id }} .spc-mobile-card:hover .spc-mobile-arrow {
      transform: translateX(4px);
      opacity: 1;
    }

    #{{ section_id }} .spc-mobile-stack {
      display: none;
    }

    #{{ section_id }} .spc-hover-default-arrow,
    #{{ section_id }} .spc-hover-orb,
    #{{ section_id }} .spc-hover-fab {
      display: none;
    }

    @media screen and (min-width: 990px) {
      #{{ section_id }} .spc-item {
        position: sticky;
        top: calc(var(--spc-sticky-top-base) + var(--spc-header-offset) + var(--spc-sticky-extra));
      }

      #{{ section_id }} .spc-card {
        --spc-desktop-shrink: 0;
        --spc-desktop-lift: 0px;
        transform-origin: center top;
        transform: translate3d(0, var(--spc-desktop-lift), 0) scale(calc(1 - var(--spc-desktop-shrink)));
        will-change: transform;
      }

      #{{ section_id }} .spc-content {
        will-change: transform;
      }

      #{{ section_id }} .spc-media img,
      #{{ section_id }} .spc-media svg {
        will-change: transform;
      }

      #{{ section_id }} .spc-link-wrap .spc-arrow {
        display: none;
      }

      #{{ section_id }} .spc-hover-default-arrow {
        display: inline-flex;
        position: absolute;
        right: 48px;
        top: 50%;
        width: 28px;
        height: 28px;
        align-items: center;
        justify-content: center;
        color: var(--spc-default-arrow-color);
        transform: translateY(-50%);
        opacity: 1;
        pointer-events: none;
        z-index: 6;
        transition:
          opacity 0.18s ease,
          transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
      }

      #{{ section_id }} .spc-hover-orb {
        display: block;
        position: absolute;
        right: 30px;
        top: 50%;
        width: 156px;
        height: 156px;
        border-radius: 999px;
        background: var(--spc-hover-orb-bg);
        transform: translate(36%, -50%) scale(0.68);
        transform-origin: center center;
        opacity: 0;
        pointer-events: none;
        z-index: 4;
        transition:
          transform 0.38s cubic-bezier(0.22, 1, 0.36, 1),
          opacity 0.22s ease;
      }

      #{{ section_id }} .spc-hover-fab {
        display: inline-flex;
        position: absolute;
        right: 30px;
        top: 50%;
        width: 62px;
        height: 62px;
        border-radius: 999px;
        align-items: center;
        justify-content: center;
        background: var(--spc-hover-button-bg);
        color: var(--spc-hover-button-icon);
        transform: translateY(-50%) scale(0.92);
        transform-origin: center center;
        opacity: 0;
        pointer-events: none;
        z-index: 5;
        transition:
          transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
          opacity 0.18s ease;
      }

      #{{ section_id }} .spc-item[data-media-position="right"] .spc-hover-default-arrow {
        right: calc(var(--spc-media-width) + 48px);
      }

      #{{ section_id }} .spc-item[data-media-position="right"] .spc-hover-orb {
        right: calc(var(--spc-media-width) + 30px);
      }

      #{{ section_id }} .spc-item[data-media-position="right"] .spc-hover-fab {
        right: calc(var(--spc-media-width) + 30px);
      }

      #{{ section_id }} .spc-card:hover .spc-hover-default-arrow {
        opacity: 0;
        transform: translateY(-50%) scale(0.85);
      }

      #{{ section_id }} .spc-card:hover .spc-hover-orb {
        opacity: 1;
        transform: translate(36%, -50%) scale(1);
      }

      #{{ section_id }} .spc-card:hover .spc-hover-fab {
        opacity: 1;
        transform: translateY(-50%) scale(1);
      }

      #{{ section_id }} .spc-content,
      #{{ section_id }} .spc-media,
      #{{ section_id }} .spc-tags,
      #{{ section_id }} .spc-link-wrap {
        position: relative;
        z-index: 3;
      }
    }

    @media screen and (max-width: 989px) {
      #{{ section_id }} .spc-shell {
        width: min(calc(100% - 24px), var(--spc-max-width));
      }

      #{{ section_id }} .spc-head {
        width: min(100%, 420px);
        margin: 0 auto 18px;
      }

      #{{ section_id }} .spc-eyebrow {
        margin: 0 0 8px;
        font-size: 11px;
        line-height: 1.2;
        letter-spacing: 0.08em;
      }

      #{{ section_id }} .spc-heading {
        font-size: clamp(28px, 9vw, 38px);
        line-height: 1.02;
        letter-spacing: -0.04em;
      }

      #{{ section_id }} .spc-subheading {
        margin-top: 10px;
        font-size: var(--spc-mobile-text-size);
        line-height: 1.55;
      }

      #{{ section_id }} .spc-stack {
        display: none;
      }

      #{{ section_id }} .spc-mobile-stack {
        --spc-mobile-top: 0px;
        display: block;
        --spc-mobile-gap: var(--spc-mobile-gap-setting);
        --spc-mobile-shrink: 0;
        --spc-mobile-lift: 0px;
        position: relative;
        isolation: isolate;
        padding-bottom: var(--spc-mobile-bottom-buffer);
      }

      #{{ section_id }} .spc-mobile-item {
        position: sticky;
        top: var(--spc-mobile-top);
        z-index: var(--mobile-z);
        overflow: visible;
      }

      #{{ section_id }} .spc-mobile-item::before {
        content: none;
      }

      #{{ section_id }} .spc-mobile-item + .spc-mobile-item {
        margin-top: var(--spc-mobile-gap);
      }

      #{{ section_id }} .spc-mobile-card {
        position: relative;
        z-index: 3;
        display: block;
        width: min(calc(var(--spc-mobile-card-width) * 1vw), var(--spc-mobile-card-max-width));
        margin: 0 auto;
        padding: var(--spc-mobile-card-padding);
        border-radius: var(--spc-mobile-card-radius);
        background: var(--spc-card-bg);
        color: var(--spc-text);
        text-decoration: none;
        box-sizing: border-box;
        overflow: visible;
        transform-origin: center top;
        transform: translate3d(0, var(--spc-mobile-lift), 0) scale(calc(1 - var(--spc-mobile-shrink)));
        will-change: transform;
      }

      #{{ section_id }} .spc-mobile-card::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        top: calc(var(--spc-mobile-seam-cover) * -1);
        height: calc(var(--spc-mobile-seam-cover) + var(--spc-mobile-card-radius));
        background: var(--spc-card-bg);
        border-top-left-radius: var(--spc-mobile-card-radius);
        border-top-right-radius: var(--spc-mobile-card-radius);
        z-index: 0;
        pointer-events: none;
      }

      #{{ section_id }} .spc-mobile-card > * {
        position: relative;
        z-index: 1;
      }

      #{{ section_id }} .spc-mobile-media {
        aspect-ratio: 1 / 0.82;
        border-radius: var(--spc-mobile-media-radius);
        overflow: hidden;
      }

      #{{ section_id }} .spc-mobile-content {
        padding: 14px 2px 4px;
        will-change: transform;
      }

      #{{ section_id }} .spc-mobile-title {
        font-size: var(--spc-mobile-title-size);
        line-height: 1.02;
        letter-spacing: -0.04em;
        word-break: normal;
      }

      #{{ section_id }} .spc-mobile-text {
        margin-top: 12px;
        max-width: none;
        font-size: 14px;
        line-height: 1.6;
      }

      #{{ section_id }} .spc-mobile-link-wrap {
        margin-top: 14px;
        gap: 12px;
      }

      #{{ section_id }} .spc-mobile-arrow {
        width: 30px;
        height: 30px;
      }

      #{{ section_id }} .spc-mobile-tag {
        min-height: 22px;
        padding: 4px 9px;
        font-size: 10px;
      }

      #{{ section_id }} .spc-mobile-kicker {
        margin: 0 0 6px;
        font-size: 12px;
        line-height: 1.35;
      }

      #{{ section_id }} .spc-content {
        padding-right: 0;
      }
    }
  </style>

  <div class="spc-shell">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="spc-head">
        {% if section.settings.eyebrow != blank %}
          <p class="spc-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="spc-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <div class="spc-subheading rte">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="spc-stack">
      {% for block in section.blocks %}
        {% liquid
          assign remainder = forloop.index0 | modulo: 2
          assign media_position = block.settings.media_position

          if media_position == 'auto'
            if remainder == 0
              assign media_position = 'left'
            else
              assign media_position = 'right'
            endif
          endif
        %}

        <div
          class="spc-item"
          data-media-position="{{ media_position }}"
          style="--card-index: {{ forloop.index0 }}; --card-z: {{ forloop.index }};"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.link != blank %}
            <a class="spc-card" href="{{ block.settings.link }}">
          {% else %}
            <div class="spc-card">
          {% endif %}

              <div class="spc-media">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400, 600, 800, 1000, 1200', sizes: '(min-width: 990px) 32vw, 100vw', alt: block.settings.title | escape }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>

              <div class="spc-content">
                {% if block.settings.tag_1 != blank or block.settings.tag_2 != blank or block.settings.tag_3 != blank %}
                  <div class="spc-tags">
                    {% if block.settings.tag_1 != blank %}
                      <span class="spc-tag">{{ block.settings.tag_1 }}</span>
                    {% endif %}
                    {% if block.settings.tag_2 != blank %}
                      <span class="spc-tag">{{ block.settings.tag_2 }}</span>
                    {% endif %}
                    {% if block.settings.tag_3 != blank %}
                      <span class="spc-tag">{{ block.settings.tag_3 }}</span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.kicker != blank %}
                  <p class="spc-kicker">{{ block.settings.kicker }}</p>
                {% endif %}

                {% if block.settings.title != blank %}
                  <h3 class="spc-title">{{ block.settings.title }}</h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="spc-text rte">{{ block.settings.text }}</div>
                {% endif %}

                {% if block.settings.link_label != blank or block.settings.link != blank %}
                  <div class="spc-link-wrap">
                    <span class="spc-link-label">
                      {% if block.settings.link_label != blank %}
                        {{ block.settings.link_label }}
                      {% else %}
                        了解更多
                      {% endif %}
                    </span>
                    <span class="spc-arrow" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" role="presentation">
                        <path d="M4.16699 10H15.0003" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                        <path d="M10.833 5.83337L14.9997 10L10.833 14.1667" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                {% endif %}
              </div>

              <div class="spc-hover-default-arrow" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 20 20" fill="none" role="presentation">
                  <path d="M4.16699 10H15.0003" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M10.833 5.83337L14.9997 10L10.833 14.1667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>

              <div class="spc-hover-orb" aria-hidden="true"></div>
              <div class="spc-hover-fab" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 20 20" fill="none" role="presentation">
                  <path d="M4.16699 10H15.0003" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                  <path d="M10.833 5.83337L14.9997 10L10.833 14.1667" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>

          {% if block.settings.link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="spc-mobile-stack" data-mobile-stack>
      {% for block in section.blocks %}
        <div
          class="spc-mobile-item"
          style="--mobile-z: {{ forloop.index }};"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.link != blank %}
            <a class="spc-mobile-card" href="{{ block.settings.link }}">
          {% else %}
            <div class="spc-mobile-card">
          {% endif %}

              <div class="spc-mobile-media">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400, 600, 800, 1000, 1200', sizes: '86vw', alt: block.settings.title | escape }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>

              <div class="spc-mobile-content">
                {% if block.settings.tag_1 != blank or block.settings.tag_2 != blank or block.settings.tag_3 != blank %}
                  <div class="spc-mobile-tags">
                    {% if block.settings.tag_1 != blank %}
                      <span class="spc-mobile-tag">{{ block.settings.tag_1 }}</span>
                    {% endif %}
                    {% if block.settings.tag_2 != blank %}
                      <span class="spc-mobile-tag">{{ block.settings.tag_2 }}</span>
                    {% endif %}
                    {% if block.settings.tag_3 != blank %}
                      <span class="spc-mobile-tag">{{ block.settings.tag_3 }}</span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.kicker != blank %}
                  <p class="spc-mobile-kicker">{{ block.settings.kicker }}</p>
                {% endif %}

                {% if block.settings.title != blank %}
                  <h3 class="spc-mobile-title">{{ block.settings.title }}</h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="spc-mobile-text rte">{{ block.settings.text }}</div>
                {% endif %}

                {% if block.settings.link_label != blank or block.settings.link != blank %}
                  <div class="spc-mobile-link-wrap">
                    <span class="spc-mobile-link-label">
                      {% if block.settings.link_label != blank %}
                        {{ block.settings.link_label }}
                      {% else %}
                        查看更多
                      {% endif %}
                    </span>
                    <span class="spc-mobile-arrow" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" role="presentation">
                        <path d="M4.16699 10H15.0003" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                        <path d="M10.833 5.83337L14.9997 10L10.833 14.1667" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                {% endif %}
              </div>

          {% if block.settings.link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
