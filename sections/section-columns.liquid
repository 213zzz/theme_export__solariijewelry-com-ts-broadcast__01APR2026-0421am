<!-- /sections/section-columns.liquid -->

{%- render 'multicolumn', type: 'images' -%}

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var sec = document.getElementById('shopify-section-' + sectionId);
    if (!sec) return;

    var mobileBlocks = [];
    {%- for block in section.blocks -%}
      {%- if block.settings.mobile_image != blank -%}
        mobileBlocks.push({
          index: {{ forloop.index0 }},
          blockId: {{ block.id | json }},
          mobileSrc: {{ block.settings.mobile_image | image_url: width: 1600 | json }}
        });
      {%- endif -%}
    {%- endfor -%}
    if (!mobileBlocks.length) return;

    var mql = window.matchMedia('(max-width: 749px)');
    var lastIsMobile = null;
    var refs = {};

    function getRef(entry) {
      var cached = refs[entry.blockId];
      if (cached && cached.root && cached.root.isConnected && cached.img && cached.img.isConnected) {
        return cached;
      }

      var root = sec.querySelector(
        '[id$="-' + entry.blockId + '"], [id="' + entry.blockId + '"], [data-block-id="' + entry.blockId + '"]'
      );

      if (!root) {
        var grids = sec.querySelectorAll('.multicolumn__grid, .columns__grid, .grid');
        for (var i = 0; i < grids.length; i++) {
          if (grids[i].children && grids[i].children.length > entry.index) {
            root = grids[i].children[entry.index];
            break;
          }
        }
      }
      if (!root) return null;

      var img = root.querySelector('img');
      if (!img) return null;

      if (!img.dataset.sgOrigSrc) {
        img.dataset.sgOrigSrc = img.getAttribute('src') || '';
        img.dataset.sgOrigSrcset = img.getAttribute('srcset') || '';
        img.dataset.sgOrigDataSrc = img.getAttribute('data-src') || '';
        img.dataset.sgOrigDataSrcset = img.getAttribute('data-srcset') || '';
      }

      var sources = [];
      var picture = img.closest ? img.closest('picture') : null;
      if (picture) {
        sources = picture.querySelectorAll('source');
        for (var s = 0; s < sources.length; s++) {
          if (!sources[s].dataset.sgOrigSrcset) {
            sources[s].dataset.sgOrigSrcset = sources[s].getAttribute('srcset') || '';
          }
        }
      }

      refs[entry.blockId] = { root: root, img: img, sources: sources };
      return refs[entry.blockId];
    }

    function applySwap(force) {
      var isMobile = mql.matches;
      if (!force && isMobile === lastIsMobile) return;
      lastIsMobile = isMobile;

      for (var i = 0; i < mobileBlocks.length; i++) {
        var entry = mobileBlocks[i];
        var ref = getRef(entry);
        if (!ref) continue;

        for (var s = 0; s < ref.sources.length; s++) {
          var source = ref.sources[s];
          if (isMobile) {
            source.setAttribute('srcset', entry.mobileSrc);
          } else if (source.dataset.sgOrigSrcset) {
            source.setAttribute('srcset', source.dataset.sgOrigSrcset);
          }
        }

        if (isMobile) {
          ref.img.setAttribute('src', entry.mobileSrc);
          ref.img.setAttribute('srcset', entry.mobileSrc);
          ref.img.setAttribute('data-src', entry.mobileSrc);
          ref.img.setAttribute('data-srcset', entry.mobileSrc);
        } else {
          if (ref.img.dataset.sgOrigSrc) ref.img.setAttribute('src', ref.img.dataset.sgOrigSrc);
          if (ref.img.dataset.sgOrigSrcset) ref.img.setAttribute('srcset', ref.img.dataset.sgOrigSrcset);
          if (ref.img.dataset.sgOrigDataSrc) ref.img.setAttribute('data-src', ref.img.dataset.sgOrigDataSrc);
          if (ref.img.dataset.sgOrigDataSrcset) ref.img.setAttribute('data-srcset', ref.img.dataset.sgOrigDataSrcset);
        }
      }
    }

    function scheduleSwap(force) {
      window.requestAnimationFrame(function() {
        applySwap(force === true);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { scheduleSwap(true); }, { once: true });
    } else {
      scheduleSwap(true);
    }

    if (mql.addEventListener) {
      mql.addEventListener('change', function() { scheduleSwap(false); });
    } else if (mql.addListener) {
      mql.addListener(function() { scheduleSwap(false); });
    }

    var resizeTicking = false;
    window.addEventListener('resize', function() {
      if (resizeTicking) return;
      resizeTicking = true;
      window.requestAnimationFrame(function() {
        resizeTicking = false;
        scheduleSwap(false);
      });
    }, { passive: true });

    function onEditorEvent(e) {
      if (e && e.detail && e.detail.sectionId && e.detail.sectionId !== sectionId) return;
      refs = {};
      scheduleSwap(true);
    }

    document.addEventListener('shopify:section:load', onEditorEvent);
    document.addEventListener('shopify:block:select', onEditorEvent);
    document.addEventListener('shopify:block:deselect', onEditorEvent);
  })();
</script>

