<!-- /sections/footer.liquid -->

{%- liquid
  assign blocks_size = section.blocks.size
  assign logo = section.settings.logo
  assign inline_blocks = ''
  assign inline_blocks_placeholder = '####inline-blocks@@@@'
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign border_color = section.settings.border_color
  assign one_third_block_count = 0
  assign blocks_code = ''
  assign blocks_width = 0
-%}

{%- style -%}
  .site-footer-wrapper {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    --item-count: {{ blocks_size }};
    background: #000;
  }

  .site-footer {
    background: transparent !important;
  }

  .site-footer .footer__blocks {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding: 0;
    background: none;
    border: none;
    box-shadow: none;
  }

  .site-footer .footer__block,
  .site-footer .footer__block--newsletter {
    min-width: 0;
    width: var(--desktop-width, 33%);
    padding: 0 15px;
    margin-bottom: 30px;
    box-sizing: border-box;
  }

  .site-footer .footer__block--divider {
    width: 100% !important;
    padding: 0;
    margin-bottom: 0;
  }

  .site-footer .footer__block--divider .divider {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .site-footer .footer__block__title,
  .site-footer .h3,
  .site-footer .rte,
  .site-footer .rte p,
  .site-footer p,
  .site-footer li,
  .site-footer summary,
  .site-footer .footer__newsletter__text {
    color: #fff;
  }

  .site-footer .footer__block__title,
  .site-footer .footer__newsletter__wrapper .footer__block__title {
    margin: 0 0 14px;
    letter-spacing: 0.02em;
  }

  .site-footer .rte p:last-child {
    margin-bottom: 0;
  }

  .site-footer a {
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.25s ease;
  }

  .site-footer a:hover {
    color: #fff;
  }

  .site-footer .footer__quicklinks li + li {
    margin-top: 8px;
  }

  .site-footer .footer__quicklinks li a {
    line-height: 1.35;
  }

  .site-footer .footer__block__image img {
    display: block;
  }

  .site-footer .footer__block--cert-anchor {
    min-height: auto !important;
    align-self: start;
  }

  .site-footer details.footer__block summary {
    list-style: none;
  }

  .site-footer details.footer__block summary::-webkit-details-marker {
    display: none;
  }

  /* Accordion & block borders */
  .site-footer .accordion summary {
    border: none !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2) !important;
    padding-bottom: 12px;
  }

  .site-footer .accordion[open] summary {
    border-bottom-color: transparent !important;
  }

  .site-footer .footer__block {
    border: none !important;
  }

  .site-footer .footer__blocks,
  .site-footer .footer__block,
  .site-footer .footer__block--menu,
  .site-footer .footer__block--text,
  .site-footer .footer__block--social,
  .site-footer .footer__block--newsletter,
  .site-footer details,
  .site-footer details summary,
  .site-footer [data-collapsible-body],
  .site-footer .accordion__content,
  .site-footer .divider-holder {
    border-top: none !important;
    box-shadow: none !important;
  }

  .site-footer .footer__payments {
    width: 100%;
    max-width: 520px;
    margin-top: 18px;
  }

  .site-footer .footer__payments--mobile-bottom {
    display: none;
  }

  .site-footer .footer__payments-title {
    margin: 0 0 12px;
    color: #fff;
    font-size: 16px;
    line-height: 1.2;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .site-footer .footer__payments-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer .footer__payments-item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 48px;
    min-height: 30px;
    padding: 4px 8px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
  }

  .site-footer .footer__payments-item svg {
    display: block;
    width: auto;
    height: 18px;
  }

  .site-footer .footer__secure-desktop,
  .site-footer .footer__secure-mobile {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .site-footer .footer__secure-title {
    margin: 0;
    color: #fff;
    font-size: 16px;
    line-height: 1.2;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .site-footer .footer__secure-image {
    margin-top: 12px;
  }

  .site-footer .footer__secure-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .site-footer .footer__secure-note {
    margin-top: 8px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 12px;
    line-height: 1.45;
  }

  .shopify-section-group-group-footer ul.payment-icons,
  .shopify-section-group-group-footer .payment-icons,
  .shopify-section-group-group-footer .footer__payment-icons {
    display: none !important;
  }

  @media (max-width: 989px) {
    .site-footer .footer__blocks {
      flex-direction: column;
      gap: 0;
      padding: 0;
    }

    .site-footer .footer__block,
    .site-footer .footer__block--newsletter {
      width: 100% !important;
      padding: 0;
      margin-bottom: 20px;
    }

    .site-footer .footer__block--divider {
      display: none;
    }

    .site-footer .footer__block,
    .site-footer details.footer__block {
      border: none !important;
      border-top: none !important;
      border-bottom: none !important;
    }

    .site-footer .accordion summary {
      border: none !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2) !important;
      padding-bottom: 12px;
    }

    .site-footer .accordion[open] summary {
      border-bottom-color: transparent !important;
    }

    .site-footer .footer__quicklinks li + li {
      margin-top: 6px;
    }

    .site-footer .footer__payments--inside-cert {
      display: none !important;
    }

    .site-footer .footer__payments--mobile-bottom {
      display: block;
      width: 100%;
      max-width: none;
      margin-top: 16px;
      padding: 16px 0;
    }

    .site-footer .footer__payments-title {
      font-size: 18px;
      margin-bottom: 10px;
    }

    .site-footer .footer__payments-grid {
      gap: 8px;
    }

    .site-footer .footer__payments-item {
      min-width: 44px;
      min-height: 28px;
      padding: 4px 7px;
    }

    .site-footer .footer__payments-item svg {
      height: 16px;
    }
  }

  {% unless border_color == 'rgba(0,0,0,0)' or border_color == blank %}
    .shopify-section-group-group-footer { --border: {{ border_color }}; }
    .shopify-section-group-group-footer .field { --border: {{ border_color }}; }
  {% endunless %}
{%- endstyle -%}

<footer
  class="site-footer-wrapper section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="footer"
>
  <div class="site-footer wrapper--full-padded">
    {%- if logo -%}
      {%- liquid
        assign logo_width = section.settings.logo_image_width
        assign logo_width_px = logo_width | append: 'px'
        assign logo_width_2x = logo_width | times: 2
        assign logo_width_3x = logo_width | times: 3
        assign logo_widths = logo_width | append: ',' | append: logo_width_2x | append: ',' | append: logo_width_3x
        assign logo_alt = logo.alt | default: shop.name | strip_html | escape
      -%}
      <div class="footer__logo__wrapper">
        <a
          href="{{ routes.root_url }}"
          class="footer__logo"
          style="width: {{ logo_width_px }};"
          aria-label="{{ 'general.accessibility.footer_logo' | t }}"
        >
          {%- render 'image',
            image: logo,
            width: logo_width_2x,
            widths: logo_widths,
            sizes: logo_width_px,
            alt: logo_alt
          -%}
        </a>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 or section.settings.show_auto_payments -%}
      <collapsible-elements>
        <div class="footer__blocks">
          {%- for block in section.blocks -%}
            {%- capture blocks_code -%}
              {{ blocks_code }}

              {%- liquid
                assign block_type = block.type
                assign title = block.settings.title
                assign text = block.settings.text
                assign show_social_links = block.settings.show_social_links
                assign enable_accordion = block.settings.enable_accordion
                assign column_width = block.settings.column_width
                assign blocks_width = blocks_width | plus: block.settings.column_width
                assign cert_anchor_title = title | strip | downcase

                if block.settings.column_width == 33
                  assign one_third_block_count = one_third_block_count | plus: 1
                endif

                capture block_style
                  echo '--desktop-width: ' | append: column_width | append: '%;'
                endcapture

                if block_type == 'linklist' or block_type == 'social' or block_type == 'text'
                  if block_type == 'linklist'
                    assign linklist = linklists[block.settings.linklist]
                    assign title = title | default: linklist.title
                  endif

                  if enable_accordion and title != blank
                    assign enable_accordion = true
                  else
                    assign enable_accordion = false
                  endif
                endif
              -%}

              {%- case block_type -%}
                {%- when 'linklist' -%}
                  <details class="footer__block footer__block--menu{% if enable_accordion %} accordion{% endif %}" style="{{ block_style }}" {{ block.shopify_attributes }} data-collapsible desktop="false" mobile="{{ enable_accordion }}">
                    <summary class="{% if title != blank %}h3 footer__block__title {{ block.settings.heading_font_size }}{% if enable_accordion %} accordion__title{% endif %}{% else %}hidden{% endif %}" data-collapsible-trigger>
                      {%- if title != blank -%}
                        {{ title | escape }}
                      {%- else -%}
                        &nbsp;
                      {%- endif -%}
                      {%- render 'icon-nav-arrow-down' -%}
                    </summary>

                    {%- if linklist != blank -%}
                      <div data-collapsible-body>
                        <ul class="footer__quicklinks unstyled{% if enable_accordion %} accordion__content{% endif %}" data-collapsible-content>
                          {%- for link in linklist.links -%}
                            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}
                  </details>

                {%- when 'page' -%}
                  {%- assign page = pages[block.settings.page] -%}

                  {%- if page == blank or page.empty? -%}
                    <details class="footer__block footer__block--page{% if enable_accordion %} accordion{% endif %}" style="{{ block_style }}" {{ block.shopify_attributes }} data-collapsible desktop="false" mobile="{{ enable_accordion }}">
                      <summary class="h3 footer__block__title {{ block.settings.heading_font_size }}{% if enable_accordion %} accordion__title{% endif %}" data-collapsible-trigger>
                        {%- if title != blank -%}
                          {{ title }}
                        {%- else -%}
                          {{ shop.name }}
                        {%- endif -%}
                        {%- render 'icon-nav-arrow-down' -%}
                      </summary>

                      <div data-collapsible-body>
                        <div class="rte{% if enable_accordion %} accordion__content{% endif %}" data-collapsible-content>{{ 'home_page.onboarding.no_content' | t }}</div>
                      </div>
                    </details>
                  {%- else -%}
                    <details class="footer__block footer__block--page{% if enable_accordion %} accordion{% endif %}" style="{{ block_style }}" {{ block.shopify_attributes }} data-collapsible desktop="false" mobile="{{ enable_accordion }}">
                      <summary class="h3 footer__block__title {{ block.settings.heading_font_size }}{% if enable_accordion %} accordion__title{% endif %}" data-collapsible-trigger>
                        {%- if title != blank -%}
                          {{ title }}
                        {%- else -%}
                          {{ page.title | escape }}
                        {%- endif -%}
                        {%- render 'icon-nav-arrow-down' -%}
                      </summary>

                      <div data-collapsible-body>
                        <div class="rte{% if enable_accordion %} accordion__content{% endif %}" data-collapsible-content>{{ page.content }}</div>
                      </div>
                    </details>
                  {%- endif -%}

                {%- when 'social' -%}
                  <details class="footer__block footer__block--social{% if enable_accordion %} accordion{% endif %}" style="{{ block_style }}" {{ block.shopify_attributes }} data-collapsible desktop="false" mobile="{{ enable_accordion }}">
                    <summary class="{% if title != blank %}h3 footer__block__title {{ block.settings.heading_font_size }}{% if enable_accordion %} accordion__title{% endif %}{% else %}hidden{% endif %}" data-collapsible-trigger>
                      {%- if title != blank -%}
                        {{ title | escape }}
                      {%- else -%}
                        &nbsp;
                      {%- endif -%}
                      {%- render 'icon-nav-arrow-down' -%}
                    </summary>

                    <div data-collapsible-body>
                      <div class="{% if enable_accordion %} accordion__content{% endif %}" data-collapsible-content>
                        {%- if text != blank -%}
                          <div class="rte footer__social__text">{{ text }}</div>
                        {%- endif -%}
                        {%- render 'social-icons' enable_follow_on_shop: block.settings.enable_follow_on_shop -%}
                      </div>
                    </div>
                  </details>

                {%- when 'text' -%}
                  <details class="footer__block footer__block--text{% if enable_accordion %} accordion{% endif %}{% if cert_anchor_title == 'moissanite diamond certified' %} footer__block--cert-anchor{% endif %}" style="{{ block_style }}" {{ block.shopify_attributes }} data-collapsible desktop="false" mobile="{{ enable_accordion }}">
                    <summary class="{% if title != blank %}h3 footer__block__title {{ block.settings.heading_font_size }}{% if enable_accordion %} accordion__title{% endif %}{% else %}hidden{% endif %}" data-collapsible-trigger>
                      {%- if title != blank -%}
                        {{ title | escape }}
                      {%- else -%}
                        &nbsp;
                      {%- endif -%}
                      {%- render 'icon-nav-arrow-down' -%}
                    </summary>

                    <div data-collapsible-body>
                      <div class="{% if enable_accordion %}accordion__content{% endif %}" data-collapsible-content>
                        {%- if block.settings.image -%}
                          {%- liquid
                            assign image_width = block.settings.image_width
                            assign image_width_x15 = image_width | times: 1.5
                            assign image_width_x2 = image_width | times: 2
                            assign sizes = image_width | append: 'px'
                            assign widths = image_width | append: ', ' | append: image_width_x15 | append: ', ' | append: image_width_x2
                          -%}
                          <div class="footer__block__image" style="width: {{ image_width }}px;">
                            {%- render 'image' image: block.settings.image, width: image_width_x2, sizes: sizes, widths: widths -%}
                          </div>
                        {%- endif -%}

                        {%- if text != blank -%}
                          <div class="rte">{{ text }}</div>
                        {%- endif -%}

                        {%- if section.settings.show_auto_payments and shop.enabled_payment_types.size > 0 and cert_anchor_title == 'moissanite diamond certified' -%}
                          <div class="footer__payments footer__payments--inside-cert">
                            {%- if section.settings.payments_title != blank -%}
                              <h3 class="footer__payments-title">{{ section.settings.payments_title | escape }}</h3>
                            {%- endif -%}

                            <ul class="footer__payments-grid" role="list">
                              {%- for type in shop.enabled_payment_types -%}
                                <li class="footer__payments-item">
                                  {{ type | payment_type_svg_tag }}
                                </li>
                              {%- endfor -%}
                            </ul>

                            {%- if section.settings.secure_title != blank or section.settings.secure_image -%}
                              <div class="footer__secure-desktop">
                                {%- if section.settings.secure_title != blank -%}
                                  <h4 class="footer__secure-title">{{ section.settings.secure_title | escape }}</h4>
                                {%- endif -%}

                                {%- if section.settings.secure_image -%}
                                  <div class="footer__secure-image" style="max-width: {{ section.settings.secure_image_width }}px;">
                                    {{
                                      section.settings.secure_image
                                      | image_url: width: 900
                                      | image_tag: loading: 'lazy', alt: section.settings.secure_title
                                    }}
                                  </div>
                                {%- endif -%}

                                {%- if section.settings.secure_note != blank -%}
                                  <div class="footer__secure-note">{{ section.settings.secure_note }}</div>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  </details>

                {%- when 'newsletter' -%}
                  <div class="footer__block footer__block--newsletter" style="{{ block_style }}" {{ block.shopify_attributes }}>
                    <div class="footer__newsletter__wrapper">
                      {%- if title != blank -%}
                        <h2 class="footer__block__title {{ block.settings.heading_font_size }}">{{ title }}</h2>
                      {%- endif -%}

                      {%- if text != blank -%}
                        <div class="rte footer__newsletter__text">{{ text }}</div>
                      {%- endif -%}

                      {%- render 'newsletter-form' block: block, footer: true -%}

                      {%- if show_social_links -%}
                        {%- render 'social-icons' modifier: 'socials--newsletter' -%}
                      {%- endif -%}
                    </div>
                  </div>

                {%- when 'divider' -%}
                  <div class="footer__block footer__block--divider{{ inline_blocks_placeholder }}" style="{{ block_style }}">
                    {%- render 'divider' block: block -%}
                  </div>
              {%- endcase -%}
            {%- endcapture -%}
          {%- endfor -%}

          {%- liquid
            if blocks_width <= 100
              assign inline_blocks = ' footer__block--divider--inline'
            endif

            if one_third_block_count == blocks_size
              echo blocks_code | replace: inline_blocks_placeholder, inline_blocks | replace: '--desktop-width: 33%;', '--desktop-width: 33.333333%;'
            else
              echo blocks_code | replace: inline_blocks_placeholder, inline_blocks
            endif
          -%}

          {%- if section.settings.show_auto_payments and shop.enabled_payment_types.size > 0 -%}
            <div class="footer__payments footer__payments--mobile-bottom">
              {%- if section.settings.payments_title != blank -%}
                <h3 class="footer__payments-title">{{ section.settings.payments_title | escape }}</h3>
              {%- endif -%}

              <ul class="footer__payments-grid" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="footer__payments-item">
                    {{ type | payment_type_svg_tag }}
                  </li>
                {%- endfor -%}
              </ul>

              {%- if section.settings.secure_title != blank or section.settings.secure_image -%}
                <div class="footer__secure-mobile">
                  {%- if section.settings.secure_title != blank -%}
                    <h4 class="footer__secure-title">{{ section.settings.secure_title | escape }}</h4>
                  {%- endif -%}

                  {%- if section.settings.secure_image -%}
                    <div class="footer__secure-image" style="max-width: {{ section.settings.secure_image_width }}px;">
                      {{
                        section.settings.secure_image
                        | image_url: width: 900
                        | image_tag: loading: 'lazy', alt: section.settings.secure_title
                      }}
                    </div>
                  {%- endif -%}

                  {%- if section.settings.secure_note != blank -%}
                    <div class="footer__secure-note">{{ section.settings.secure_note }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </collapsible-elements>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 8,
  "settings": [
    {
      "label": "Logo",
      "type": "image_picker",
      "id": "logo",
      "info": "300 x 90px .jpg recommended. [Learn more](http://presidiodev.com/link/broadcast/images)"
    },
    {
      "type": "range",
      "id": "logo_image_width",
      "label": "Logo width (in pixels)",
      "min": 50,
      "max": 400,
      "step": 5,
      "unit": "px",
      "default": 150
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Borders and lines",
      "default": "#212121",
      "alpha": true,
      "info": "Applies to Divider and Newsletter"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 75
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Payments"
    },
    {
      "type": "checkbox",
      "id": "show_auto_payments",
      "label": "Show auto payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "payments_title",
      "label": "Payment heading",
      "default": "We accept"
    },
    {
      "type": "text",
      "id": "secure_title",
      "label": "Secure heading",
      "default": "Secure certification"
    },
    {
      "type": "image_picker",
      "id": "secure_image",
      "label": "Secure certification image"
    },
    {
      "type": "range",
      "id": "secure_image_width",
      "label": "Secure certification image width",
      "min": 80,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "text",
      "id": "secure_note",
      "label": "Secure note"
    }
  ],
  "blocks": [
    {
      "type": "linklist",
      "name": "Link list",
      "settings": [
        {
          "type": "link_list",
          "id": "linklist",
          "label": "Link list",
          "default": "footer",
          "info": "This menu won't show dropdown items."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading size",
          "default": "heading-medium",
          "options": [
            { "value": "heading-mini", "label": "Mini" },
            { "value": "heading-x-small", "label": "Extra small" },
            { "value": "heading-small", "label": "Small" },
            { "value": "heading-medium", "label": "Medium" },
            { "value": "heading-large", "label": "Large" },
            { "value": "heading-x-large", "label": "Extra large" }
          ]
        },
        {
          "type": "range",
          "id": "column_width",
          "label": "Column width",
          "unit": "%",
          "min": 1,
          "max": 100,
          "step": 1,
          "default": 33,
          "info": "Desktop only"
        },
        {
          "type": "header",
          "content": "Mobile"
        },
        {
          "type": "checkbox",
          "id": "enable_accordion",
          "label": "Enable accordion",
          "info": "Transform block into accordion element",
          "default": false
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Subscribers are under 'Accepts Marketing' in your [customer admin](/admin/customers)."
        },
        {
          "type": "text",
          "id": "title",
