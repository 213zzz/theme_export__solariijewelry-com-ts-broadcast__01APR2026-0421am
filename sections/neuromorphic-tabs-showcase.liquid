{%- comment -%}
  Section: Why Choose Us (Tabbed)
  Features:
    - Up to 5 editable tabs
    - Cards: standard (icon), wide (2-col span), image-top
    - Media: Shopify-hosted video, YouTube/Vimeo URL, or image
    - Stat row blocks per tab
    - FAQ accordion per card
    - Full desktop + mobile typography & layout controls
{%- endcomment -%}

<style>
  /* ── Scoped variables ── */
  #shopify-section-{{ section.id }} {
    --wcu-bg:          {{ section.settings.bg_color }};
    --wcu-bg2:         {{ section.settings.bg_color_2 }};
    --wcu-gold:        {{ section.settings.accent_color }};
    --wcu-gold-l:      {{ section.settings.accent_color_light }};
    --wcu-text:        {{ section.settings.text_color }};
    --wcu-muted:       {{ section.settings.muted_color }};
    --wcu-shadow-d:    rgba(0,0,0,.10);
    --wcu-shadow-l:    rgba(255,255,255,.82);
    --wcu-max:         {{ section.settings.max_width }}px;
    --wcu-pt:          {{ section.settings.padding_top_desktop }}px;
    --wcu-pb:          {{ section.settings.padding_bottom_desktop }}px;
    --wcu-cols:        {{ section.settings.grid_columns_desktop }};
    --wcu-title:       {{ section.settings.title_size_desktop }}px;
    --wcu-sub:         {{ section.settings.subtitle_size_desktop }}px;
    --wcu-ctitle:      {{ section.settings.card_title_size }}px;
    --wcu-cdesc:       {{ section.settings.desc_size }}px;
    --wcu-stat:        {{ section.settings.stat_num_size }}px;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --wcu-pt:    {{ section.settings.padding_top_mobile }}px;
      --wcu-pb:    {{ section.settings.padding_bottom_mobile }}px;
      --wcu-cols:  {{ section.settings.grid_columns_mobile }};
      --wcu-title: {{ section.settings.title_size_mobile }}px;
      --wcu-sub:   {{ section.settings.subtitle_size_mobile }}px;
    }
  }

  /* ── Base reset (scoped) ── */
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }

  /* ── Section ── */
  #shopify-section-{{ section.id }} .wcu {
    background: var(--wcu-bg);
    padding: var(--wcu-pt) 0 var(--wcu-pb);
    font-family: 'Funnel Display', sans-serif;
    color: var(--wcu-text);
  }
  #shopify-section-{{ section.id }} .wcu__inner {
    max-width: var(--wcu-max);
    margin: 0 auto;
    padding: 0 40px;
    text-align: center;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .wcu__inner { padding: 0 20px; }
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .wcu__eyebrow {
    display: inline-block;
    padding: 6px 18px;
    border-radius: 999px;
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--wcu-gold);
    background: linear-gradient(145deg, var(--wcu-bg), var(--wcu-bg2));
    box-shadow: 3px 3px 6px var(--wcu-shadow-d), -3px -3px 6px var(--wcu-shadow-l);
    margin-bottom: 20px;
  }
  #shopify-section-{{ section.id }} .wcu__title {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: var(--wcu-title);
    font-weight: 800;
    letter-spacing: -.02em;
    margin-bottom: 12px;
    color: var(--wcu-text);
  }
  #shopify-section-{{ section.id }} .wcu__subtitle {
    max-width: 560px;
    margin: 0 auto 40px;
    font-size: var(--wcu-sub);
    line-height: 1.7;
    color: var(--wcu-muted);
  }

  /* ── Tabs ── */
  #shopify-section-{{ section.id }} .wcu__tabs {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    padding: 8px;
    border-radius: 24px;
    border: 1px solid rgba(171,140,82,.16);
    background: linear-gradient(180deg, rgba(255,252,247,.92), rgba(247,241,233,.96));
    box-shadow: 0 16px 32px rgba(120,94,64,.08), inset 0 1px 0 rgba(255,255,255,.82);
    margin-bottom: 44px;
  }
  #shopify-section-{{ section.id }} .wcu__tab {
    appearance: none;
    border: 1px solid transparent;
    cursor: pointer;
    padding: 13px 24px 14px;
    min-width: 138px;
    border-radius: 16px;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #7a6756;
    background: transparent;
    position: relative;
    transition: color .28s, background .28s, border-color .28s, box-shadow .28s, transform .28s;
  }
  #shopify-section-{{ section.id }} .wcu__tab::after {
    content: '';
    position: absolute;
    left: 50%; bottom: 8px;
    width: 26px; height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--wcu-gold), var(--wcu-gold-l));
    transform: translateX(-50%) scaleX(.45);
    opacity: 0;
    transition: transform .28s, opacity .28s;
  }
  #shopify-section-{{ section.id }} .wcu__tab:hover {
    color: var(--wcu-text);
    background: rgba(255,255,255,.62);
    border-color: rgba(171,140,82,.14);
  }
  #shopify-section-{{ section.id }} .wcu__tab:focus-visible {
    outline: none;
    border-color: rgba(171,140,82,.28);
    box-shadow: 0 0 0 3px rgba(171,140,82,.14);
  }
  #shopify-section-{{ section.id }} .wcu__tab.active {
    color: var(--wcu-text);
    background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(246,239,230,.96));
    border-color: rgba(171,140,82,.22);
    box-shadow: 0 10px 20px rgba(112,85,53,.10), inset 0 1px 0 rgba(255,255,255,.94);
    transform: translateY(-1px);
  }
  #shopify-section-{{ section.id }} .wcu__tab.active::after {
    opacity: 1;
    transform: translateX(-50%) scaleX(1);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .wcu__tab {
      min-width: 0;
      padding: 11px 14px 12px;
      border-radius: 14px;
      font-size: 11px;
      letter-spacing: .12em;
    }
  }

  /* ── Panels ── */
  #shopify-section-{{ section.id }} .wcu__panel { display: none; text-align: left; }
  #shopify-section-{{ section.id }} .wcu__panel.active { display: block; animation: wcuFadeUp .4s ease; }
  @keyframes wcuFadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }

  /* ── Grid ── */
  #shopify-section-{{ section.id }} .wcu__grid {
    display: grid;
    grid-template-columns: repeat(var(--wcu-cols), 1fr);
    gap: 24px;
  }

  /* ── Card base ── */
  #shopify-section-{{ section.id }} .wcu__card {
    padding: 32px 28px;
    border-radius: 22px;
    background: linear-gradient(150deg, var(--wcu-bg), var(--wcu-bg2));
    box-shadow: 6px 6px 14px var(--wcu-shadow-d), -6px -6px 14px var(--wcu-shadow-l);
    transition: transform .3s;
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ section.id }} .wcu__card:hover { transform: translateY(-4px); }

  /* icon */
  #shopify-section-{{ section.id }} .wcu__card-emoji {
    width: 56px; height: 56px;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px;
    margin-bottom: 20px;
    background: linear-gradient(145deg, var(--wcu-bg), var(--wcu-bg2));
    box-shadow: 4px 4px 8px var(--wcu-shadow-d), -4px -4px 8px var(--wcu-shadow-l);
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .wcu__card-emoji img {
    width: 100%; height: 100%; object-fit: contain; border-radius: 10px;
  }

  /* text */
  #shopify-section-{{ section.id }} .wcu__card-title {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: var(--wcu-ctitle);
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--wcu-text);
  }
  #shopify-section-{{ section.id }} .wcu__card-desc {
    font-size: var(--wcu-cdesc);
    line-height: 1.7;
    color: var(--wcu-muted);
    margin-bottom: 16px;
    flex: 1;
  }

  /* tags */
  #shopify-section-{{ section.id }} .wcu__tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: auto; }
  #shopify-section-{{ section.id }} .wcu__tag {
    display: inline-block;
    padding: 5px 14px;
    border-radius: 999px;
    font-family: 'Poppins', sans-serif;
    font-size: 12px; font-weight: 500;
    background: linear-gradient(145deg, var(--wcu-bg), var(--wcu-bg2));
    box-shadow: 2px 2px 4px var(--wcu-shadow-d), -2px -2px 4px var(--wcu-shadow-l);
    color: var(--wcu-muted);
  }
  #shopify-section-{{ section.id }} .wcu__tag--gold {
    background: linear-gradient(135deg, var(--wcu-gold), var(--wcu-gold-l));
    color: #fff;
    box-shadow: 0 3px 8px rgba(171,140,82,.25);
  }

  /* checklist */
  #shopify-section-{{ section.id }} .wcu__list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  #shopify-section-{{ section.id }} .wcu__list li {
    position: relative; padding-left: 20px;
    font-size: 14px; line-height: 1.6; color: var(--wcu-muted);
  }
  #shopify-section-{{ section.id }} .wcu__list li::before {
    content: '✓'; position: absolute; left: 0; top: 0;
    color: var(--wcu-gold); font-weight: 700; font-size: 13px;
  }

  /* ── Image-top card ── */
  #shopify-section-{{ section.id }} .wcu__card--img { padding: 0; overflow: hidden; }
  #shopify-section-{{ section.id }} .wcu__card--img .wcu__img-body { padding: 24px 28px; }
  #shopify-section-{{ section.id }} .wcu__card--img .wcu__card-desc { margin-bottom: 0; }

  /* ── Wide (highlight) card ── */
  #shopify-section-{{ section.id }} .wcu__card--wide {
    grid-column: span 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .wcu__card--wide .wcu__hl-body {
    padding: 36px 32px;
    display: flex; flex-direction: column; justify-content: center;
  }
  #shopify-section-{{ section.id }} .wcu__card--wide .wcu__card-title { font-size: 24px; margin-bottom: 14px; }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .wcu__card--wide { grid-column: span 2; }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .wcu__card--wide {
      grid-column: span 1;
      grid-template-columns: 1fr;
    }
  }

  /* ── Media (images & video) ── */
  #shopify-section-{{ section.id }} .wcu__ph {
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, #ddd5c8 0%, #c9c0b0 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 42px; color: rgba(0,0,0,.15);
    width: 100%;
  }
  #shopify-section-{{ section.id }} .wcu__card--wide .wcu__ph { aspect-ratio: auto; min-height: 320px; }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .wcu__card--wide .wcu__ph { min-height: 200px; }
  }
  #shopify-section-{{ section.id }} .wcu__img {
    width: 100%; display: block; object-fit: cover;
    aspect-ratio: 4/3;
  }
  #shopify-section-{{ section.id }} .wcu__card--wide .wcu__img { aspect-ratio: auto; min-height: 320px; }
  #shopify-section-{{ section.id }} .wcu__media-wrap { width: 100%; }
  #shopify-section-{{ section.id }} .wcu__video { width: 100%; display: block; aspect-ratio: 4/3; object-fit: cover; }
  #shopify-section-{{ section.id }} .wcu__card--wide .wcu__video { aspect-ratio: auto; min-height: 320px; height: 100%; }

  /* video-url embed */
  #shopify-section-{{ section.id }} .wcu__video-ph {
    position: relative; cursor: pointer; overflow: hidden;
    aspect-ratio: 4/3;
    background: #111;
  }
  #shopify-section-{{ section.id }} .wcu__card--wide .wcu__video-ph { aspect-ratio: auto; min-height: 320px; }
  #shopify-section-{{ section.id }} .wcu__video-ph .wcu__img { aspect-ratio: auto; position: absolute; inset: 0; height: 100%; }
  #shopify-section-{{ section.id }} .wcu__play-btn {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 64px; height: 64px; border-radius: 50%;
    border: none; cursor: pointer;
    background: rgba(0,0,0,.55);
    color: #fff; font-size: 22px;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s, transform .2s;
    backdrop-filter: blur(4px);
  }
  #shopify-section-{{ section.id }} .wcu__play-btn:hover { background: rgba(0,0,0,.75); transform: translate(-50%,-50%) scale(1.08); }

  /* ── Stats row ── */
  #shopify-section-{{ section.id }} .wcu__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 24px;
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .wcu__stats { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .wcu__stats { grid-template-columns: repeat(2, 1fr); }
  }
  #shopify-section-{{ section.id }} .wcu__stat {
    padding: 24px 16px;
    border-radius: 18px;
    text-align: center;
    background: linear-gradient(150deg, var(--wcu-bg), var(--wcu-bg2));
    box-shadow: 5px 5px 12px var(--wcu-shadow-d), -5px -5px 12px var(--wcu-shadow-l);
  }
  #shopify-section-{{ section.id }} .wcu__stat-num {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: var(--wcu-stat);
    font-weight: 800;
    background: linear-gradient(135deg, var(--wcu-gold), var(--wcu-gold-l));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 6px;
  }
  #shopify-section-{{ section.id }} .wcu__stat-label {
    font-size: 13px;
    color: var(--wcu-muted);
    font-family: 'Poppins', sans-serif;
  }

  /* ── FAQ accordion ── */
  #shopify-section-{{ section.id }} .wcu__faq { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
  #shopify-section-{{ section.id }} .wcu__faq-item {
    border-radius: 14px; overflow: hidden;
    background: linear-gradient(145deg, var(--wcu-bg), var(--wcu-bg2));
    box-shadow: inset 2px 2px 4px rgba(255,255,255,.6), inset -2px -2px 4px rgba(0,0,0,.03);
  }
  #shopify-section-{{ section.id }} .wcu__faq-item summary {
    list-style: none; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 18px;
    font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600;
    color: var(--wcu-text);
  }
  #shopify-section-{{ section.id }} .wcu__faq-item summary::-webkit-details-marker { display: none; }
  #shopify-section-{{ section.id }} .wcu__faq-plus { font-size: 18px; transition: transform .25s; flex-shrink: 0; margin-left: 8px; }
  #shopify-section-{{ section.id }} .wcu__faq-item[open] .wcu__faq-plus { transform: rotate(45deg); }
  #shopify-section-{{ section.id }} .wcu__faq-body {
    padding: 0 18px 18px;
    font-size: 14px; line-height: 1.7;
    color: var(--wcu-muted);
  }

  /* ── Responsive grid ── */
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .wcu__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .wcu__grid { grid-template-columns: repeat(var(--wcu-cols), 1fr); }
  }
</style>

{%- comment -%}Count tabs{%- endcomment -%}
{%- assign total_tabs = 0 -%}
{%- for b in section.blocks -%}
  {%- if b.type == 'tab' -%}{%- assign total_tabs = total_tabs | plus: 1 -%}{%- endif -%}
{%- endfor -%}

<section class="wcu" id="wcu-{{ section.id }}">
  <div class="wcu__inner">

    {%- if section.settings.eyebrow != blank -%}
      <div class="wcu__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <{{ section.settings.title_tag }} class="wcu__title">{{ section.settings.title }}</{{ section.settings.title_tag }}>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="wcu__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if total_tabs > 1 -%}
      <div class="wcu__tabs" role="tablist">
        {%- assign ti = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'tab' -%}
            {%- assign ti = ti | plus: 1 -%}
            <button class="wcu__tab{% if ti == 1 %} active{% endif %}"
                    role="tab"
                    aria-selected="{% if ti == 1 %}true{% else %}false{% endif %}"
                    onclick="wcuTab(this,{{ ti }},'{{ section.id }}')"
                    {{ block.shopify_attributes }}>
              {{- block.settings.tab_name | default: 'Tab' -}}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%}——— Panels ———{%- endcomment -%}
    {%- assign pi = 0 -%}
    {%- for tab_block in section.blocks -%}
      {%- if tab_block.type == 'tab' -%}
        {%- assign pi = pi | plus: 1 -%}
        {%- assign ps = pi | append: '' -%}

        <div class="wcu__panel{% if pi == 1 %} active{% endif %}"
             data-tab-panel="{{ pi }}"
             data-section="{{ section.id }}"
             role="tabpanel"
             {{ tab_block.shopify_attributes }}>

          {%- comment -%}— Cards —{%- endcomment -%}
          {%- assign has_cards = false -%}
          {%- for b in section.blocks -%}
            {%- if b.type == 'card' and b.settings.tab_index == ps -%}{%- assign has_cards = true -%}{%- endif -%}
          {%- endfor -%}

          {%- if has_cards -%}
          <div class="wcu__grid">
            {%- for card in section.blocks -%}
              {%- if card.type == 'card' and card.settings.tab_index == ps -%}
                {%- assign lo = card.settings.layout -%}

                <div class="wcu__card{% if lo == 'image_top' %} wcu__card--img{% elsif lo == 'wide' %} wcu__card--wide{% endif %}"
                     {{ card.shopify_attributes }}>

                  {%- if lo == 'wide' -%}
                    {%- if card.settings.video != blank -%}
                      <div class="wcu__media-wrap">
                        {{- card.settings.video | video_tag: autoplay: false, loop: false, controls: true, muted: false, class: 'wcu__video' -}}
                      </div>
                    {%- elsif card.settings.video_url != blank -%}
                      <div class="wcu__video-ph" data-video-url="{{ card.settings.video_url.url }}">
                        {%- if card.settings.image != blank -%}
                          {{ card.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'wcu__img' }}
                        {%- else -%}
                          <div class="wcu__ph">{{ card.settings.emoji | default: '▶' }}</div>
                        {%- endif -%}
                        <button class="wcu__play-btn" aria-label="Play video">&#9654;</button>
                      </div>
                    {%- elsif card.settings.image != blank -%}
                      {{ card.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'wcu__img' }}
                    {%- else -%}
                      <div class="wcu__ph">{{ card.settings.emoji | default: '💎' }}</div>
                    {%- endif -%}
                    <div class="wcu__hl-body">
                      {%- if card.settings.title != blank -%}<h3 class="wcu__card-title">{{ card.settings.title }}</h3>{%- endif -%}
                      {%- if card.settings.description != blank -%}<p class="wcu__card-desc">{{ card.settings.description }}</p>{%- endif -%}
                      {%- if card.settings.tags != blank -%}
                        <div class="wcu__tags">
                          {%- assign tag_list = card.settings.tags | newline_to_br | split: '<br />' -%}
                          {%- for tl in tag_list -%}
                            {%- assign t = tl | strip -%}
                            {%- if t != blank -%}
                              {%- if t contains '*' -%}<span class="wcu__tag wcu__tag--gold">{{ t | remove: '*' | strip }}</span>
                              {%- else -%}<span class="wcu__tag">{{ t }}</span>{%- endif -%}
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    </div>

                  {%- elsif lo == 'image_top' -%}
                    {%- if card.settings.video != blank -%}
                      <div class="wcu__media-wrap">
                        {{- card.settings.video | video_tag: autoplay: false, loop: false, controls: true, muted: false, class: 'wcu__video' -}}
                      </div>
                    {%- elsif card.settings.video_url != blank -%}
                      <div class="wcu__video-ph" data-video-url="{{ card.settings.video_url.url }}">
                        {%- if card.settings.image != blank -%}
                          {{ card.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'wcu__img' }}
                        {%- else -%}
                          <div class="wcu__ph">{{ card.settings.emoji | default: '▶' }}</div>
                        {%- endif -%}
                        <button class="wcu__play-btn" aria-label="Play video">&#9654;</button>
                      </div>
                    {%- elsif card.settings.image != blank -%}
                      {{ card.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'wcu__img' }}
                    {%- else -%}
                      <div class="wcu__ph">{{ card.settings.emoji | default: '🖼️' }}</div>
                    {%- endif -%}
                    <div class="wcu__img-body">
                      {%- if card.settings.title != blank -%}<h3 class="wcu__card-title">{{ card.settings.title }}</h3>{%- endif -%}
                      {%- if card.settings.description != blank -%}<p class="wcu__card-desc">{{ card.settings.description }}</p>{%- endif -%}
                    </div>

                  {%- else -%}
                    {%- if card.settings.icon_image != blank -%}
                      <div class="wcu__card-emoji">
                        {{ card.settings.icon_image | image_url: width: 56 | image_tag: loading: 'lazy' }}
                      </div>
                    {%- elsif card.settings.emoji != blank -%}
                      <div class="wcu__card-emoji">{{ card.settings.emoji }}</div>
                    {%- endif -%}
                    {%- if card.settings.title != blank -%}<h3 class="wcu__card-title">{{ card.settings.title }}</h3>{%- endif -%}
                    {%- if card.settings.description != blank -%}<p class="wcu__card-desc">{{ card.settings.description }}</p>{%- endif -%}
                    {%- if card.settings.tags != blank -%}
                      <div class="wcu__tags">
                        {%- assign tag_list = card.settings.tags | newline_to_br | split: '<br />' -%}
                        {%- for tl in tag_list -%}
                          {%- assign t = tl | strip -%}
                          {%- if t != blank -%}
                            {%- if t contains '*' -%}<span class="wcu__tag wcu__tag--gold">{{ t | remove: '*' | strip }}</span>
                            {%- else -%}<span class="wcu__tag">{{ t }}</span>{%- endif -%}
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                    {%- if card.settings.checklist != blank -%}
                      <ul class="wcu__list">
                        {%- assign items = card.settings.checklist | newline_to_br | split: '<br />' -%}
                        {%- for it in items -%}
                          {%- assign i = it | strip -%}
                          {%- if i != blank -%}<li>{{ i }}</li>{%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                    {%- if card.settings.faq_q1 != blank or card.settings.faq_q2 != blank or card.settings.faq_q3 != blank -%}
                      <div class="wcu__faq">
                        {%- if card.settings.faq_q1 != blank -%}
                          <details class="wcu__faq-item" open>
                            <summary><span>{{ card.settings.faq_q1 }}</span><span class="wcu__faq-plus">+</span></summary>
                            <div class="wcu__faq-body">{{ card.settings.faq_a1 }}</div>
                          </details>
                        {%- endif -%}
                        {%- if card.settings.faq_q2 != blank -%}
                          <details class="wcu__faq-item">
                            <summary><span>{{ card.settings.faq_q2 }}</span><span class="wcu__faq-plus">+</span></summary>
                            <div class="wcu__faq-body">{{ card.settings.faq_a2 }}</div>
                          </details>
                        {%- endif -%}
                        {%- if card.settings.faq_q3 != blank -%}
                          <details class="wcu__faq-item">
                            <summary><span>{{ card.settings.faq_q3 }}</span><span class="wcu__faq-plus">+</span></summary>
                            <div class="wcu__faq-body">{{ card.settings.faq_a3 }}</div>
                          </details>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- endif -%}

                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- endif -%}

          {%- comment -%}— Stats —{%- endcomment -%}
          {%- assign has_stats = false -%}
          {%- for b in section.blocks -%}
            {%- if b.type == 'stat' and b.settings.tab_index == ps -%}{%- assign has_stats = true -%}{%- endif -%}
          {%- endfor -%}
          {%- if has_stats -%}
          <div class="wcu__stats">
            {%- for stat in section.blocks -%}
              {%- if stat.type == 'stat' and stat.settings.tab_index == ps -%}
                <div class="wcu__stat" {{ stat.shopify_attributes }}>
                  <div class="wcu__stat-num">{{ stat.settings.number }}</div>
                  <div class="wcu__stat-label">{{ stat.settings.label }}</div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- endif -%}

        </div>{%- comment -%}end panel{%- endcomment -%}
      {%- endif -%}
    {%- endfor -%}

  </div>
</section>

<script>
(function () {
  function wcuTab(btn, idx, sid) {
    var s = document.getElementById('wcu-' + sid);
    if (!s) return;
    s.querySelectorAll('.wcu__tab').forEach(function(t) {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    s.querySelectorAll('.wcu__panel').forEach(function(p) {
      p.classList.remove('active');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    var panel = s.querySelector('[data-tab-panel="' + idx + '"]');
    if (panel) panel.classList.add('active');
  }
  window.wcuTab = wcuTab;

  /* Video URL embed (YouTube / Vimeo) */
  document.querySelectorAll('.wcu__video-ph').forEach(function(el) {
    el.addEventListener('click', function () {
      var url = el.getAttribute('data-video-url');
      if (!url) return;
      var src = url;
      if (url.includes('youtube.com/watch')) {
        src = url.replace('watch?v=', 'embed/').split('&')[0] + '?autoplay=1';
      } else if (url.includes('youtu.be/')) {
        var id = url.split('youtu.be/')[1].split('?')[0];
        src = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
      } else if (url.includes('vimeo.com/')) {
        var vid = url.split('vimeo.com/')[1].split('?')[0];
        src = 'https://player.vimeo.com/video/' + vid + '?autoplay=1';
      }
      var iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
      el.style.position = 'relative';
      el.innerHTML = '';
      el.appendChild(iframe);
    });
  });
})();
</script>

