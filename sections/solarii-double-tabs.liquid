  </style>

  <script>
    (() => {
      const section = document.getElementById('solarii-double-tabs-{{ section.id }}');
      if (!section) return;

      const outerTabs = section.querySelectorAll('[data-outer-tab]');
      const panels = section.querySelectorAll('[data-panel]');
      const innerTabs = section.querySelectorAll('[data-inner-tab]');
      const innerPanels = section.querySelectorAll('[data-inner-panel]');

      const cshRoot = section.querySelector('[data-csh-root]');
      const customPanel = section.querySelector('[data-panel="custom"]');
      const body = document.body;

      let backdrops = [];
      let openBtns = [];

      function isMobile() {
        return window.matchMedia && window.matchMedia('(max-width: 749px)').matches;
      }

      function getBackdropNodes() {
        if (!cshRoot) return [];
        return Array.from(cshRoot.querySelectorAll('[data-csh-backdrop]'));
      }

      function anyModalOpen() {
        return getBackdropNodes().some((bd) => bd.classList.contains('is-open'));
      }

      function pauseVideos(scope) {
        if (!scope) return;
        scope.querySelectorAll('video').forEach((video) => {
          try { video.pause(); } catch (e) {}
        });
      }

      function syncCustomHeroVideos() {
        if (!cshRoot || !customPanel) return;

        const vd = cshRoot.querySelector('.sdtcsh__heroVideo--desktop');
        const vm = cshRoot.querySelector('.sdtcsh__heroVideo--mobile');
        const panelActive = customPanel.classList.contains('is-active');
        const modalOpened = anyModalOpen();

        if (!panelActive || modalOpened) {
          if (vd) { try { vd.pause(); } catch (e) {} }
          if (vm) { try { vm.pause(); } catch (e) {} }
          return;
        }

        if (isMobile()) {
          if (vd) { try { vd.pause(); } catch (e) {} }
          if (vm && vm.hasAttribute('autoplay')) {
            try { vm.play(); } catch (e) {}
          }
        } else {
          if (vm) { try { vm.pause(); } catch (e) {} }
          if (vd && vd.hasAttribute('autoplay')) {
            try { vd.play(); } catch (e) {}
          }
        }
      }

      function closeAllCustomModals() {
        if (!cshRoot) return;
        backdrops.forEach((bd) => {
          bd.classList.remove('is-open');
          pauseVideos(bd);
        });
        body.style.overflow = '';
        syncCustomHeroVideos();
      }

      function openModal(id) {
        if (!cshRoot) return;
        closeAllCustomModals();

        const bd = cshRoot.querySelector('[data-csh-backdrop][data-modal="' + id + '"]');
        if (!bd) return;

        bd.classList.add('is-open');

        if (!isMobile()) {
          body.style.overflow = 'hidden';
        }

        syncCustomHeroVideos();

        const video = bd.querySelector('video');
        if (video && video.hasAttribute('autoplay')) {
          try { video.play(); } catch (e) {}
        }
      }

      outerTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-outer-tab');

          outerTabs.forEach((item) => item.classList.remove('is-active'));
          panels.forEach((panel) => panel.classList.remove('is-active'));

          tab.classList.add('is-active');
          const activePanel = section.querySelector('[data-panel="' + target + '"]');
          if (activePanel) activePanel.classList.add('is-active');

          if (target !== 'custom') {
            closeAllCustomModals();
            if (cshRoot) pauseVideos(cshRoot);
          } else {
            syncCustomHeroVideos();
          }
        });
      });

      innerTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-inner-tab');

          innerTabs.forEach((item) => item.classList.remove('is-active'));
          innerPanels.forEach((panel) => panel.classList.remove('is-active'));

          tab.classList.add('is-active');
          const activePanel = section.querySelector('[data-inner-panel="' + target + '"]');
          if (activePanel) activePanel.classList.add('is-active');
        });
      });

      if (cshRoot) {
        backdrops = Array.from(cshRoot.querySelectorAll('[data-csh-backdrop]'));
        openBtns = Array.from(cshRoot.querySelectorAll('[data-csh-open]'));

        openBtns.forEach((btn) => {
          btn.addEventListener('click', () => {
            const hot = btn.closest('[data-csh-hotspot]');
            const id = hot ? hot.getAttribute('data-modal-id') : null;
            if (id) openModal(id);
          });
        });

        backdrops.forEach((bd) => {
          bd.addEventListener('click', (e) => {
            if (e.target === bd) closeAllCustomModals();
          });

          const closeBtn = bd.querySelector('[data-csh-close]');
          if (closeBtn) {
            closeBtn.addEventListener('click', closeAllCustomModals);
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeAllCustomModals();
        });

        syncCustomHeroVideos();
        window.addEventListener('resize', syncCustomHeroVideos, { passive: true });

        if (window.Shopify && Shopify.designMode) {
          document.addEventListener('shopify:section:load', syncCustomHeroVideos);
          document.addEventListener('shopify:section:reorder', syncCustomHeroVideos);
          document.addEventListener('shopify:section:select', syncCustomHeroVideos);
        }

        {% if section.settings.custom_coord_helper %}
        try {
          if (window.Shopify && Shopify.designMode) {
            const hero = cshRoot.querySelector('[data-csh-hero]');
            if (hero) {
              hero.addEventListener('click', (e) => {
                const rect = hero.getBoundingClientRect();
                const x = ((e.clientX - rect.left) / rect.width) * 100;
                const y = ((e.clientY - rect.top) / rect.height) * 100;
                const msg = 'X: ' + x.toFixed(1) + '% , Y: ' + y.toFixed(1) + '%';
                console.log('[Hotspot coords]', msg);
                if (navigator.clipboard) navigator.clipboard.writeText(msg).catch(() => {});
              });
            }
          }
        } catch (err) {}
        {% endif %}

        const enableSparkle = {{ section.settings.custom_sparkle_trail | json }};
        const strength = Number({{ section.settings.custom_sparkle_strength | default: 5 }});

        if (enableSparkle && window.matchMedia && window.matchMedia('(pointer:fine)').matches) {
          const hero = cshRoot.querySelector('[data-csh-hero]');
          const canvas = cshRoot.querySelector('[data-csh-sparkle]');

          if (hero && canvas) {
            const ctx = canvas.getContext('2d', { alpha: true });
            let dpr = Math.max(1, window.devicePixelRatio || 1);
            let w = 0;
            let h = 0;

            function resizeCanvas() {
              const rect = hero.getBoundingClientRect();
              w = Math.max(1, Math.floor(rect.width));
              h = Math.max(1, Math.floor(rect.height));
              dpr = Math.max(1, window.devicePixelRatio || 1);
              canvas.width = Math.floor(w * dpr);
              canvas.height = Math.floor(h * dpr);
              canvas.style.width = w + 'px';
              canvas.style.height = h + 'px';
              ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            }

            const particles = [];
            const MAX = 220;
            let raf = 0;
            let lastT = 0;
            let lastEmit = 0;

            function rand(a, b) {
              return a + Math.random() * (b - a);
            }

            function drawStar(x, y, r, rot, alpha) {
              const spikes = 5;
              const inner = r * 0.45;

              ctx.save();
              ctx.translate(x, y);
              ctx.rotate(rot);
              ctx.globalAlpha = alpha;
              ctx.beginPath();

              for (let i = 0; i < spikes; i++) {
                ctx.lineTo(Math.cos((i * 2 * Math.PI) / spikes) * r, Math.sin((i * 2 * Math.PI) / spikes) * r);
                ctx.lineTo(Math.cos(((i * 2 + 1) * Math.PI) / spikes) * inner, Math.sin(((i * 2 + 1) * Math.PI) / spikes) * inner);
              }

              ctx.closePath();
              ctx.fillStyle = Math.random() < 0.5 ? 'rgba(255,255,255,1)' : 'rgba(255,246,226,1)';
              ctx.fill();
              ctx.restore();
            }

            function tick(t) {
              raf = requestAnimationFrame(tick);
              const dt = Math.min(0.033, (t - lastT) / 1000 || 0.016);
              lastT = t;

              ctx.clearRect(0, 0, w, h);

              for (let i = particles.length - 1; i >= 0; i--) {
                const p = particles[i];
                p.life -= dt;

                if (p.life <= 0) {
                  particles.splice(i, 1);
                  continue;
                }

                p.x += p.vx * dt;
                p.y += p.vy * dt;
                p.vy += p.g * dt;
                p.rot += p.vr * dt;

                const a = Math.max(0, Math.min(1, p.life / p.maxLife));
                drawStar(p.x, p.y, p.r, p.rot, a);
              }

              if (particles.length === 0) {
                cancelAnimationFrame(raf);
                raf = 0;
              }
            }

            function emitAt(clientX, clientY) {
              const now = performance.now();
              if (now - lastEmit < 14) return;
              lastEmit = now;

              const rect = hero.getBoundingClientRect();
              const x = clientX - rect.left;
              const y = clientY - rect.top;

              const count = Math.max(1, Math.round(strength / 2));

              for (let i = 0; i < count; i++) {
                if (particles.length >= MAX) particles.shift();

                const life = rand(0.45, 0.85);
                particles.push({
                  x: x + rand(-2, 2),
                  y: y + rand(-2, 2),
                  vx: rand(-40, 40),
                  vy: rand(-60, -10),
                  g: rand(120, 220),
                  r: rand(2.2, 4.4),
                  rot: rand(0, Math.PI * 2),
                  vr: rand(-6, 6),
                  life: life,
                  maxLife: life
                });
              }

              if (!raf) {
                lastT = performance.now();
                raf = requestAnimationFrame(tick);
              }
            }

            resizeCanvas();
            window.addEventListener('resize', resizeCanvas, { passive: true });
            hero.addEventListener('pointermove', (e) => emitAt(e.clientX, e.clientY), { passive: true });

            if (window.Shopify && Shopify.designMode) {
              document.addEventListener('shopify:section:load', resizeCanvas);
              document.addEventListener('shopify:section:reorder', resizeCanvas);
            }
          }
        }
      }
    })();
  </script>
</section>

