{% liquid
  assign design_blocks = section.blocks | where: 'type', 'design_series'
  assign hotspot_blocks = section.blocks | where: 'type', 'hotspot'
%}

<section id="solarii-double-tabs-{{ section.id }}" class="solarii-double-tabs">
  <div class="sdt__inner page-width">
    <div class="sdt__outer-tabs" role="tablist" aria-label="外层标签">
      <button class="sdt__outer-tab is-active" type="button" data-outer-tab="design">
        {{ section.settings.outer_label_1 }}
      </button>
      <button class="sdt__outer-tab" type="button" data-outer-tab="custom">
        {{ section.settings.outer_label_2 }}
      </button>
    </div>

    <div class="sdt__shell">
      <div class="sdt__panel sdt__panel--design is-active" data-panel="design">
        {% if design_blocks.size > 0 %}
          <div class="sdt__inner-tabs sdt__inner-tabs--design" role="tablist" aria-label="系列标签">
            {% for block in design_blocks %}
              <button
                class="sdt__inner-tab sdt__inner-tab--design {% if forloop.first %}is-active{% endif %}"
                type="button"
                data-inner-tab="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.tab_label }}
              </button>
            {% endfor %}
          </div>

          <div class="sdt__inner-panels">
            {% for block in design_blocks %}
              <div class="sdt__inner-panel {% if forloop.first %}is-active{% endif %}" data-inner-panel="{{ block.id }}">
                <div class="sdt__media-card">
                  {% if block.settings.media_type == 'video' and block.settings.video != blank %}
                    {{
                      block.settings.video
                      | video_tag:
                        controls: true,
                        autoplay: false,
                        loop: false,
                        muted: true,
                        playsinline: true,
                        class: 'sdt__media-video'
                    }}
                  {% elsif block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1800
                      | image_tag:
                        loading: 'lazy',
                        class: 'sdt__media-image',
                        widths: '600, 900, 1200, 1500, 1800'
                    }}
                  {% else %}
                    <div class="sdt__media-placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {% endif %}
                </div>

                <div class="sdt__copy-card">
                  {% if block.settings.kicker != blank %}
                    <div class="sdt__copy-kicker">{{ block.settings.kicker }}</div>
                  {% endif %}

                  {% if block.settings.title != blank %}
                    <h3 class="sdt__copy-title">{{ block.settings.title }}</h3>
                  {% endif %}

                  {% if block.settings.desc != blank %}
                    <div class="sdt__copy-body">{{ block.settings.desc }}</div>
                  {% endif %}

                  <div class="sdt__meta-grid">
                    {% if block.settings.sub_1_title != blank or block.settings.sub_1_text != blank %}
                      <div class="sdt__meta-item">
                        {% if block.settings.sub_1_title != blank %}
                          <div class="sdt__meta-label">{{ block.settings.sub_1_title }}</div>
                        {% endif %}
                        {% if block.settings.sub_1_text != blank %}
                          <div class="sdt__meta-value">{{ block.settings.sub_1_text }}</div>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% if block.settings.sub_2_title != blank or block.settings.sub_2_text != blank %}
                      <div class="sdt__meta-item">
                        {% if block.settings.sub_2_title != blank %}
                          <div class="sdt__meta-label">{{ block.settings.sub_2_title }}</div>
                        {% endif %}
                        {% if block.settings.sub_2_text != blank %}
                          <div class="sdt__meta-value">{{ block.settings.sub_2_text }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>

                  {% if block.settings.button_text != blank %}
                    <div class="sdt__actions">
                      <a
                        class="sdt__btn sdt__btn--primary"
                        {% if block.settings.button_link != blank %}
                          href="{{ block.settings.button_link }}"
                        {% else %}
                          role="link" aria-disabled="true"
                        {% endif %}
                      >
                        {{ block.settings.button_text }}
                      </a>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="sdt__empty">请在主题编辑器中添加系列区块</div>
        {% endif %}
      </div>

      <div class="sdt__panel sdt__panel--custom" data-panel="custom">
        {% liquid
          assign hero_img = section.settings.custom_image
          assign hero_img_m = section.settings.custom_image_mobile
          assign hero_vid_d = section.settings.custom_video
          assign hero_vid_m = section.settings.custom_video_mobile
        %}

        <div class="sdtcsh" data-csh-root>
          <div class="sdtcsh__hero" data-csh-hero>
            {% if section.settings.custom_media_type == 'video' and hero_vid_d != blank %}
              <div class="sdtcsh__media sdtcsh__media--video">
                {{
                  hero_vid_d
                  | video_tag:
                    class: 'sdtcsh__img sdtcsh__heroVideo sdtcsh__heroVideo--desktop',
                    autoplay: section.settings.custom_video_autoplay,
                    loop: true,
                    muted: true,
                    controls: false,
                    playsinline: true,
                    preload: 'metadata'
                }}

                {% if hero_vid_m != blank %}
                  {{
                    hero_vid_m
                    | video_tag:
                      class: 'sdtcsh__img sdtcsh__heroVideo sdtcsh__heroVideo--mobile',
                      autoplay: section.settings.custom_video_autoplay,
                      loop: true,
                      muted: true,
                      controls: false,
                      playsinline: true,
                      preload: 'metadata'
                  }}
                {% else %}
                  {{
                    hero_vid_d
                    | video_tag:
                      class: 'sdtcsh__img sdtcsh__heroVideo sdtcsh__heroVideo--mobile',
                      autoplay: section.settings.custom_video_autoplay,
                      loop: true,
                      muted: true,
                      controls: false,
                      playsinline: true,
                      preload: 'metadata'
                  }}
                {% endif %}
              </div>
            {% elsif hero_img != blank %}
              <picture class="sdtcsh__media">
                {% if hero_img_m != blank %}
                  <source media="(max-width: 749px)" srcset="{{ hero_img_m | image_url: width: 1200 }}">
                {% endif %}
                <img
                  src="{{ hero_img | image_url: width: 2400 }}"
                  alt="{{ section.settings.custom_image_alt | escape }}"
                  loading="lazy"
                  class="sdtcsh__img"
                >
              </picture>
            {% else %}
              <div class="sdtcsh__fallback" aria-hidden="true"></div>
            {% endif %}

            <div class="sdtcsh__overlay" aria-hidden="true"></div>
            <canvas class="sdtcsh__sparkle" data-csh-sparkle aria-hidden="true"></canvas>

            {% if section.settings.custom_bg_word != blank %}
              <div class="sdtcsh__bgword" aria-hidden="true">{{ section.settings.custom_bg_word }}</div>
            {% endif %}

            <div class="sdtcsh__content">
              <div class="sdtcsh__copy">
                {% if section.settings.custom_eyebrow != blank %}
                  <div class="sdtcsh__eyebrow">{{ section.settings.custom_eyebrow }}</div>
                {% endif %}

                {% if section.settings.custom_title != blank %}
                  <h2 class="sdtcsh__heading">{{ section.settings.custom_title }}</h2>
                {% endif %}

                {% if section.settings.custom_desc != blank %}
                  <div class="sdtcsh__subheading">{{ section.settings.custom_desc | newline_to_br }}</div>
                {% endif %}
              </div>

              {% if section.settings.custom_button_text != blank %}
                {% assign cta_href = section.settings.custom_button_link %}
                <a
                  class="sdtcsh__cta sdtcsh__cta--{{ section.settings.custom_button_style }}{% if cta_href == blank %} is-disabled{% endif %}"
                  href="{% if cta_href != blank %}{{ cta_href }}{% else %}#{% endif %}"
                  {% if cta_href == blank %}aria-disabled="true"{% endif %}
                >
                  {{ section.settings.custom_button_text }}
                </a>
              {% endif %}
            </div>

            {% for block in hotspot_blocks %}
              {% liquid
                assign label_side = block.settings.label_side
                assign show_on_mobile = block.settings.show_on_mobile
                assign modal_title = block.settings.modal_title
                if modal_title == blank
                  assign modal_title = block.settings.label
                endif
              %}

              <div
                class="sdtcsh__hotspot {% unless show_on_mobile %}sdtcsh__hotspot--hide-mobile{% endunless %}"
                style="--x: {{ block.settings.pos_x }}%; --y: {{ block.settings.pos_y }}%; --xm: {{ block.settings.pos_x_m }}%; --ym: {{ block.settings.pos_y_m }}%;"
                data-csh-hotspot
                data-modal-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {% if label_side == 'left' %}
                  <span class="sdtcsh__label">{{ block.settings.label }}</span>
                {% endif %}

                <button
                  type="button"
                  class="sdtcsh__dot"
                  aria-label="{{ block.settings.label | default: 'Open hotspot' | escape }}"
                  data-csh-open
                >
                  <span class="sdtcsh__plus" aria-hidden="true"></span>
                </button>

                {% if label_side == 'right' %}
                  <span class="sdtcsh__label">{{ block.settings.label }}</span>
                {% endif %}
              </div>

              <div class="sdtcsh__backdrop" data-csh-backdrop data-modal="{{ block.id }}" aria-hidden="true">
                <div class="sdtcsh__modal" role="dialog" aria-modal="true" aria-label="{{ modal_title | escape }}">
                  <div class="sdtcsh__modalGrid">
                    <div class="sdtcsh__modalText">
                      <div class="sdtcsh__modalTitle">{{ modal_title }}</div>

                      {% if block.settings.modal_text != blank %}
                        <div class="sdtcsh__modalBody">{{ block.settings.modal_text }}</div>
                      {% endif %}

                      {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                        <a class="sdtcsh__learn" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
                      {% endif %}
                    </div>

                    <div class="sdtcsh__modalMedia">
                      <button type="button" class="sdtcsh__close" aria-label="Close" data-csh-close>×</button>

                      {% if block.settings.media_type == 'video' and block.settings.video != blank %}
                        <div class="sdtcsh__videoWrap">
                          {{
                            block.settings.video
                            | video_tag:
                              class: 'sdtcsh__video',
                              autoplay: block.settings.video_autoplay,
                              loop: true,
                              muted: true,
                              controls: false,
                              playsinline: true,
                              preload: 'metadata'
                          }}
                        </div>
                      {% elsif block.settings.media_type == 'image' and block.settings.media_image != blank %}
                        <img
                          class="sdtcsh__mediaImg"
                          src="{{ block.settings.media_image | image_url: width: 1400 }}"
                          alt=""
                          loading="lazy"
                        >
                      {% else %}
                        <div class="sdtcsh__mediaEmpty" aria-hidden="true"></div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

    </div>
  </div>

  <style>
    #solarii-double-tabs-{{ section.id }} {
      --sdt-bg: {{ section.settings.section_bg }};
      --sdt-card: {{ section.settings.card_bg }};
      --sdt-text: {{ section.settings.text_color }};
      --sdt-sub: {{ section.settings.subtext_color }};
      --sdt-border: {{ section.settings.border_color }};
      --sdt-pill: {{ section.settings.pill_bg }};
      --sdt-pill-active: {{ section.settings.pill_active_bg }};
      --sdt-pill-active-text: {{ section.settings.pill_active_text }};
      --sdt-btn: {{ section.settings.button_bg }};
      --sdt-btn-text: {{ section.settings.button_text_color }};
      background: var(--sdt-bg);
      color: var(--sdt-text);
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      position: relative;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner {
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
    }

    #solarii-double-tabs-{{ section.id }} * {
      box-sizing: border-box;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tabs {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      max-width: 560px;
      margin: 0 auto 24px;
      padding: 8px;
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid var(--sdt-border);
      border-radius: 22px;
      box-shadow: 0 10px 28px rgba(31, 27, 24, 0.04);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab,
    #solarii-double-tabs-{{ section.id }} .sdt__inner-tab,
    #solarii-double-tabs-{{ section.id }} .sdt__btn {
      appearance: none;
      border: 1px solid var(--sdt-border);
      background: var(--sdt-pill);
      color: var(--sdt-text);
      cursor: pointer;
      transition: all .25s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab {
      min-height: 54px;
      padding: 12px 16px;
      border-radius: 16px;
      background: transparent;
      border: 1px solid transparent;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
      text-align: center;
      white-space: normal;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab:hover {
      background: rgba(255, 255, 255, 0.72);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab.is-active {
      background: var(--sdt-pill-active);
      color: var(--sdt-pill-active-text);
      border-color: var(--sdt-pill-active);
      box-shadow: 0 10px 20px rgba(31, 27, 24, 0.12);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__panel {
      display: none;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__panel.is-active {
      display: block;
      animation: sdtFade .28s ease;
    }

    @keyframes sdtFade {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    #solarii-double-tabs-{{ section.id }} .sdt__shell {
      background: var(--sdt-card);
      border: 1px solid var(--sdt-border);
      border-radius: 28px;
      padding: 24px;
      box-shadow: 0 18px 60px rgba(30, 24, 18, 0.06);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__panel-head {
      display: grid;
      gap: 8px;
      margin-bottom: 22px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__eyebrow,
    #solarii-double-tabs-{{ section.id }} .sdt__copy-kicker,
    #solarii-double-tabs-{{ section.id }} .sdt__meta-label {
      font-size: 11px;
      line-height: 1;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--sdt-sub);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__title {
      margin: 0;
      font-size: clamp(28px, 4vw, 54px);
      line-height: 1.05;
      letter-spacing: -.03em;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__desc,
    #solarii-double-tabs-{{ section.id }} .sdt__copy-body {
      color: var(--sdt-sub);
      font-size: 15px;
      line-height: 1.75;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__panel--design .sdt__inner-tabs {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 20px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-tab--design {
      width: 100%;
      min-height: 52px;
      padding: 12px 10px;
      border-radius: 16px;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.25;
      text-align: center;
      white-space: normal;
      letter-spacing: .04em;
      text-transform: uppercase;
      border-color: var(--sdt-border);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-tab--design.is-active {
      background: var(--sdt-pill-active);
      color: var(--sdt-pill-active-text);
      border-color: var(--sdt-pill-active);
      box-shadow: 0 10px 20px rgba(31, 27, 24, 0.12);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-panel,
    #solarii-double-tabs-{{ section.id }} .sdt__single-layout {
      display: none;
      grid-template-columns: minmax(0, 1.08fr) minmax(320px, .92fr);
      gap: 22px;
      align-items: start;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-panel.is-active,
    #solarii-double-tabs-{{ section.id }} .sdt__single-layout {
      display: grid;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__media-card,
    #solarii-double-tabs-{{ section.id }} .sdt__copy-card {
      background: rgba(255,255,255,.66);
      border: 1px solid var(--sdt-border);
      border-radius: 22px;
      overflow: hidden;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__media-card {
      min-height: 420px;
      position: relative;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__media-image,
    #solarii-double-tabs-{{ section.id }} .sdt__media-video,
    #solarii-double-tabs-{{ section.id }} .sdt__media-card video,
    #solarii-double-tabs-{{ section.id }} .sdt__media-card iframe {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 420px;
      object-fit: cover;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__media-placeholder {
      height: 420px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #ece6de;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__copy-card {
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      align-self: start;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__copy-title {
      margin: 0;
      font-size: clamp(24px, 3vw, 38px);
      line-height: 1.08;
      letter-spacing: -.03em;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__meta-grid {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__meta-item {
      position: relative;
      padding: 0;
      background: transparent;
      border: 0;
      border-radius: 0;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__meta-item + .sdt__meta-item {
      margin-left: 28px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__meta-item + .sdt__meta-item::before {
      content: "|";
      position: absolute;
      left: -15px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--sdt-sub);
      font-size: 14px;
      line-height: 1;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__meta-item .sdt__meta-label {
      display: none;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__meta-value {
      margin-top: 0;
      font-size: 15px;
      line-height: 1.45;
      color: var(--sdt-text);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__btn {
      padding: 12px 18px;
      font-size: 13px;
      font-weight: 600;
      line-height: 1;
      border-radius: 999px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__btn--primary {
      background: var(--sdt-btn);
      color: var(--sdt-btn-text);
      border-color: var(--sdt-btn);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__empty {
      padding: 30px;
      border: 1px dashed var(--sdt-border);
      border-radius: 20px;
      color: var(--sdt-sub);
    }

    /* Custom Hotspot Hero */
    #solarii-double-tabs-{{ section.id }} .sdtcsh{
      --hDesk: {{ section.settings.custom_height_desktop }}px;
      --hMob: {{ section.settings.custom_height_mobile }}px;
      --overlay: {{ section.settings.custom_overlay_opacity | divided_by: 100.0 }};

      --text: {{ section.settings.custom_text_color }};
      --label: {{ section.settings.custom_label_color }};
      --dotBg: {{ section.settings.custom_dot_bg }};
      --dotBd: {{ section.settings.custom_dot_border }};
      --plus: {{ section.settings.custom_plus_color }};

      --ctaBg: {{ section.settings.custom_cta_bg }};
      --ctaText: {{ section.settings.custom_cta_text }};
      --ctaBd: {{ section.settings.custom_cta_border }};

      --modalTextBg: {{ section.settings.custom_modal_text_bg }};
      --modalBg: rgba(0,0,0,.35);

      --titleD: {{ section.settings.custom_heading_size_desktop }}px;
      --titleM: {{ section.settings.custom_heading_size_mobile }}px;
      --subD: {{ section.settings.custom_subheading_size_desktop }}px;
      --subM: {{ section.settings.custom_subheading_size_mobile }}px;
      --ctaD: {{ section.settings.custom_cta_size_desktop }}px;
      --ctaM: {{ section.settings.custom_cta_size_mobile }}px;

      --mTitleD: {{ section.settings.custom_modal_title_size_desktop }}px;
      --mTitleM: {{ section.settings.custom_modal_title_size_mobile }}px;
      --mBodyD: {{ section.settings.custom_modal_body_size_desktop }}px;
      --mBodyM: {{ section.settings.custom_modal_body_size_mobile }}px;

      position: relative;
    }

    #solarii-double-tabs-{{ section.id }} .sdtcsh__hero{
      position: relative;
      min-height: var(--hDesk);
      width: 100%;
      overflow: hidden;
      background: #f4f2ee;
      border-radius: 22px;
    }

    @media (max-width: 749px){
      #solarii-double-tabs-{{ section.id }} .sdtcsh__hero{
        min-height: var(--hMob);
        border-radius: 16px;
      }
    }

    #solarii-double-tabs-{{ section.id }} .sdtcsh__media,
    #solarii-double-tabs-{{ section.id }} .sdtcsh__img{
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
      object-fit: cover;
    }

    #solarii-double-tabs-{{ section.id }} .sdtcsh__heroVideo{
      width:100% !important;
      height:100% !important;
      object-fit: cover;
      display:block;
    }

    #solarii-double-tabs-{{ section.id }} .sdtcsh__heroVideo--mobile{ display:none; }

    @media (max-width: 749px){
      #solarii-double-tabs-{{ section.id }} .sdtcsh__heroVideo--desktop{ display:none; }
      #solarii-double-tabs-{{ section.id }} .sdtcsh__heroVideo--mobile{ display:block; }
    }

    #solarii-double-tabs-{{ section.id }} .sdtcsh__fallback{
      position:absolute;
      inset:0;
      background: radial-gradient(1200px 500px at 60% 40%, #efe9dd, #d9cfbf);
    }

    #solarii-double-tabs-{{ section.id }} .sdtcsh__overlay{
      position:absolute;
      inset:0;
      background:
