{% liquid
  assign block_count = section.blocks.size
  if block_count == 0
    assign block_count = 5
  endif
%}

<section id="shopify-section-{{ section.id }}" class="solarii-usp-bar-{{ section.id }}">
  <div class="solarii-usp-bar__container">
    <div class="solarii-usp-bar__shell">
      {%- capture usp_items -%}
        {%- for block in section.blocks -%}
          {%- capture item_inner -%}
            <span class="solarii-usp-bar__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'shipping' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="7" width="11" height="8" rx="2"></rect>
                    <path d="M14 10h3l2 2v3h-5"></path>
                    <circle cx="8" cy="17" r="1.5"></circle>
                    <circle cx="18" cy="17" r="1.5"></circle>
                  </svg>
                {%- when 'return' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12a9 9 0 1 1-2.64-6.36"></path>
                    <path d="M21 3v6h-6"></path>
                  </svg>
                {%- when 'warranty' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z"></path>
                    <path d="M9.5 12.2l1.5 1.5 3.5-3.6"></path>
                  </svg>
                {%- when 'custom' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3v18"></path>
                    <path d="M3 12h18"></path>
                    <path d="M5.6 5.6l12.8 12.8"></path>
                    <path d="M18.4 5.6L5.6 18.4"></path>
                  </svg>
                {%- when 'payment' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="6" width="18" height="12" rx="2"></rect>
                    <path d="M3 10h18"></path>
                    <path d="M7 14h4"></path>
                  </svg>
                {%- when 'gift' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="10" width="18" height="10" rx="2"></rect>
                    <path d="M12 10v10"></path>
                    <path d="M3 14h18"></path>
                    <path d="M12 10H7.8a2.3 2.3 0 1 1 0-4.6c2.2 0 4.2 4.6 4.2 4.6z"></path>
                    <path d="M12 10h4.2a2.3 2.3 0 1 0 0-4.6C14 5.4 12 10 12 10z"></path>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l2.2 5.1L20 10l-4 4 .9 6-4.9-3-4.9 3 .9-6-4-4 5.8-1.9L12 3z"></path>
                  </svg>
              {%- endcase -%}
            </span>

            <div class="solarii-usp-bar__copy">
              {%- if block.settings.title != blank -%}
                <p class="solarii-usp-bar__title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="solarii-usp-bar__text">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          {%- endcapture -%}

          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="solarii-usp-bar__item" {{ block.shopify_attributes }}>{{ item_inner }}</a>
          {%- else -%}
            <div class="solarii-usp-bar__item" {{ block.shopify_attributes }}>{{ item_inner }}</div>
          {%- endif -%}
        {%- else -%}
          {%- for i in (1..5) -%}
            <div class="solarii-usp-bar__item">
              <span class="solarii-usp-bar__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3l2.2 5.1L20 10l-4 4 .9 6-4.9-3-4.9 3 .9-6-4-4 5.8-1.9L12 3z"></path>
                </svg>
              </span>
              <div class="solarii-usp-bar__copy">
                <p class="solarii-usp-bar__title">Store Benefit</p>
                <div class="solarii-usp-bar__text">Add your content in the theme editor</div>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      {%- endcapture -%}

      <div class="solarii-usp-bar__track solarii-usp-bar__track--count-{{ block_count }}">
        {{ usp_items }}
        {%- comment -%} Duplicate for seamless mobile marquee {%- endcomment -%}
        <span class="solarii-usp-bar__marquee-clone" aria-hidden="true">{{ usp_items }}</span>
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --sb-max-width: {{ section.settings.max_width }}px;
    --sb-side-padding: {{ section.settings.side_padding }}px;
    --sb-inner-bg: {{ section.settings.inner_bg }};
    --sb-border: {{ section.settings.border_color }};
    --sb-title: {{ section.settings.title_color }};
    --sb-text: {{ section.settings.text_color }};
    --sb-icon: {{ section.settings.icon_color }};
    --sb-divider: rgba(160, 132, 108, 0.18);
  }

  /* ── Classic flat bar ── */
  .solarii-usp-bar-{{ section.id }} {
    position: relative;
    z-index: 3;
    background: var(--sb-inner-bg);
    border-top: 1px solid var(--sb-border);
    border-bottom: 1px solid var(--sb-border);
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__container {
    max-width: var(--sb-max-width);
    margin: 0 auto;
    padding-left: var(--sb-side-padding);
    padding-right: var(--sb-side-padding);
  }

  @media screen and (max-width: 989px) {
    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__container {
      max-width: none;
      padding-left: 0;
      padding-right: 0;
    }
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__shell {
    position: relative;
    overflow: hidden;
  }

  /* remove old shine animation */
  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__shell::before {
    display: none;
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__track {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex: 1 1 0%;
    padding: 22px 20px;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__item:hover {
    opacity: 0.7;
  }

  /* vertical divider between items */
  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__item:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 0;
    width: 1px;
    height: 36px;
    transform: translateY(-50%);
    background: var(--sb-divider);
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--sb-icon);
    flex-shrink: 0;
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__icon svg {
    width: 28px;
    height: 28px;
    display: block;
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__copy {
    min-width: 0;
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__title {
    margin: 0 0 2px;
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.25;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--sb-title);
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__text {
    margin: 0;
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.4;
    color: var(--sb-text);
  }

  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__text p {
    margin: 0;
  }

  /* hide marquee clone on desktop */
  .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__marquee-clone {
    display: none;
  }

  /* ── Mobile: horizontal marquee scroll ── */
  @media screen and (max-width: 989px) {
    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__shell {
      overflow: hidden;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__track {
      display: flex;
      width: max-content;
      animation: uspMarquee-{{ section.id }} {{ block_count | times: 4 }}s linear infinite;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__track:hover {
      animation-play-state: paused;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__item {
      flex: 0 0 auto;
      padding: 12px 24px;
      gap: 10px;
      white-space: nowrap;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__item::after {
      display: none !important;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__marquee-clone {
      display: contents;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__icon svg {
      width: 20px;
      height: 20px;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__title {
      font-size: {{ section.settings.title_size_mobile }}px;
      margin: 0;
    }

    .solarii-usp-bar-{{ section.id }} .solarii-usp-bar__text {
      font-size: {{ section.settings.text_size_mobile }}px;
    }
  }

  @keyframes uspMarquee-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

{% schema %}
{
  "name": "Solarii USP Bar",
  "tag": "section",
  "class": "section section-solarii-usp-bar",
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "label": "最大宽度",
      "min": 900,
      "max": 1600,
      "step": 20,
      "default": 1280
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "左右边距",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "lift_desktop",
      "label": "桌面端轻微上提",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "lift_mobile",
      "label": "手机端轻微上提",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "底部留白",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "外层圆角",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "item_radius",
      "label": "项目圆角（预留）",
      "min": 8,
      "max": 28,
      "step": 2,
      "default": 16
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "外层背景色 1",
      "default": "#f8f2eb"
    },
    {
      "type": "color",
      "id": "card_bg_2",
      "label": "外层背景色 2",
      "default": "#f3ece4"
    },
    {
      "type": "color",
      "id": "inner_bg",
      "label": "内层背景色",
      "default": "#fbf7f2"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "边框颜色",
      "default": "#e2d4c5"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "标题颜色",
      "default": "#4d362c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "副文案颜色",
      "default": "#8a7567"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "图标颜色",
      "default": "#9a7458"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "图标背景色",
      "default": "#f5efe8"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "桌面端标题字号",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "桌面端副文案字号",
      "min": 11,
      "max": 18,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "手机端标题字号",
      "min": 11,
      "max": 20,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "手机端副文案字号",
      "min": 10,
      "max": 16,
      "step": 1,
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "卖点项",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "图标",
          "default": "shipping",
          "options": [
            { "value": "shipping", "label": "运输" },
            { "value": "return", "label": "退换" },
            { "value": "warranty", "label": "质保" },
            { "value": "custom", "label": "定制" },
            { "value": "payment", "label": "支付" },
            { "value": "gift", "label": "礼物" },
            { "value": "star", "label": "星形" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "标题",
          "default": "Free Shipping"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "副文案",
          "default": "<p>Smooth delivery on every order</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "链接（可选）"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Solarii USP Bar",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "text": "<p>Smooth delivery on every order</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "return",
            "title": "Easy Returns",
            "text": "<p>Simple, stress free aftercare</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "warranty",
            "title": "Lifetime Warranty",
            "text": "<p>Crafted to last, backed with care</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "custom",
            "title": "Custom Design",
            "text": "<p>Personalize your perfect piece</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "payment",
            "title": "Secure Payment",
            "text": "<p>Safe checkout with confidence</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}