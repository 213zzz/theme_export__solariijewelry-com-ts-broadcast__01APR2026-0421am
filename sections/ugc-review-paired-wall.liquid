{% liquid
  assign sid = section.id
%}

{%- capture row_1_markup -%}
  {%- assign row_1_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.row == '1' -%}

      {%- if block.type == 'media' -%}
        {%- comment -%} ── Media-only card (Instagram style) ── {%- endcomment -%}
        <div class="ugc-review-wall__media-item"
          data-ugc-lightbox
          data-ugc-link="{{ block.settings.link }}"
          {%- if block.settings.video != blank -%}
            data-ugc-media="video"
          {%- elsif block.settings.image != blank -%}
            data-ugc-media="image"
            data-ugc-src="{{ block.settings.image | image_url: width: 1200 }}"
          {%- endif -%}
          {%- if block.settings.product != blank -%}
            data-ugc-product-title="{{ block.settings.product.title | escape }}"
            data-ugc-product-price="{{ block.settings.product.price | money }}"
            data-ugc-product-url="{{ block.settings.product.url }}"
            {%- if block.settings.product.featured_image != blank -%}
              data-ugc-product-img="{{ block.settings.product.featured_image | image_url: width: 200 }}"
            {%- endif -%}
          {%- endif -%}
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.video != blank -%}
            <template class="ugc-review-wall__media-tpl">
              {{ block.settings.video | video_tag: autoplay: false, loop: true, muted: false, controls: true, playsinline: true, image_size: '1200x' }}
            </template>
          {%- endif -%}
          <div class="ugc-review-wall__media-visual">
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x' }}
            {%- elsif block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 900 }}"
                alt="{{ block.settings.alt | default: '' | escape }}"
                loading="lazy"
                width="450" height="560"
              >
            {%- else -%}
              <div class="ugc-review-wall__media-placeholder">
                {{ 'image' | placeholder_svg_tag: 'ugc-review-wall__ugc-placeholder-svg' }}
              </div>
            {%- endif -%}

            {%- if block.settings.link != blank -%}
              <div class="ugc-review-wall__media-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
              </div>
            {%- endif -%}
          </div>

          {%- if block.settings.product != blank -%}
            <div class="ugc-review-wall__media-product">
              {%- if block.settings.product.featured_image != blank -%}
                <img
                  class="ugc-review-wall__media-product-img"
                  src="{{ block.settings.product.featured_image | image_url: width: 120 }}"
                  alt="{{ block.settings.product.title | escape }}"
                  loading="lazy"
                  width="48" height="48"
                >
              {%- endif -%}
              <div class="ugc-review-wall__media-product-info">
                <strong>{{ block.settings.product.title | escape }}</strong>
                <span>{{ block.settings.product.price | money }}</span>
              </div>
              <span class="ugc-review-wall__media-product-cta">View details</span>
            </div>
          {%- endif -%}
        </div>

      {%- else -%}
        {%- comment -%} ── Story + review card (original) ── {%- endcomment -%}
        {%- assign row_1_count = row_1_count | plus: 1 -%}
        <article class="ugc-review-wall__story" {{ block.shopify_attributes }}>
          <div class="ugc-review-wall__story-head">
            <div class="ugc-review-wall__story-no">
              {%- if row_1_count < 10 -%}0{{ row_1_count }}{%- else -%}{{ row_1_count }}{%- endif -%}
            </div>
            <span>{{ block.settings.story_label | escape }}</span>
            <div class="ugc-review-wall__story-line"></div>
          </div>

          <div class="ugc-review-wall__story-body">
            <div class="ugc-review-wall__review-card">
              {%- if block.settings.review_label != blank -%}
                <div class="ugc-review-wall__review-label">{{ block.settings.review_label | escape }}</div>
              {%- endif -%}

              <div class="ugc-review-wall__author">
                {%- if block.settings.avatar != blank -%}
                  <img
                    class="ugc-review-wall__avatar"
                    src="{{ block.settings.avatar | image_url: width: 120 }}"
                    alt="{{ block.settings.author | escape }}"
                    loading="lazy"
                    width="46"
                    height="46"
                  >
                {%- endif -%}

                <div>
                  <strong>{{ block.settings.author | escape }}</strong>
                  {%- if block.settings.author_meta != blank -%}
                    <span>{{ block.settings.author_meta | escape }}</span>
                  {%- endif -%}
                </div>
              </div>

              {%- if block.settings.rating > 0 -%}
                <div class="ugc-review-wall__stars" aria-label="{{ block.settings.rating }} stars">
                  {%- for i in (1..5) -%}
                    {%- if i <= block.settings.rating -%}
                      <span>★</span>
                    {%- else -%}
                      <span class="ugc-review-wall__star--empty">★</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- if block.settings.review_text != blank -%}
                <p class="ugc-review-wall__review-text">{{ block.settings.review_text | escape }}</p>
              {%- endif -%}

              <div class="ugc-review-wall__review-meta">
                {%- if block.settings.review_tag != blank -%}
                  <span class="ugc-review-wall__review-tag">{{ block.settings.review_tag | escape }}</span>
                {%- endif -%}

                {%- if block.settings.link != blank -%}
                  <a class="ugc-review-wall__arrow" href="{{ block.settings.link }}" aria-label="Open story">
                    <span>→</span>
                  </a>
                {%- else -%}
                  <span class="ugc-review-wall__arrow" aria-hidden="true">
                    <span>→</span>
                  </span>
                {%- endif -%}
              </div>
            </div>

            <div class="ugc-review-wall__ugc-card">
              {%- if block.settings.link != blank -%}
                <a class="ugc-review-wall__ugc-link" href="{{ block.settings.link }}" aria-label="Open UGC">
              {%- endif -%}

              {%- if block.settings.ugc_video != blank -%}
                {{ block.settings.ugc_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x' }}
              {%- elsif block.settings.ugc_image != blank -%}
                <img
                  src="{{ block.settings.ugc_image | image_url: width: 900 }}"
                  alt="{{ block.settings.author | escape }}"
                  loading="lazy"
                  width="472"
                  height="584"
                >
              {%- else -%}
                <div class="ugc-review-wall__ugc-placeholder">
                  {{ 'image' | placeholder_svg_tag: 'ugc-review-wall__ugc-placeholder-svg' }}
                </div>
              {%- endif -%}

              {%- if block.settings.ugc_label != blank -%}
                <div class="ugc-review-wall__ugc-label">{{ block.settings.ugc_label | escape }}</div>
              {%- endif -%}

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endif -%}

    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

