  class="ugc-review-wall-section"
  data-pause-on-hover="{{ section.settings.pause_on_hover }}"
>
  <div class="ugc-review-wall">
    {%- for block in section.blocks -%}
      {%- if block.type == 'heading' -%}
        <div class="ugc-review-wall__header" {{ block.shopify_attributes }}
          style="
