{%- capture row_1_focus_markup -%}
  {%- assign row_1_story_focus_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'story' and block.settings.row == '1' -%}
      {%- assign row_1_story_focus_count = row_1_story_focus_count | plus: 1 -%}
      <div class="ugc-review-wall__focus-slide" data-ugc-focus-slide>
        {%- if block.settings.link != blank -%}
          <a
            class="ugc-review-wall__focus-media"
            href="{{ block.settings.link }}"
            aria-label="Open UGC from {{ block.settings.author | escape }}"
          >
        {%- else -%}
          <div class="ugc-review-wall__focus-media">
        {%- endif -%}
            {%- if block.settings.ugc_video != blank -%}
              {{ block.settings.ugc_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x' }}
            {%- elsif block.settings.ugc_image != blank -%}
              <img
                src="{{ block.settings.ugc_image | image_url: width: 900 }}"
                alt="{{ block.settings.author | escape }}"
                loading="lazy"
                width="472"
                height="584"
              >
            {%- else -%}
              <div class="ugc-review-wall__ugc-placeholder">
                {{ 'image' | placeholder_svg_tag: 'ugc-review-wall__ugc-placeholder-svg' }}
              </div>
            {%- endif -%}

            <div class="ugc-review-wall__focus-badge">
              <span class="ugc-review-wall__focus-no">
                {%- if row_1_story_focus_count < 10 -%}0{{ row_1_story_focus_count }}{%- else -%}{{ row_1_story_focus_count }}{%- endif -%}
              </span>
              {%- if block.settings.story_label != blank -%}
                <span class="ugc-review-wall__focus-label">{{ block.settings.story_label | escape }}</span>
              {%- endif -%}
            </div>
        {%- if block.settings.link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}

        <template class="ugc-review-wall__focus-review-template">
          <div class="ugc-review-wall__focus-review-inner">
            {%- if block.settings.review_label != blank -%}
              <div class="ugc-review-wall__focus-review-label">{{ block.settings.review_label | escape }}</div>
            {%- endif -%}

            {%- if block.settings.rating > 0 -%}
              <div class="ugc-review-wall__focus-stars" aria-label="{{ block.settings.rating }} stars">
                {%- for i in (1..5) -%}
                  {%- if i <= block.settings.rating -%}
                    <span>★</span>
                  {%- else -%}
                    <span class="ugc-review-wall__star--empty">★</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if block.settings.review_text != blank -%}
              <p class="ugc-review-wall__focus-text">{{ block.settings.review_text | escape }}</p>
            {%- endif -%}

            <div class="ugc-review-wall__focus-author-row">
              {%- if block.settings.avatar != blank -%}
                <img
                  class="ugc-review-wall__focus-avatar"
                  src="{{ block.settings.avatar | image_url: width: 120 }}"
                  alt="{{ block.settings.author | escape }}"
                  loading="lazy"
                  width="40"
                  height="40"
                >
              {%- else -%}
                <span class="ugc-review-wall__focus-avatar ugc-review-wall__focus-avatar--placeholder">
                  {{ block.settings.author | default: 'A' | slice: 0, 1 | escape }}
                </span>
              {%- endif -%}

              <div class="ugc-review-wall__focus-author-text">
                <strong>{{ block.settings.author | escape }}</strong>
                {%- if block.settings.author_meta != blank -%}
