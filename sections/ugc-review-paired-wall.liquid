            <div class="ugc-review-wall__set">{{ row_1_markup }}</div>
            <div class="ugc-review-wall__set" aria-hidden="true">{{ row_1_markup }}</div>
          </div>
        </div>
      {%- endif -%}

      {%- if row_2_markup != blank -%}
