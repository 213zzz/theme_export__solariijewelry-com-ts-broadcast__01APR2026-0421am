<script>
(function() {
  var SEC = document.getElementById("ugc-review-wall-{{ sid }}");
  if (!SEC) return;
  var LB  = document.getElementById("ugc-lightbox-{{ sid }}");
  if (!LB) return;

  var mediaEl   = LB.querySelector(".ugc-review-wall__lightbox-media");
  var productEl = LB.querySelector(".ugc-review-wall__lightbox-product");
  var insBtn    = LB.querySelector(".ugc-review-wall__lightbox-ins");
  var closeBtn  = LB.querySelector(".ugc-review-wall__lightbox-close");
  var backdrop  = LB.querySelector(".ugc-review-wall__lightbox-backdrop");

  /* Extract Instagram embed URL from a link */
  function getInsEmbedUrl(url) {
    if (!url) return null;
    var m = url.match(/instagram\.com\/(p|reel|tv)\/([A-Za-z0-9_-]+)/);
    if (m) return "https://www.instagram.com/" + m[1] + "/" + m[2] + "/embed/";
    return null;
  }

  function openLB(card) {
    var type = card.getAttribute("data-ugc-media");
    var src  = card.getAttribute("data-ugc-src");
    var link = card.getAttribute("data-ugc-link");
    var insEmbed = getInsEmbedUrl(link);

    /* Reset media area */
    mediaEl.innerHTML = "";
    mediaEl.style.aspectRatio = "";

    if (type === "video") {
      /* Clone the <template> inside the card which holds the full <video> tag */
      var tpl = card.querySelector(".ugc-review-wall__media-tpl");
      if (tpl && tpl.content) {
        var clone = tpl.content.cloneNode(true);
        mediaEl.appendChild(clone);
        var v = mediaEl.querySelector("video");
        if (v) { v.muted = false; v.controls = true; try { v.play(); } catch(e) {} }
      }
    } else if (type === "image" && src) {
      var img = document.createElement("img");
      img.src = src;
      img.alt = "";
      mediaEl.appendChild(img);
    } else if (insEmbed) {
      /* No uploaded media — use Instagram embed iframe */
      mediaEl.style.aspectRatio = "auto";
      var iframe = document.createElement("iframe");
      iframe.src = insEmbed;
      iframe.width = "100%";
      iframe.style.cssText = "border:none;min-height:520px;display:block;";
      iframe.setAttribute("allowfullscreen", "");
      iframe.setAttribute("allow", "autoplay; encrypted-media");
      iframe.loading = "lazy";
      mediaEl.appendChild(iframe);
    }

    /* Product tag */
    var pTitle = card.getAttribute("data-ugc-product-title");
    var pPrice = card.getAttribute("data-ugc-product-price");
    var pImg   = card.getAttribute("data-ugc-product-img");
    var pUrl   = card.getAttribute("data-ugc-product-url");

    if (pTitle) {
      var html = "";
      if (pImg) html += '<img src="' + pImg + '" alt="" width="40" height="40">';
      html += '<div class="ugc-review-wall__lightbox-product-text">';
      if (pUrl) html += '<a href="' + pUrl + '" style="text-decoration:none;color:inherit">';
      html += '<strong>' + pTitle + '</strong>';
      html += '<span>' + (pPrice || '') + '</span>';
      if (pUrl) html += '</a>';
      html += '</div>';
      productEl.innerHTML = html;
      productEl.classList.add("is-visible");
    } else {
      productEl.innerHTML = "";
      productEl.classList.remove("is-visible");
    }

    /* Instagram button */
    if (link) {
      insBtn.href = link;
      insBtn.classList.add("is-visible");
    } else {
      insBtn.classList.remove("is-visible");
    }

    LB.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeLB() {
    LB.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    /* Pause video / remove iframe */
    var v = mediaEl.querySelector("video");
    if (v) { try { v.pause(); } catch(e) {} }
    setTimeout(function() {
      mediaEl.innerHTML = "";
      mediaEl.style.aspectRatio = "";
    }, 300);
  }

  /* Delegate click on media cards – only on the card itself, not on lightbox */
  SEC.addEventListener("click", function(e) {
    var card = e.target.closest("[data-ugc-lightbox]");
    if (!card || !SEC.contains(card)) return;
    e.preventDefault();
    openLB(card);
  });

  /* Lightbox close – separate listeners so ins button click is NOT blocked */
  closeBtn.addEventListener("click", function(e) {
    e.stopPropagation();
    closeLB();
  });
  backdrop.addEventListener("click", function(e) {
    e.stopPropagation();
    closeLB();
  });

  /* Let clicks inside dialog pass through normally (for ins button, product links) */
  LB.querySelector(".ugc-review-wall__lightbox-dialog").addEventListener("click", function(e) {
    /* Only stop propagation to backdrop, don't prevent default so links work */
    e.stopPropagation();
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && LB.getAttribute("aria-hidden") === "false") closeLB();
  });

  function initFocusCarousel(root) {
    var stage = root.querySelector("[data-ugc-focus-stage]");
    var review = root.querySelector("[data-ugc-focus-review]");
    var slides = Array.prototype.slice.call(root.querySelectorAll("[data-ugc-focus-slide]"));
    if (!stage || !review || !slides.length) return;

    var activeIndex = 0;
    var scrollTimer = null;
    var autoplayTimer = null;
    var rawDelay = parseInt(root.getAttribute("data-ugc-autoplay"), 10);
    var autoplayDelay = isNaN(rawDelay) ? 4200 : Math.min(Math.max(rawDelay, 3200), 6200);

    function renderReview(index) {
      var slide = slides[index];
      if (!slide) return;
      var tpl = slide.querySelector(".ugc-review-wall__focus-review-template");
      review.innerHTML = tpl ? tpl.innerHTML : "";
    }

    function scrollToIndex(index, behavior) {
      var slide = slides[index];
      if (!slide) return;

      var targetLeft = slide.offsetLeft - ((stage.clientWidth - slide.offsetWidth) / 2);
      if (targetLeft < 0) targetLeft = 0;

      if (behavior === "auto" || typeof stage.scrollTo !== "function") {
        stage.scrollLeft = targetLeft;
      } else {
        stage.scrollTo({ left: targetLeft, behavior: behavior });
      }
    }

    function setActive(index, shouldScroll, behavior) {
      if (!slides.length) return;

      if (index < 0) index = slides.length - 1;
      if (index >= slides.length) index = 0;
      activeIndex = index;

      slides.forEach(function(slide, slideIndex) {
        slide.classList.toggle("is-active", slideIndex === activeIndex);
      });

      renderReview(activeIndex);

      if (shouldScroll) {
        scrollToIndex(activeIndex, behavior || "smooth");
      }
    }

    function detectActiveFromScroll() {
      var stageCenter = stage.scrollLeft + (stage.clientWidth / 2);
      var nextIndex = activeIndex;
      var minDistance = Infinity;

      slides.forEach(function(slide, slideIndex) {
        var slideCenter = slide.offsetLeft + (slide.offsetWidth / 2);
        var distance = Math.abs(slideCenter - stageCenter);
        if (distance < minDistance) {
          minDistance = distance;
          nextIndex = slideIndex;
        }
      });

      if (nextIndex !== activeIndex) {
        setActive(nextIndex, false);
      }
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        window.clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    function startAutoplay() {
      stopAutoplay();
      if (!mobileQuery.matches || slides.length < 2) return;

      autoplayTimer = window.setInterval(function() {
        setActive(activeIndex + 1, true, "smooth");
      }, autoplayDelay);
    }

    function syncAfterScroll() {
      if (scrollTimer) window.clearTimeout(scrollTimer);
      scrollTimer = window.setTimeout(function() {
        detectActiveFromScroll();
        startAutoplay();
      }, 110);
    }

    stage.addEventListener("scroll", syncAfterScroll, { passive: true });
    stage.addEventListener("touchstart", stopAutoplay, { passive: true });
    stage.addEventListener("pointerdown", stopAutoplay);
    stage.addEventListener("mouseenter", stopAutoplay);
    stage.addEventListener("mouseleave", startAutoplay);

    window.addEventListener("resize", function() {
      if (!mobileQuery.matches) {
        stopAutoplay();
        return;
      }

      window.requestAnimationFrame(function() {
        scrollToIndex(activeIndex, "auto");
      });
    });

    function handleBreakpointChange() {
      if (!mobileQuery.matches) {
        stopAutoplay();
        return;
      }

      window.requestAnimationFrame(function() {
        scrollToIndex(activeIndex, "auto");
        startAutoplay();
      });
    }

    if (mobileQuery.addEventListener) {
      mobileQuery.addEventListener("change", handleBreakpointChange);
    } else if (mobileQuery.addListener) {
      mobileQuery.addListener(handleBreakpointChange);
    }

    setActive(0, false);
    window.requestAnimationFrame(function() {
      scrollToIndex(0, "auto");
      startAutoplay();
    });
  }

  var mobileQuery = window.matchMedia ? window.matchMedia("(max-width: 768px)") : { matches: window.innerWidth <= 768 };
  Array.prototype.forEach.call(SEC.querySelectorAll("[data-ugc-focus]"), initFocusCarousel);
})();
</script>

