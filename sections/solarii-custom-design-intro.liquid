{% liquid
  assign design_blocks = section.blocks | where: 'type', 'design_series'
  assign custom_sizes = section.settings.custom_sizes | split: ','
  assign custom_plating = section.settings.custom_plating | split: ','
  assign custom_gem_types = section.settings.custom_gem_types | split: ','
  assign custom_gem_materials = section.settings.custom_gem_materials | split: ','
  assign custom_carats = section.settings.custom_carats | split: ','
  assign custom_metals = section.settings.custom_metals | split: ','
%}

<section
  id="solarii-double-tabs-{{ section.id }}"
  class="solarii-double-tabs"
  data-make-webhook="{{ section.settings.make_webhook_url | escape }}"
>
  <div class="sdt__inner page-width">
    <div class="sdt__outer-tabs" role="tablist" aria-label="外层标签">
      <button class="sdt__outer-tab is-active" type="button" data-outer-tab="design">
        {{ section.settings.outer_label_1 }}
      </button>
      <button class="sdt__outer-tab" type="button" data-outer-tab="custom">
        {{ section.settings.outer_label_2 }}
      </button>
      <button class="sdt__outer-tab" type="button" data-outer-tab="filter">
        {{ section.settings.outer_label_3 }}
      </button>
    </div>

    <div class="sdt__shell">
      <div class="sdt__panel is-active" data-panel="design">
        <div class="sdt__panel-head">
          {% if section.settings.design_eyebrow != blank %}
            <div class="sdt__eyebrow">{{ section.settings.design_eyebrow }}</div>
          {% endif %}
          {% if section.settings.design_title != blank %}
            <h2 class="sdt__title">{{ section.settings.design_title }}</h2>
          {% endif %}
          {% if section.settings.design_desc != blank %}
            <div class="sdt__desc">{{ section.settings.design_desc }}</div>
          {% endif %}
        </div>

        {% if design_blocks.size > 0 %}
          <div class="sdt__inner-tabs" role="tablist" aria-label="系列标签">
            {% for block in design_blocks %}
              <button
                class="sdt__inner-tab {% if forloop.first %}is-active{% endif %}"
                type="button"
                data-inner-tab="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.tab_label }}
              </button>
            {% endfor %}
          </div>

          <div class="sdt__inner-panels">
            {% for block in design_blocks %}
              <div class="sdt__inner-panel {% if forloop.first %}is-active{% endif %}" data-inner-panel="{{ block.id }}">
                <div class="sdt__media-card">
                  {% if block.settings.media_type == 'video' and block.settings.video != blank %}
                    {{
                      block.settings.video
                      | video_tag:
                        controls: true,
                        autoplay: false,
                        loop: false,
                        muted: true,
                        playsinline: true,
                        class: 'sdt__media-video'
                    }}
                  {% elsif block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1800
                      | image_tag:
                        loading: 'lazy',
                        class: 'sdt__media-image',
                        widths: '600, 900, 1200, 1500, 1800'
                    }}
                  {% else %}
                    <div class="sdt__media-placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {% endif %}
                </div>

                <div class="sdt__copy-card">
                  {% if block.settings.kicker != blank %}
                    <div class="sdt__copy-kicker">{{ block.settings.kicker }}</div>
                  {% endif %}

                  {% if block.settings.title != blank %}
                    <h3 class="sdt__copy-title">{{ block.settings.title }}</h3>
                  {% endif %}

                  {% if block.settings.desc != blank %}
                    <div class="sdt__copy-body">{{ block.settings.desc }}</div>
                  {% endif %}

                  <div class="sdt__meta-grid">
                    {% if block.settings.sub_1_title != blank or block.settings.sub_1_text != blank %}
                      <div class="sdt__meta-item">
                        {% if block.settings.sub_1_title != blank %}
                          <div class="sdt__meta-label">{{ block.settings.sub_1_title }}</div>
                        {% endif %}
                        {% if block.settings.sub_1_text != blank %}
                          <div class="sdt__meta-value">{{ block.settings.sub_1_text }}</div>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% if block.settings.sub_2_title != blank or block.settings.sub_2_text != blank %}
                      <div class="sdt__meta-item">
                        {% if block.settings.sub_2_title != blank %}
                          <div class="sdt__meta-label">{{ block.settings.sub_2_title }}</div>
                        {% endif %}
                        {% if block.settings.sub_2_text != blank %}
                          <div class="sdt__meta-value">{{ block.settings.sub_2_text }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>

                  {% if block.settings.button_text != blank %}
                    <div class="sdt__actions">
                      <a
                        class="sdt__btn sdt__btn--primary"
                        {% if block.settings.button_link != blank %}
                          href="{{ block.settings.button_link }}"
                        {% else %}
                          role="link" aria-disabled="true"
                        {% endif %}
                      >
                        {{ block.settings.button_text }}
                      </a>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="sdt__empty">请在主题编辑器中添加系列区块</div>
        {% endif %}
      </div>

      <div class="sdt__panel" data-panel="custom">
        <div class="sdt__panel-head">
          {% if section.settings.custom_eyebrow != blank %}
            <div class="sdt__eyebrow">{{ section.settings.custom_eyebrow }}</div>
          {% endif %}
          {% if section.settings.custom_title != blank %}
            <h2 class="sdt__title">{{ section.settings.custom_title }}</h2>
          {% endif %}
          {% if section.settings.custom_desc != blank %}
            <div class="sdt__desc">{{ section.settings.custom_desc }}</div>
          {% endif %}
        </div>

        <div class="sdt__custom-layout">
          <div class="sdt__upload-card">
            <div class="sdt__upload-dropzone" data-upload-dropzone>
              <input class="sdt__upload-input" type="file" accept="image/*" multiple data-upload-input>

              <div class="sdt__upload-placeholder" data-upload-placeholder>
                <div class="sdt__upload-icon">↑</div>
                <h3 class="sdt__upload-title">{{ section.settings.upload_title }}</h3>
                <div class="sdt__upload-text">{{ section.settings.upload_text }}</div>

                <button class="sdt__btn sdt__btn--primary" type="button" data-upload-trigger>
                  {{ section.settings.upload_button_text }}
                </button>

                <div class="sdt__upload-pills">
                  {% if section.settings.upload_pill_1 != blank %}<span>{{ section.settings.upload_pill_1 }}</span>{% endif %}
                  {% if section.settings.upload_pill_2 != blank %}<span>{{ section.settings.upload_pill_2 }}</span>{% endif %}
                  {% if section.settings.upload_pill_3 != blank %}<span>{{ section.settings.upload_pill_3 }}</span>{% endif %}
                </div>
              </div>

              <div class="sdt__upload-preview" data-upload-preview hidden>
                <div class="sdt__upload-preview-grid" data-upload-preview-grid></div>
              </div>
            </div>

            <div class="sdt__upload-actions">
              <button class="sdt__btn sdt__btn--primary" type="button" data-upload-trigger>
                {{ section.settings.upload_secondary_button_text }}
              </button>
              <button class="sdt__btn sdt__btn--ghost" type="button" data-upload-clear>
                {{ section.settings.upload_remove_text }}
              </button>
            </div>

            <div class="sdt__file-row">
              <span data-file-name>{{ section.settings.upload_empty_file_text }}</span>
              <span data-file-state>{{ section.settings.upload_waiting_text }}</span>
            </div>
          </div>

          <div class="sdt__config-card">
            <div class="sdt__config-top">
              {% if section.settings.custom_builder_kicker != blank %}
                <div class="sdt__copy-kicker">{{ section.settings.custom_builder_kicker }}</div>
              {% endif %}
              {% if section.settings.custom_builder_title != blank %}
                <h3 class="sdt__copy-title">{{ section.settings.custom_builder_title }}</h3>
              {% endif %}
              {% if section.settings.custom_builder_desc != blank %}
                <div class="sdt__copy-body">{{ section.settings.custom_builder_desc }}</div>
              {% endif %}
            </div>

            <div class="sdt__form-grid">
              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_name }}</div>
                <input class="sdt__input" type="text" data-custom-field="name" placeholder="{{ section.settings.placeholder_name }}">
              </div>

              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_phone }}</div>
                <input class="sdt__input" type="text" data-custom-field="phone" placeholder="{{ section.settings.placeholder_phone }}">
              </div>

              <div class="sdt__field sdt__field--span-2">
                <div class="sdt__field-label">{{ section.settings.label_email }}</div>
                <input class="sdt__input" type="email" data-custom-field="email" placeholder="{{ section.settings.placeholder_email }}">
              </div>

              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_gem_type }}</div>
                <div class="sdt__select-wrap">
                  <select class="sdt__select" data-summary-source="gem_type">
                    {% for item in custom_gem_types %}
                      {% assign value = item | strip %}
                      {% if value != blank %}
                        <option value="{{ value | escape }}" {% if value == section.settings.default_gem_type %}selected{% endif %}>{{ value }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_gem_material }}</div>
                <div class="sdt__select-wrap">
                  <select class="sdt__select" data-summary-source="gem_material">
                    {% for item in custom_gem_materials %}
                      {% assign value = item | strip %}
                      {% if value != blank %}
                        <option value="{{ value | escape }}" {% if value == section.settings.default_gem_material %}selected{% endif %}>{{ value }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_carat }}</div>
                <div class="sdt__select-wrap">
                  <select class="sdt__select" data-summary-source="carat">
                    {% for item in custom_carats %}
                      {% assign value = item | strip %}
                      {% if value != blank %}
                        <option value="{{ value | escape }}" {% if value == section.settings.default_carat %}selected{% endif %}>{{ value }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_size }}</div>
                <div class="sdt__select-wrap">
                  <select class="sdt__select" data-summary-source="size">
                    {% for item in custom_sizes %}
                      {% assign value = item | strip %}
                      {% if value != blank %}
                        <option value="{{ value | escape }}" {% if value == section.settings.default_size %}selected{% endif %}>{{ value }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_metal }}</div>
                <div class="sdt__select-wrap">
                  <select class="sdt__select" data-summary-source="metal">
                    {% for item in custom_metals %}
                      {% assign value = item | strip %}
                      {% if value != blank %}
                        <option value="{{ value | escape }}" {% if value == section.settings.default_metal %}selected{% endif %}>{{ value }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="sdt__field">
                <div class="sdt__field-label">{{ section.settings.label_plating }}</div>
                <div class="sdt__select-wrap">
                  <select class="sdt__select" data-summary-source="plating">
                    {% for item in custom_plating %}
                      {% assign value = item | strip %}
                      {% if value != blank %}
                        <option value="{{ value | escape }}" {% if value == section.settings.default_plating %}selected{% endif %}>{{ value }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="sdt__field sdt__field--span-2">
                <div class="sdt__field-label">{{ section.settings.label_budget }}</div>
                <input class="sdt__input" type="text" data-custom-field="budget" placeholder="{{ section.settings.placeholder_budget }}">
              </div>

              <div class="sdt__field sdt__field--span-2">
                <div class="sdt__field-label">{{ section.settings.label_note }}</div>
                <textarea class="sdt__textarea" data-custom-field="note" placeholder="{{ section.settings.placeholder_note }}"></textarea>
              </div>
            </div>

            <div class="sdt__summary-card">
              <h4 class="sdt__summary-title">{{ section.settings.summary_title }}</h4>

              <div class="sdt__summary-grid">
                <div class="sdt__summary-item">
                  <div class="sdt__summary-label">{{ section.settings.label_gem_type }}</div>
                  <div class="sdt__summary-value" data-summary-target="gem_type">{{ section.settings.default_gem_type }}</div>
                </div>
                <div class="sdt__summary-item">
                  <div class="sdt__summary-label">{{ section.settings.label_gem_material }}</div>
                  <div class="sdt__summary-value" data-summary-target="gem_material">{{ section.settings.default_gem_material }}</div>
                </div>
                <div class="sdt__summary-item">
                  <div class="sdt__summary-label">{{ section.settings.label_size }}</div>
                  <div class="sdt__summary-value" data-summary-target="size">{{ section.settings.default_size }}</div>
                </div>
                <div class="sdt__summary-item">
                  <div class="sdt__summary-label">{{ section.settings.label_metal }}</div>
                  <div class="sdt__summary-value" data-summary-target="metal">{{ section.settings.default_metal }}</div>
                </div>
              </div>

              <div class="sdt__summary-footer" data-summary-file-text>
                {{ section.settings.summary_no_file_text }}
              </div>

              <div class="sdt__actions">
                <button class="sdt__btn sdt__btn--primary" type="button" data-submit-custom-request>
                  {{ section.settings.custom_primary_text }}
                </button>

                {% if section.settings.custom_secondary_text != blank %}
                  <a
                    class="sdt__btn sdt__btn--soft"
                    {% if section.settings.custom_secondary_link != blank %}
                      href="{{ section.settings.custom_secondary_link }}"
                    {% else %}
                      role="link" aria-disabled="true"
                    {% endif %}
                  >
                    {{ section.settings.custom_secondary_text }}
                  </a>
                {% endif %}
              </div>

              <div class="sdt__submit-note" data-submit-note></div>
            </div>
          </div>
        </div>
      </div>

      <div class="sdt__panel" data-panel="filter">
        <div class="sdt__panel-head">
          {% if section.settings.filter_eyebrow != blank %}
            <div class="sdt__eyebrow">{{ section.settings.filter_eyebrow }}</div>
          {% endif %}
          {% if section.settings.filter_title != blank %}
            <h2 class="sdt__title">{{ section.settings.filter_title }}</h2>
          {% endif %}
          {% if section.settings.filter_desc != blank %}
            <div class="sdt__desc">{{ section.settings.filter_desc }}</div>
          {% endif %}
        </div>

        <div class="sdt__single-layout">
          <div class="sdt__media-card">
            {% if section.settings.filter_media_type == 'video' and section.settings.filter_video != blank %}
              {{
                section.settings.filter_video
                | video_tag:
                  controls: true,
                  autoplay: false,
                  loop: false,
                  muted: true,
                  playsinline: true,
                  class: 'sdt__media-video'
              }}
            {% elsif section.settings.filter_image != blank %}
              {{
                section.settings.filter_image
                | image_url: width: 1800
                | image_tag:
                  loading: 'lazy',
                  class: 'sdt__media-image',
                  widths: '600, 900, 1200, 1500, 1800'
              }}
            {% else %}
              <div class="sdt__media-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
          </div>

          <div class="sdt__copy-card">
            {% if section.settings.filter_kicker != blank %}
              <div class="sdt__copy-kicker">{{ section.settings.filter_kicker }}</div>
            {% endif %}

            {% if section.settings.filter_card_title != blank %}
              <h3 class="sdt__copy-title">{{ section.settings.filter_card_title }}</h3>
            {% endif %}

            {% if section.settings.filter_card_desc != blank %}
              <div class="sdt__copy-body">{{ section.settings.filter_card_desc }}</div>
            {% endif %}

            <div class="sdt__meta-grid">
              {% if section.settings.filter_sub_1_title != blank or section.settings.filter_sub_1_text != blank %}
                <div class="sdt__meta-item">
                  {% if section.settings.filter_sub_1_title != blank %}
                    <div class="sdt__meta-label">{{ section.settings.filter_sub_1_title }}</div>
                  {% endif %}
                  {% if section.settings.filter_sub_1_text != blank %}
                    <div class="sdt__meta-value">{{ section.settings.filter_sub_1_text }}</div>
                  {% endif %}
                </div>
              {% endif %}

              {% if section.settings.filter_sub_2_title != blank or section.settings.filter_sub_2_text != blank %}
                <div class="sdt__meta-item">
                  {% if section.settings.filter_sub_2_title != blank %}
                    <div class="sdt__meta-label">{{ section.settings.filter_sub_2_title }}</div>
                  {% endif %}
                  {% if section.settings.filter_sub_2_text != blank %}
                    <div class="sdt__meta-value">{{ section.settings.filter_sub_2_text }}</div>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            {% if section.settings.filter_button_text != blank %}
              <div class="sdt__actions">
                <a
                  class="sdt__btn sdt__btn--primary"
                  {% if section.settings.filter_button_link != blank %}
                    href="{{ section.settings.filter_button_link }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                >
                  {{ section.settings.filter_button_text }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    #solarii-double-tabs-{{ section.id }} {
      --sdt-bg: {{ section.settings.section_bg }};
      --sdt-card: {{ section.settings.card_bg }};
      --sdt-text: {{ section.settings.text_color }};
      --sdt-sub: {{ section.settings.subtext_color }};
      --sdt-border: {{ section.settings.border_color }};
      --sdt-pill: {{ section.settings.pill_bg }};
      --sdt-pill-active: {{ section.settings.pill_active_bg }};
      --sdt-pill-active-text: {{ section.settings.pill_active_text }};
      --sdt-btn: {{ section.settings.button_bg }};
      --sdt-btn-text: {{ section.settings.button_text_color }};
      background: var(--sdt-bg);
      color: var(--sdt-text);
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner {
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
    }

    #solarii-double-tabs-{{ section.id }} * { box-sizing: border-box; }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tabs {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      max-width: 760px;
      margin: 0 auto 24px;
      padding: 8px;
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid var(--sdt-border);
      border-radius: 22px;
      box-shadow: 0 10px 28px rgba(31, 27, 24, 0.04);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab,
    #solarii-double-tabs-{{ section.id }} .sdt__inner-tab,
    #solarii-double-tabs-{{ section.id }} .sdt__btn {
      appearance: none;
      border: 1px solid var(--sdt-border);
      background: var(--sdt-pill);
      color: var(--sdt-text);
      cursor: pointer;
      transition: all .25s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab {
      min-height: 54px;
      padding: 12px 16px;
      border-radius: 16px;
      background: transparent;
      border: 1px solid transparent;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
      text-align: center;
      white-space: normal;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab:hover {
      background: rgba(255, 255, 255, 0.72);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__outer-tab.is-active {
      background: var(--sdt-pill-active);
      color: var(--sdt-pill-active-text);
      border-color: var(--sdt-pill-active);
      box-shadow: 0 10px 20px rgba(31, 27, 24, 0.12);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-tab.is-active {
      background: var(--sdt-pill-active);
      color: var(--sdt-pill-active-text);
      border-color: var(--sdt-pill-active);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__shell {
      background: var(--sdt-card);
      border: 1px solid var(--sdt-border);
      border-radius: 28px;
      padding: 28px;
      box-shadow: 0 18px 60px rgba(30, 24, 18, 0.06);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__panel {
      display: none;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__panel.is-active {
      display: block;
      animation: sdtFade .28s ease;
    }

    @keyframes sdtFade {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    #solarii-double-tabs-{{ section.id }} .sdt__panel-head {
      display: grid;
      gap: 8px;
      margin-bottom: 22px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__eyebrow,
    #solarii-double-tabs-{{ section.id }} .sdt__copy-kicker,
    #solarii-double-tabs-{{ section.id }} .sdt__field-label,
    #solarii-double-tabs-{{ section.id }} .sdt__summary-label,
    #solarii-double-tabs-{{ section.id }} .sdt__meta-label {
      font-size: 11px;
      line-height: 1;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--sdt-sub);
    }

    #solarii-double-tabs-{{ section.id }} .sdt__title {
      margin: 0;
      font-size: clamp(28px, 4vw, 54px);
      line-height: 1.05;
      letter-spacing: -.03em;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__desc,
    #solarii-double-tabs-{{ section.id }} .sdt__copy-body {
      color: var(--sdt-sub);
      font-size: 15px;
      line-height: 1.75;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 22px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-tab {
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 600;
      line-height: 1;
      border-radius: 999px;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-panel,
    #solarii-double-tabs-{{ section.id }} .sdt__single-layout {
      display: none;
      grid-template-columns: minmax(0, 1.08fr) minmax(320px, .92fr);
      gap: 22px;
      align-items: start;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__inner-panel.is-active,
    #solarii-double-tabs-{{ section.id }} .sdt__single-layout {
      display: grid;
    }

    #solarii-double-tabs-{{ section.id }} .sdt__media-card,
