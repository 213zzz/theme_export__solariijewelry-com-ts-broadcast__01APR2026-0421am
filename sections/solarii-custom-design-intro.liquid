        padding: 11px 12px;
        font-size: 12px;
      }
    }
  </style>

  <script>
    (() => {
      const section = document.getElementById('solarii-double-tabs-{{ section.id }}');
      if (!section) return;

      const webhookUrl = section.dataset.makeWebhook || '';
      const outerTabs = section.querySelectorAll('[data-outer-tab]');
      const panels = section.querySelectorAll('[data-panel]');
      const innerTabs = section.querySelectorAll('[data-inner-tab]');
      const innerPanels = section.querySelectorAll('[data-inner-panel]');

      const uploadInput = section.querySelector('[data-upload-input]');
      const uploadPreview = section.querySelector('[data-upload-preview]');
      const uploadPreviewGrid = section.querySelector('[data-upload-preview-grid]');
      const uploadPlaceholder = section.querySelector('[data-upload-placeholder]');
      const uploadTriggerButtons = section.querySelectorAll('[data-upload-trigger]');
      const uploadClear = section.querySelector('[data-upload-clear]');
      const fileNameEl = section.querySelector('[data-file-name]');
      const fileStateEl = section.querySelector('[data-file-state]');
      const summaryFileText = section.querySelector('[data-summary-file-text]');
      const dropzone = section.querySelector('[data-upload-dropzone]');
      const submitBtn = section.querySelector('[data-submit-custom-request]');
      const submitNote = section.querySelector('[data-submit-note]');

      let selectedFiles = [];
      let selectedImageDataUrls = [];

      const fileToDataUrl = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = (event) => resolve(event.target.result || '');
          reader.onerror = reject;
          reader.readAsDataURL(file);
        });

      const escapeHtml = (str) => {
        return String(str)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      };

      const renderPreview = () => {
        if (!uploadPreview || !uploadPreviewGrid || !uploadPlaceholder) return;

        if (!selectedFiles.length) {
          uploadPreview.hidden = true;
          uploadPreviewGrid.innerHTML = '';
          uploadPlaceholder.hidden = false;
          if (fileNameEl) fileNameEl.textContent = '{{ section.settings.upload_empty_file_text | escape }}';
          if (fileStateEl) fileStateEl.textContent = '{{ section.settings.upload_waiting_text | escape }}';
          if (summaryFileText) summaryFileText.textContent = '{{ section.settings.summary_no_file_text | escape }}';
          return;
        }

        const itemsHtml = selectedImageDataUrls.map((src, index) => {
          const isSingle = selectedImageDataUrls.length === 1 ? ' is-single' : '';
          return `
            <div class="sdt__upload-preview-item${isSingle}">
              <img src="${src}" alt="预览图 ${index + 1}">
              <span class="sdt__upload-preview-badge">${index + 1}</span>
            </div>
          `;
        }).join('');

        uploadPreviewGrid.innerHTML = itemsHtml;
        uploadPreview.hidden = false;
        uploadPlaceholder.hidden = true;

        if (fileNameEl) {
          if (selectedFiles.length === 1) {
            fileNameEl.textContent = selectedFiles[0].name;
          } else {
            fileNameEl.textContent = `已选择 ${selectedFiles.length} 张图片`;
          }
        }

        if (fileStateEl) fileStateEl.textContent = '已就绪';

        if (summaryFileText) {
          if (selectedFiles.length === 1) {
            summaryFileText.textContent = `已选择参考图：${selectedFiles[0].name}`;
          } else {
            summaryFileText.textContent = `已选择 ${selectedFiles.length} 张参考图`;
          }
        }
      };

      const handleFiles = async (fileList) => {
        const files = Array.from(fileList || []).filter((file) => file && file.type && file.type.startsWith('image/'));
        if (!files.length) {
          if (submitNote) submitNote.textContent = '请上传图片文件';
          return;
        }

        selectedFiles = files;

        try {
          selectedImageDataUrls = await Promise.all(files.map((file) => fileToDataUrl(file)));
          renderPreview();
          if (submitNote) submitNote.textContent = '';
        } catch (error) {
          console.error(error);
          if (submitNote) submitNote.textContent = '图片读取失败，请重新选择';
        }
      };

      outerTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-outer-tab');
          outerTabs.forEach((item) => item.classList.remove('is-active'));
          panels.forEach((panel) => panel.classList.remove('is-active'));
          tab.classList.add('is-active');
          const activePanel = section.querySelector(`[data-panel="${target}"]`);
          if (activePanel) activePanel.classList.add('is-active');
        });
      });

      innerTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-inner-tab');
          innerTabs.forEach((item) => item.classList.remove('is-active'));
          innerPanels.forEach((panel) => panel.classList.remove('is-active'));
          tab.classList.add('is-active');
          const activePanel = section.querySelector(`[data-inner-panel="${target}"]`);
          if (activePanel) activePanel.classList.add('is-active');
        });
      });

      if (uploadInput) {
        uploadTriggerButtons.forEach((btn) => {
          btn.addEventListener('click', () => uploadInput.click());
        });

        uploadInput.addEventListener('change', async () => {
          await handleFiles(uploadInput.files);
        });

        if (uploadClear) {
          uploadClear.addEventListener('click', () => {
            uploadInput.value = '';
            selectedFiles = [];
            selectedImageDataUrls = [];
            renderPreview();
            if (submitNote) submitNote.textContent = '';
          });
        }

        if (dropzone) {
          dropzone.addEventListener('dragover', (e) => e.preventDefault());

          dropzone.addEventListener('drop', async (e) => {
            e.preventDefault();
            const files = e.dataTransfer.files;
            if (!files || !files.length) return;

            const dt = new DataTransfer();
            Array.from(files).forEach((file) => {
              if (file.type && file.type.startsWith('image/')) {
                dt.items.add(file);
              }
            });

            uploadInput.files = dt.files;
            await handleFiles(uploadInput.files);
          });
        }
      }

      const selects = section.querySelectorAll('[data-summary-source]');
      selects.forEach((select) => {
        select.addEventListener('change', () => {
          const key = select.getAttribute('data-summary-source');
          const target = section.querySelector(`[data-summary-target="${key}"]`);
          if (target) target.textContent = select.value;
        });
      });

      if (submitBtn) {
        submitBtn.addEventListener('click', async () => {
          const getValue = (selector) => {
            const el = section.querySelector(selector);
            return el ? el.value.trim() : '';
          };

          const name = getValue('[data-custom-field="name"]');
          const email = getValue('[data-custom-field="email"]');
          const phone = getValue('[data-custom-field="phone"]');
          const budget = getValue('[data-custom-field="budget"]');
          const noteInput = getValue('[data-custom-field="note"]');

          const gemType = section.querySelector('[data-summary-source="gem_type"]')?.value || '';
          const gemMaterial = section.querySelector('[data-summary-source="gem_material"]')?.value || '';
          const carat = section.querySelector('[data-summary-source="carat"]')?.value || '';
          const metal = section.querySelector('[data-summary-source="metal"]')?.value || '';
          const size = section.querySelector('[data-summary-source="size"]')?.value || '';
          const plating = section.querySelector('[data-summary-source="plating"]')?.value || '';

          if (!webhookUrl) {
            if (submitNote) submitNote.textContent = '请先在模块设置里填写 Make Webhook 地址';
            return;
          }

          if (!name || !email) {
            if (submitNote) submitNote.textContent = '请至少填写姓名和邮箱';
            return;
          }

          if (!selectedFiles.length) {
            if (submitNote) submitNote.textContent = '请先上传至少一张参考图';
            return;
          }

          if (!selectedImageDataUrls.length || selectedImageDataUrls.length !== selectedFiles.length) {
            try {
              selectedImageDataUrls = await Promise.all(selectedFiles.map((file) => fileToDataUrl(file)));
            } catch (error) {
              console.error(error);
              if (submitNote) submitNote.textContent = '图片读取失败，请重新选择';
              return;
            }
          }

          const noteParts = [];
          if (noteInput) noteParts.push(noteInput);
          if (plating) noteParts.push(`镀层: ${plating}`);

          const formData = new FormData();
          formData.append('request_id', `CDR-${Date.now()}`);
          formData.append('created_at', new Date().toISOString());
          formData.append('page_url', window.location.href);
          formData.append('name', name);
          formData.append('email', email);
          formData.append('phone', phone);
          formData.append('gem_type', gemType);
          formData.append('gem_material', gemMaterial);
          formData.append('carat', carat);
          formData.append('metal', metal);
          formData.append('size', size);
          formData.append('budget', budget);
          formData.append('note', noteParts.join(' | '));
          formData.append('image_url', '');
          formData.append('plating', plating);

          formData.append('image_count', String(selectedFiles.length));

          selectedFiles.forEach((file, index) => {
            const dataUrl = selectedImageDataUrls[index] || '';
            const num = index + 1;

            formData.append('images[]', file, file.name);
            formData.append(`image_${num}`, file, file.name);
            formData.append(`image_name_${num}`, file.name);
            formData.append(`image_mime_${num}`, file.type || '');
            formData.append(`image_data_uri_${num}`, dataUrl);
          });

          formData.append('image_names_json', JSON.stringify(selectedFiles.map((file) => file.name)));
          formData.append('image_mimes_json', JSON.stringify(selectedFiles.map((file) => file.type || '')));
          formData.append('image_data_uris_json', JSON.stringify(selectedImageDataUrls));

          formData.append('image_name', selectedFiles[0]?.name || '');
          formData.append('image_mime', selectedFiles[0]?.type || '');
          formData.append('image_data_uri', selectedImageDataUrls[0] || '');

          try {
            submitBtn.disabled = true;
            submitBtn.textContent = '提交中...';
            if (submitNote) submitNote.textContent = '';

            const response = await fetch(webhookUrl, {
              method: 'POST',
              body: formData
            });

            if (!response.ok) {
              throw new Error(`Webhook request failed: ${response.status}`);
            }

            submitBtn.textContent = '已提交';
            if (submitNote) {
              submitNote.textContent = '定制请求已成功发送';
            }
          } catch (error) {
            console.error(error);
            submitBtn.textContent = '{{ section.settings.custom_primary_text | escape }}';
            if (submitNote) {
              submitNote.textContent = '提交失败，请稍后再试';
            }
          } finally {
            setTimeout(() => {
              submitBtn.disabled = false;
              submitBtn.textContent = '{{ section.settings.custom_primary_text | escape }}';
            }, 2000);
          }
        });
      }
    })();
  </script>
</section>

