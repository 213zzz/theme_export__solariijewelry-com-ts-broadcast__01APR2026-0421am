xt_align_desktop":"text-center","text_font_size_px_mobile":32,"text_align_mobile":"text-center--mobile","color_scheme":"","padding_top":0,"padding_bottom":0}},"section_double_n48kKA":{"type":"section-double","blocks":{"heading_UVryBx":{"type":"heading","settings":{"title":"Moissanite","heading_font_size":"heading-large","padding_bottom":16,"heading_tag":"automatic"}},"text_kDy4wj":{"type":"text","settings":{"text":"<p>Our moissanite stones are a marvel, meticulously crafted in state-of-the-art laboratories. Renowned for their incredible brilliance, hardness, and fire, moissanite is the perfect alternative to diamonds. Each stone is precisely cut and polished to showcase its stunning sparkle. <br\/><br\/>Moissanite represents the perfect fusion of technology and aesthetics, embodying an eco-friendly and sustainable choice that allows you to experience the purity of nature and the advancements of science.<\/p>","text_font_size":"body-medium","padding_bottom":16}}},"block_order":["heading_UVryBx","text_kDy4wj"],"settings":{"image_1":"shopify:\/\/shop_images\/696CBDE6-4038-464A-96FD-A0360F7BEC7F_1_201_a.webp","image_width":"one-half","text_alignment":"text-left","layout":"","width":"wrapper--full","height":"screen-height-three-quarters","mobile_height":"screen-height-one-half--mobile","reverse_blocks":false,"color_scheme":"","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_announcement_HP7WRy":{"type":"section-announcement","blocks":{"text_MXTAYy":{"type":"text","settings":{"text":"","text_font_size":"body-small","color":"","target_device_enabled":false,"target_device":"mobile"}}},"block_order":["text_MXTAYy"],"settings":{"slider_speed":7,"text_alignment":"center","marquee_speed":100,"direction":"ticker-rtl","message_spacing":10,"show_border":false,"layout":"marquee","color_scheme":"","padding_top":0,"padding_bottom":0}},"section_double_bGVArD":{"type":"section-double","blocks":{"heading_DDqhMC":{"type":"heading","settings":{"title":"Simulated Diamond","heading_font_size":"heading-large","padding_bottom":16,"heading_tag":"automatic"}},"text_UWg8Uq":{"type":"text","settings":{"text":"<p>Our cubic zirconia stones are a testament to the beauty and versatility of modern gemstones.Carefully crafted with precision and attention to detail, zircon offers a unique charm with its own distinct sparkle.Known for its brilliance and wide range of colors, zircon is an excellent choice for those seeking a stunning and affordable gemstone.<br\/><br\/>Each stone is expertly cut and polished, ensuring a radiant finish that highlights its natural beauty.While zircon may not possess the same hardness and wear resistance as moissanite, it remains a popular and elegant option for various jewelry pieces, embodying both affordability and aesthetic appeal<\/p>","text_font_size":"body-medium","padding_bottom":16}}},"block_order":["heading_DDqhMC","text_UWg8Uq"],"settings":{"image_1":"shopify:\/\/shop_images\/C1B2390E-01BB-4CE6-BEC2-5B2A323E1501_1_201_a.webp","image_width":"one-half","text_alignment":"text-left","layout":"is-reversed","width":"wrapper--full","height":"screen-height-three-quarters","mobile_height":"screen-height-one-half--mobile","reverse_blocks":false,"color_scheme":"","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_announcement_e7Tdp8":{"type":"section-announcement","blocks":{"text_VLDtdJ":{"type":"text","settings":{"text":"","text_font_size":"body-small","color":"","target_device_enabled":false,"target_device":"mobile"}}},"block_order":["text_VLDtdJ"],"settings":{"slider_speed":7,"text_alignment":"center","marquee_speed":100,"direction":"ticker-rtl","message_spacing":10,"show_border":false,"layout":"marquee","color_scheme":"","padding_top":0,"padding_bottom":0}},"section_double_H96nfn":{"type":"section-double","blocks":{"heading_DcRy8W":{"type":"heading","settings":{"title":"925 Sterling Silver","heading_font_size":"heading-large","padding_bottom":16,"heading_tag":"automatic"}},"text_rBkf47":{"typ