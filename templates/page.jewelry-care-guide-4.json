ge_1":"shopify:\/\/shop_images\/2C4CC357-E74B-439A-9DFF-601A608FD9BD_1_201_a.webp","image_2":"shopify:\/\/shop_images\/38662b71-623f-452f-a66d-f2b6fb2ca29f.jpg","image_width":"one-half","text_alignment":"text-left","layout":"is-reversed","width":"wrapper--full","height":"screen-height-three-quarters","mobile_height":"screen-height-one-half--mobile","reverse_blocks":false,"color_scheme":"scheme-1","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_text_with_products_LgyGGK":{"type":"section-text-with-products","settings":{"subheading":"","heading":"Best Ways to Clean Jewelry","image_border_radius":20,"width":"wrapper","text_font_size_px_desktop":29,"text_align_desktop":"text-center","text_font_size_px_mobile":19,"text_align_mobile":"text-center--mobile","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}},"section_text_with_products_Nx3dqi":{"type":"section-text-with-products","settings":{"subheading":"","heading":"Everyday exposure to dirt, dust, oils, and cosmetics can tarnish metals and make gemstones appear less brilliant. In this guide you will find detailed care instructions for Solarii jewelry","image_border_radius":20,"width":"wrapper","text_font_size_px_desktop":27,"text_align_desktop":"text-center","text_font_size_px_mobile":14,"text_align_mobile":"text-center--mobile","color_scheme":"","padding_top":0,"padding_bottom":26}},"section_rich_text_ydKBwb":{"type":"section-rich-text","blocks":{"text_8DpkK6":{"type":"text","settings":{"text":"<p>At Solarii Jewelry, our ethically sourced moissanite and zircon jewelry is designed to be both beautiful and affordable. While our pieces are not the most expensive, they still deserve care and regular attention.<\/p>","text_font_size":"body-medium","padding_bottom":16}}},"block_order":["text_8DpkK6"],"disabled":true,"settings":{"align_text":"text-left","width":"wrapper","color_scheme":"","overlay_type":"disabled","padding_top":20,"padding_bottom":6}},"section_hero_VTQBgq":{"type":"section-hero","blocks":{"heading_FLMhh4":{"type":"heading","settings":{"title":"Jewelry Care Guide","heading_font_size":"heading-x-large","heading_tag":"automatic","padding_bottom":8}},"text_WrNwYc":{"type":"text","settings":{"text":"<p>Tell your brand's story through images.<\/p>","text_font_size":"body-large","padding_bottom":8}}},"block_order":["heading_FLMhh4","text_WrNwYc"],"disabled":true,"settings":{"image_1":"shopify:\/\/shop_images\/b6289d9f-74cb-42bd-949b-e8109271ea02_ebcae387-97b4-4ca1-b16a-912bf00fd4a0.jpg","link":"","width":"wrapper--full","height":"screen-height-full","flex_align_desktop":"align--bottom-right-desktop","content_width":50,"mobile_image":"shopify:\/\/shop_images\/ch.jpg","mobile_height":"screen-height-full--mobile","flex_align_mobile":"align--bottom-left-mobile","color_scheme":"","show_text_background":false,"overlay_type":"disabled","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_double_9zmxP7":{"type":"section-double","blocks":{"heading_eNyFQT":{"type":"heading","settings":{"title":"Jewelry care","heading_font_size":"heading-large","padding_bottom":16,"heading_tag":"automatic"}},"text_myAJbX":{"type":"text","settings":{"text":"<p>To keep your Solarii Jewelry sparkling for years, follow these simple care tips:<\/p><p><strong>Clean Regularly:<\/strong> Wipe with a soft, lint-free cloth. For deeper cleaning, use mild soap in warm water, gently scrub with a soft brush, and rinse thoroughly. Dry completely before storing.<\/p><p><strong>Protect from Damage:<\/strong> Remove jewelry during rigorous activities to avoid scratches and damage.<\/p><p><strong>Avoid Chemicals:<\/strong> Keep your jewelry away from perfumes, lotions, and makeup. Apply these products first, and put on your jewelry last.<\/p><p><strong>Avoid Water:<\/strong> Don't wear jewelry while showering, swimming, or during heavy sweating to prevent tarnishing and discoloration.<\/p><p><strong>Proper Storage:<\/strong> Store in a dry, cool place using the original box or a jewelry organizer to prevent scratches and tangling.<\/p><p>These steps will help maintain the beauty and longevity of your Solarii Jewelry pieces.<\/p>","text_font_size":"body-medium","padding_bottom":16}}},"block_order":["heading_eNyFQT","text_myAJbX"],"settings":{"image_1":"shopify:\/\/shop_images\/2BF8CC2C-1267-4765-8E02-EB2994FEAA22_1_201_a.webp","image_width":"one-half","text_alignment":"text-left","layout":"","width":"wrapper--full","height":"image-height","mobile_height":"image-height--mobile","reverse_blocks":false,"color_scheme":"","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_announcement_KHqCQz":{"type":"section-announcement","blocks":{"text_WYmaaD":{"type":"text","settings":{"text":"","text_font_size":"body-small","color":"","target_device_enabled":false,"target_device":"mobile"}}},"block_order":["text_WYmaaD"],"disabled":true,"settings":{"slider_speed":7,"text_alignment":"center","marquee_speed":100,"direction":"ticker-rtl","message_spacing":10,"show_border":false,"layout":"marquee","color_scheme":"","padding_top":0,"padding_bottom":0}},"section_double_slider_XeXYFH":{"type":"section-double-slider","blocks":{"text_slide_mtMycG":{"type":"text-slide","settings":{"subheading":"","title":"Pave Setting","heading_font_size":"heading-large","text":"<p>Pave settings are delicate and require proper care to prolong their life. To minimize the risk of losing a pave-set gemstone, do not wear the jewelry in situations where friction or abrasion could wear away the metal beads that secure the gemstone. Avoid applying strong pressure or scratching the pave setting. Inspect pave-set jewelry at least every three months and immediately after it is bumped, scratched, or damaged to identify loose gemstones. If a pave-set gemstone is lost, it can be replaced for a fee.<\/p>","text_font_size":"body-medium","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"heading_tag":"automatic"}},"text_slide_hFe6rp":{"type":"text-slide","settings":{"subheading":"","title":"Wearing Jewelry","heading_font_size":"heading-large","text":"<p>Protect your jewelry from impacts with hard surfaces during sports or physical labor. Avoid contact with rough surfaces and protect your jewelry from harsh chemicals such as chlorine and household bleach. Limit your jewelry's exposure to extreme temperatures, perfumes, cosmetics, and household chemicals, which can damage jewelry. Do not wear your rings while gripping objects with force, such as bicycle handlebars or heavy objects, as the pressure may cause the delicate metal rings to bend or break.<\/p>","text_font_size":"body-medium","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"heading_tag":"automatic"}}},"block_order":["text_slide_mtMycG","text_slide_hFe6rp"],"settings":{"image_1":"shopify:\/\/shop_images\/5f93b4f8-c464-403c-b37b-9affe280ea21.jpg","image_2":"shopify:\/\/shop_images\/Copy_of_10459-11_2.webp","image_width":"one-half","autoplay":true,"autoplay_speed":4,"text_alignment":"text-left","layout":"is-reversed","width":"wrapper--full","height":"image-height","mobile_height":"screen-height-one-half--mobile","reverse_blocks":false,"color_scheme":"","padding_top":50,"padding_bottom":0,"show_placeholder":true}},"section_rich_text_columns_tQ4NMb":{"type":"section-rich-text-columns","blocks":{"heading_mrMaaV":{"type":"heading","settings":{"title":"Wearing Care & Disclaimer","heading_font_size":"heading-large","position":"left","padding_bottom":16,"heading_tag":"automatic"}},"text_VA4LJW":{"type":"text","settings":{"text":"<p>Each Solarii ring is handcrafted with precision and passion. Some designs feature unique cuts and settings that enhance brilliance and character.<br\/>To ensure comfort and safety, please follow our wearing instructions carefully and avoid forced or improper wear, collisions, or physical activities while wearing your ring.<br\/>Solarii Jewelry cannot be held responsible for any discomfort or injury resulting from improper use.<br\/>We appreciate your understanding and care — may every sparkle bring you joy and confidence.<\/p>","text_font_size":"body-medium","position":"right","padding_bottom":16}}},"block_order":["heading_mrMaaV","text_VA4LJW"],"name":"Rich text columns","settings":{"left_column_width":40,"divider_width":20,"show_line":true,"right_column_width":40,"align_text":"text-left","width":"wrapper--full-padded","align_text_mobile":"text-left--mobile","color_scheme":"","padding_top":30,"padding_bottom":20}},"section_double_FaARyb":{"type":"section-double","blocks":{"heading_BjaKGd":{"type":"heading","settings":{"title":"Pave Setting","heading_font_size":"heading-large","padding_bottom":16,"heading_tag":"automatic"}},"text_C3fVkL":{"type":"text","settings":{"text":"<p>Pave settings are delicate and require proper care to prolong their life. To minimize the risk of losing a pave-set gemstone, do not wear the jewelry in situations where friction or abrasion could wear away the metal beads that secure the gemstone. Avoid applying strong pressure or scratching the pave setting. Inspect pave-set jewelry at least every three months and immediately after it is bumped, scratched, or damaged to identify loose gemstones. If a pave-set gemstone is lost, it can be replaced for a fee.<\/p>","text_font_size":"body-medium","padding_bottom":16}}},"block_order":["heading_BjaKGd","text_C3fVkL"],"disabled":true,"settings":{"image_1":"shopify:\/\/shop_images\/dl.beatsnoop.com-final-LhK0yarjGg.jpg","image_width":"one-half","text_alignment":"text-left","layout":"is-reversed","width":"wrapper--full","height":"image-height","mobile_height":"image-height--mobile","reverse_blocks":false,"color_scheme":"","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_announcement_cgRFxY":{"type":"section-announcement","blocks":{"text_TBKqpC":{"type":"text","settings":{"text":"","text_