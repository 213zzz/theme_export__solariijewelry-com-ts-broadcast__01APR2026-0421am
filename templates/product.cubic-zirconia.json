:"text-center","width":"wrapper","color_scheme":"scheme-a99bb364-57b9-4cca-912d-b0f18794ffaf","overlay_type":"disabled","padding_top":10,"padding_bottom":0}},"section_double_4Bcq63":{"type":"section-double","blocks":{"text_tzQdLE":{"type":"text","settings":{"text":"<p>A ring is just an accessory, and cubic zirconia is one of many choices. Materials hold no inherent value—it's all about personal taste. If it doesn't enhance your beauty, what good are even the priciest diamonds?<\/p>","text_font_size":"body-large","padding_bottom":16}}},"block_order":["text_tzQdLE"],"settings":{"image_1":"shopify:\/\/shop_images\/3ccb2a20c440bb4de5e6a372c42be757.gif","image_width":"one-half","text_alignment":"text-left","layout":"","width":"wrapper--full","height":"screen-height-three-quarters","mobile_height":"screen-height-one-third--mobile","reverse_blocks":false,"color_scheme":"scheme-1","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_rich_text_McLVAM":{"type":"section-rich-text","blocks":{"heading_BtThgk":{"type":"heading","settings":{"title":"What makes our products special？","heading_font_size":"heading-medium","padding_bottom":10,"heading_tag":"automatic"}}},"block_order":["heading_BtThgk"],"settings":{"align_text":"text-center","width":"wrapper","color_scheme":"scheme-9c9f1fe6-23f9-471e-b2f3-03a31f5fb70d","overlay_type":"disabled","padding_top":14,"padding_bottom":0}},"section_columns_HgPdQA":{"type":"section-columns","blocks":{"image_aNYG4b":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/diamond-vs-moissanite_97808b9c-7d49-43b2-88dd-e34151ed44a8_1.jpg","image_width":100,"image_shape":"normal","title":"","heading_font_size":"heading-small","text":"<p>Solarii Alternative's Simulated Diamonds uses a unique Russian formula and high-purity materials, enhanced with advanced crystal stabilization technology. Its multi-layer coating boosts brightness, prevents oxidation, and ensures long-lasting vibrant colors, surpassing diamonds in transparency and brilliance.<\/p>","text_font_size":"body-small","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"image_aspect_ratio":1,"mobile_image_aspect_ratio":1,"heading_tag":"automatic"}},"image_jy4dPq":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/20241031-215013.gif","image_width":100,"image_shape":"normal","title":"","heading_font_size":"heading-small","text":"<p>Solarii Alternative’s Simulated Diamonds is treated with cutting-edge, multi-layer coatings applied using advanced PVD or CVD technology. These coatings significantly enhance the gemstone’s brilliance while offering superior protection against scratches, oxidation, and wear, ensuring that the stone retains its flawless appearance over time.<\/p>","text_font_size":"body-small","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"image_aspect_ratio":1,"mobile_image_aspect_ratio":1,"heading_tag":"automatic"}},"image_dNnCTD":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/11_4f76ec9c-d81b-4544-b2a2-f6c7d011c349.jpg","image_width":100,"image_shape":"normal","title":"","heading_font_size":"heading-small","text":"<p>Solarii Alternative employs state-of-the-art multi-layer coating technology for the ring band, incorporating world-leading nano-coating and laser melting techniques. These sophisticated coatings provide unparalleled durability, exceptional scratch and corrosion resistance, and a seamless bond with the surface, preserving the ring’s beauty and luster for a lifetime.<\/p>","text_font_size":"body-small","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"image_aspect_ratio":1,"mobile_image_aspect_ratio":1,"heading_tag":"automatic"}}},"block_order":["image_aNYG4b","image_jy4dPq","image_dNnCTD"],"settings":{"title":"","heading_font_size":"heading-medium","al