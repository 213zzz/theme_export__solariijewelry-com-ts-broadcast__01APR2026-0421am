":["title","loox_reviews_loox_rating_knLgmA","loox_reviews_loox_snippets_widget_DMFXz7","price","countdown_cFb9xg","sharing_FWnda4","accordion_zYaABM","text_rpCWCk","text_UyVkjk","text_jXqFDw","variants","buttons","trustz_payment_badge_NCb6Gp","accordion_8MwtR3","accordion_QgCAgY","icon_1","icon_663HJF","icon_2","icon_KMKHHa","icon_NGWPpx","features_m7iwXy","pickup","tabs","divider_1","upsell"],"settings":{"product_sticky_enable":true,"variant_image_scroll":true,"show_cart_bar":true,"enable_zoom":true,"enable_video_looping":false,"image_layout":"stacked","image_size":"normal","mobile_image_style":"thumbs","color_scheme":"scheme-1","padding_top":0,"padding_bottom":30}},"section_accordion_kNiVya":{"type":"section-accordion","blocks":{"text_WtjXfb":{"type":"text","settings":{"title":"What is your stone material?","heading_font_size":"heading-small","text":"<p>We use high-quality <a href=\"https:\/\/solariijewelry.com\/pages\/about-moissanite\" title=\"About Moissanite\"><em><strong>moissanite<\/strong><\/em><\/a> and <a href=\"https:\/\/solariijewelry.com\/pages\/about-cubic-zirconia\" title=\"https:\/\/solariijewelry.com\/pages\/about-cubic-zirconia\"><em><strong>Simulated Diamonds<\/strong><\/em><\/a>, both ethically and sustainably lab-created. These stones sparkle just as brilliantly as diamonds<\/p>"}},"text_diG7wX":{"type":"text","settings":{"title":"Will your jewelry turn my finger green?","heading_font_size":"heading-small","text":"<p>No, it won’t! We can guarantee this.Our jewelry is made from 925 sterling silver plated with 18K gold, so it won’t discolor your skin, and it's hypoallergenic too.<\/p>"}},"text_pbXDqj":{"type":"text","settings":{"title":"How should I care for my jewelry?","heading_font_size":"heading-small","text":"<p>When you’re not wearing it, store your jewelry in a jewelry box or pouch. A quick polish with a silver cloth will keep it shining. We recommend taking it off when showering, applying lotions, or during workouts to prevent oxidation. And while it's tempting, it's best not to wear it to bed!<\/p><p><a href=\"https:\/\/solariijewelry.com\/pages\/jewelry-care\" title=\"Jewelry care\"><em><strong>Jewelry Care Tips<\/strong><\/em><\/a><\/p>"}},"text_7qV8CB":{"type":"text","settings":{"title":"Do I get anything extra with my order?","heading_font_size":"heading-small","text":"<p>Yes! Along with your jewelry and a gift box, you’ll receive a free surprise jewelry piece and a good luck <a href=\"https:\/\/solariijewelry.com\/pages\/mystery-box-promotion\" title=\"Mystery Box Promotion\"><em><strong>crystal<\/strong><\/em><\/a>. Plus, we <a href=\"https:\/\/solariijewelry.com\/pages\/planting-trees-together\" title=\"Planting Trees Together\"><em><strong>plant a tree<\/strong><\/em><\/a> in your name as part of our commitment to the planet.<\/p>"}},"text_gnBfDf":{"type":"text","settings":{"title":"Can I customize my jewelry?","heading_font_size":"heading-small","text":"<p>Yes, we offer <a href=\"https:\/\/solariijewelry.com\/pages\/custom-design\" title=\"Custom Design\"><em><strong>custom jewelry<\/strong><\/em><\/a>, and the design process is completely free! You can share any of your ideas with us, and we’ll bring them to life. Just reach out to us at service@solariijewelry.com, and we’ll make sure your vision becomes reality.<\/p>"}},"text_TCJ86G":{"type":"text","settings":{"title":"Have more questions?","heading_font_size":"heading-small","text":"<p>We’ve highlighted the 5 most common questions here, but if you have more, feel free to check out our full <a href=\"https:\/\/solariijewelry.com\/pages\/faq\" title=\"FAQ\"><em><strong>FAQ<\/strong><\/em><\/a> section for additional details.<\/p>"}}},"block_order":["text_WtjXfb","text_diG7wX","text_pbXDqj","text_7qV8CB","text_gnBfDf","text_TCJ86G"],"settings":{"default_open":false,"title":"Jewelry FAQ","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-washing-machine","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_PCmrb3":{"type":"section-accordion","blocks":{"icon_jAnB7d":{"type":"icon","settings":{"icon_name":"icon-green-shipment","icon_size":20,"icon_color":"","title":"Free shipping & Free package gifts","heading_font_size":"heading-small","icon_alignment":"left","text":"<p>We do our best to process and ship your order as soon as we can! Below you'll find our shipping options and their estimated shipping times.<br\/><br\/>• Free Shipping - (6-12 Business Days)<br\/>• Express Shipping - (5-8 Business Days)<br\/>• Rush Shipping - (3-5 Business Days)<\/p><p><a href=\"\/policies\/shipping-policy\" title=\"Shipping Policy\"><strong>Learn More<\/strong><\/a><\/p>","text_alignment":"text-left"}},"icon_idnAWe":{"type":"icon","settings":{"icon_name":"icon-location","icon_size":20,"icon_color":"","title":"Order tracking","heading_font_size":"heading-small","icon_alignment":"left","text":"<p>Tracking numbers are automatically sent once your order has been shipped. Please check your junk folder if you do not receive one 72 hours after placing your order.<\/p>","text_alignment":"text-left"}},"icon_dQDGbL":{"type":"icon","settings":{"icon_name":"icon-chat","icon_size":20,"icon_color":"","title":"Contact Us","heading_font_size":"heading-small","icon_alignment":"left","text":"<p><strong>If you have any questions about your order, please reach out to us at <\/strong><a><strong>service@solariijewelry.com<\/strong><\/a><strong>. We typically respond within 24 hours.<\/strong><\/p>","text_alignment":"text-left"}}},"block_order":["icon_jAnB7d","icon_idnAWe","icon_dQDGbL"],"settings":{"default_open":false,"title":"Shipping & Returns","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-shield","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_hQVpFe":{"type":"section-accordion","blocks":{"text_WFt8Pq":{"type":"text","