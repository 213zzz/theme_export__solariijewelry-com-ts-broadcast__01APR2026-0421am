:16}}},"block_order":["heading_6y9Fmi","text_GHHwpD"],"settings":{"align_text":"text-center","width":"wrapper","color_scheme":"scheme-9c9f1fe6-23f9-471e-b2f3-03a31f5fb70d","overlay_type":"disabled","padding_top":10,"padding_bottom":0}},"section_rich_text_BCKyfy":{"type":"section-rich-text","blocks":{"heading_FTfaVk":{"type":"heading","settings":{"title":"Why Choose Us","heading_font_size":"heading-large","padding_bottom":16,"heading_tag":"automatic"}},"text_ACJGz4":{"type":"text","settings":{"text":"<p>With over a decade of handcrafted expertise and 100,000+ happy customers, Solarii promises one-on-one custom craftsmanship—no matter your order size. We use ethical gemstones and guarantee 100% match with our photos. Enjoy peace of mind with 30-day no-hassle refunds, a 1-year warranty, and 24\/7 customer support.<\/p>","text_font_size":"body-medium","padding_bottom":16}}},"block_order":["heading_FTfaVk","text_ACJGz4"],"settings":{"align_text":"text-center","width":"wrapper","color_scheme":"scheme-9c9f1fe6-23f9-471e-b2f3-03a31f5fb70d","overlay_type":"disabled","padding_top":10,"padding_bottom":0}},"section_rich_text_whpQPV":{"type":"section-rich-text","blocks":{"heading_nRkjHX":{"type":"heading","settings":{"title":"Solarii's Ethical Excellence","heading_font_size":"heading-large","padding_bottom":16,"heading_tag":"automatic"}},"text_8XtxkN":{"type":"text","settings":{"text":"<p>Choosing the right engagement ring and wedding band is a reflection of your values and beliefs. At Solarii, we understand the importance of ethical sourcing. Sadly, many traditional jewelers still use conflict minerals and blood diamonds, materials linked to human suffering. We reject this practice. Every piece of jewelry we craft is made from 100% responsibly sourced materials. With our human-made stones, you get the beauty and brilliance of a traditional wedding ring without the ethical compromise. Our commitment to ethical excellence ensures your love story is not just beautiful—it’s conscientious.<\/p>","text_font_size":"body-medium","padding_bottom":16}}},"block_order":["heading_nRkjHX","text_8XtxkN"],"disabled":true,"settings":{"align_text":"text-center","width":"wrapper","color_scheme":"scheme-3","overlay_type":"disabled","padding_top":10,"padding_bottom":0}}},"order":["hero","section_rich_text_9iUjkB","section_hero_yKF9cK","subcollections","section_highlights_eGKwzP","solarii_ring_filter_nmtiRm","main","sparqAppBlock","section_rich_text_pAjDTM","section_rich_text_BCKyfy","section_rich_text_whpQPV"]}