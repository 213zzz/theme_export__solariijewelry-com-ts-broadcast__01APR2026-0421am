":{"icon_name":"icon-notes","image":"shopify:\/\/shop_images\/16-1.png","icon_size":20,"icon_color":"#545454","text":"<p>Easy Return or Exchange within 30 days<\/p>","text_font_size":"body-medium","width":"full","padding_bottom":16}},"icon_663HJF":{"type":"icon","settings":{"icon_name":"icon-award","image":"shopify:\/\/shop_images\/16-3.png","icon_size":20,"icon_color":"#545454","text":"<p>One year warranty<\/p>","text_font_size":"body-medium","width":"full","padding_bottom":16}},"icon_2":{"type":"icon","settings":{"icon_name":"icon-truck","image":"shopify:\/\/shop_images\/16-2.png","icon_size":20,"icon_color":"#545454","text":"<p>Free shipping & Free package gifts<\/p>","text_font_size":"body-medium","width":"full","padding_bottom":16}},"icon_KMKHHa":{"type":"icon","settings":{"icon_name":"icon-award","image":"shopify:\/\/shop_images\/16-4.png","icon_size":20,"icon_color":"#545454","text":"<p>925 Sterling Silver<\/p>","text_font_size":"body-medium","width":"full","padding_bottom":16}}},"block_order":["title","loox_reviews_loox_rating_RmpBmG","loox_reviews_loox_snippets_widget_kpeXU3","price","countdown_dbJGaa","accordion_X9nqxr","variants","klarna_on_site_messaging_app_block_QyN4yT","buttons","trustz_payment_badge_rnKfx4","accordion_jHM8Nn","accordion_tMFjyA","icon_1","icon_663HJF","icon_2","icon_KMKHHa"],"settings":{"product_sticky_enable":true,"variant_image_scroll":true,"show_cart_bar":true,"enable_zoom":true,"enable_video_looping":false,"image_layout":"stacked","image_size":"normal","mobile_image_style":"thumbs","color_scheme":"scheme-1","padding_top":90,"padding_bottom":30}},"faq":{"type":"section-accordion","blocks":{"faq-1":{"type":"text","settings":{"title":"Are your rings Nickel free?","heading_font_size":"heading-small","text":"<p>Absolutely! We mean it when we say “conflict-free”. Rest assured, our pieces don’t contain any nickel or other metals that can cause common allergic reactions.<\/p>"}},"text_wCNEX9":{"type":"text","settings":{"title":"Will your jewelry turn my finger green?","heading_font_size":"heading-small","text":"<p><em>The long answer:<\/em>No, our jewelry will not turn any part of your body green - We can guarantee this. If you do run into an issue with any of your pieces, please don’t hesitate to reach out to our support team at <strong>service@solariijewelry.com<\/strong><\/p>"}},"text_MEEaGK":{"type":"text","settings":{"title":"Where do your stones rank in the Mohs scale?","heading_font_size":"heading-small","text":"<p>Our simulated diamonds rank at an 8.5 out of 10 on the Mohs scale. This scale is used to measure the mineral hardness and scratch resistance of the stone in question. Traditional diamonds usually rank at a 10, so we’re not too far behind. 😉<\/p>"}},"text_d7qpEX":{"type":"text","settings":{"title":"Is your jewelry plated in rhodium?","heading_font_size":"heading-small","text":"<p>Yes, all sterling silver jewelry is plated in rhodium to give it that classic, unmistakable shine! Rhodium plating also helps give your jewelry an extra layer of protection against scratches and does not corrode or tarnish.<\/p>"}},"text_KqkMnP":{"type":"text","settings":{"title":"What are your stones made of?","heading_font_size":"heading-small","text":"<p>Our rings are made from conflict free materials. We don't support inhumanely mined diamonds, which is why we use high quality conflict free simulated diamonds. Simulated diamonds are man-made stones that look just like a perfect diamond and shine like crazy.<\/p>"}},"text_t7GyjL":{"type":"text","settings":{"title":"How are your stones cut?","heading_font_size":"heading-small","text":"<p>Every one of our stones are hand-cut with precision to ensure you’re wearing the same shine and brilliance as a traditional diamond.<\/p>"}}},"block_order":["faq-1","text_wCNEX9","text_MEEaGK","text_d7qpEX","text_KqkMnP","text_t7GyjL"],"settings":{"default_open":false,"title":"Jewelry FAQ","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-fast-shipment","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_kNiVya":{"type":"section-accordion","blocks":{"icon_J7E79p":{"type":"icon","settings":{"icon_name":"icon-green-shipment","icon_size":20,"icon_color":"","title":"Free shipping & Free package gifts","heading_font_size":"heading-small","icon_alignment":"left","text":"<p>We do our best to process and ship your order as soon as we can! Below you'll find our shipping options and their estimated shipping times.<br\/><br\/>• Free Shipping - (6-12 Business Days)<br\/>• Express Shipping - (5-8 Business Days)<br\/>• Rush Shipping - (3-5 Business Days)<\/p><p><a href=\"\/policies\/shipping-policy\" title=\"Shipping Policy\"><strong>Learn More<\/strong><\/a><\/p>","text_alignment":"text-left"}},"icon_BpFVB4":{"type":"icon","settings":{"icon_name":"icon-location","icon_size":20,"icon_color":"","title":"Order tracking","heading_font_size":"heading-small","icon_alignment":"left","text":"<p>Tracking numbers are automatically sent once your order has been shipped. Please check your junk folder if you do not receive one 72 hours after placing your order.<\/p>","text_alignment":"text-left"}},"icon_D3chie":{"type":"icon","settings":{"icon_name":"icon-chat","icon_size":20,"icon_color":"","title":"Contact Us","heading_font_size":"heading-small","icon_alignment":"left","text":"<p><strong>If you have any questions about your order, please reach out to us at <\/strong><a><strong>service@solariijewelry.com<\/strong><\/a><strong>. We typically respond within 24 hours.<\/strong><\/p>","text_alignment":"text-left"}}},"block_order":["icon_J7E79p","icon_BpFVB4","icon_D3chie"],"settings":{"default_open":false,"title":"Shipping & Returns","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-smile","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_YzLWbn":{"type":"section-accordion","blocks":{"text_czfw7g":{"type":"text","settings":{"title":"Will moissanite or Simulated Diamonds become dull over time?","heading_font_size":"heading-small","text":"<p>Moissanite and high-quality simulated diamonds are designed to stay brilliant over time. Unlike some gemstones, they won’t cloud or lose their sparkle—even after years of wear. With proper care, your stone will continue to shine just as beautifully as the day you got it.<\/p>"}},"text_ikGzKW":{"type":"text","settings":{"title":"What is a simulated diamond?","heading_font_size":"heading-small","text":"<p>Simulated diamonds are lab-created stones crafted to mirror the beauty of natural diamonds. They offer exceptional brilliance, clarity, and fire—without the premium price.<\/p>"}},"text_mmz8Jx":{"type":"text","settings":{"title":"Can I wear simulated diamonds every day?","heading_font_size":"heading-small","text":"<p>Absolutely. They’re durable enough for everyday use and perfect for rings, earrings, and necklaces.<\/p>"}},"text_GnRHbR":{"type":"text","settings":{"title":"Are simulated diamonds suitable for engagement rings?","heading_font_size":"heading-small","text":"<p>Yes! They're a stunning, affordable, and ethical choice for modern couples looking for beauty without compromise.<\/p>"}},"text_DyLWYc":{"type":"text","settings":{"title":"How do simulated diamonds compare to other diamond alternatives?","heading_font_size":"heading-small","text":"<p>They offer brilliant shine and clarity, crafted for a natural diamond look, and are known for their excellent value and wearability.<\/p>"}},"text_jVJegW":{"type":"text","settings":{"title":"Can simulated diamond rings be resized or repaired?","heading_font_size":"heading-small","text":"<p>Yes, just like natural gemstone rings, they can be resized or repaired by professionals if needed.<\/p>"}}},"block_order":["text_czfw7g","text_ikGzKW","text_mmz8Jx","text_GnRHbR","text_DyLWYc","text_jVJegW"],"settings":{"default_open":false,"title":"Simulated Diamonds FAQ","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-fast-shipment","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_Hp74FJ":{"type":"section-accordion","blocks":{"text_xJHjcc":{"type":"text","settings":{"title":"Wedding & Engagement","heading_font_size":"heading-small","text":"<p>Why spend a fortune on a diamond? Choose a stunning, handcrafted, conflict-free ring with a lifetime guarantee. A smarter choice, without the high cost.<\/p>"}},"text_8zCdeg":{"type":"text","settings":{"title":"Travel","heading_font_size":"heading-small","text":"<p>Adventure confidently and worry-free with a travel ring that shines, while your expensive ring stays safe at home.<\/p>"}},"text_pzcNRQ":{"type":"text","settings":{"title":"Pregnancy","heading_font_size":"heading-small","text":"<p>When your pregnant, no need to resize or go without a ring—our rings are the perfect stand-in when your hands start to swell.<\/p>"}},"text_rYY3FP":{"type":"text","settings":{"title":"Every Occasion","heading_font_size":"heading-small","text":"<p>Match your ring to your mood. Whether you feel like wearing gold one day or silver the next... you can make it possible and not feel guilty with our affordable selection.<\/p>"}}},"block_order":["text_xJHjcc","text_8zCdeg","text_pzcNRQ","text_rYY3FP"],"settings":{"default_open":false,"title":"YOUR RING, PERFECT FOR ANY OCCASION.","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-fast-shipment","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_hero_Ud83fb":{"type":"section-hero","disabled":true,"settings":{"image_1":"shopify:\/\/shop_images\/20241024-210857.gif","link":"","width":"wrapper--full","height":"image-height","flex_align_desktop":"align--middle-center-desktop","content_width":50,"mobile_height":"image-height--mobil