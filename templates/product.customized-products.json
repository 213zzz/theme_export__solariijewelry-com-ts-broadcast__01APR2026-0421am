ng_bottom":30}},"faq":{"type":"section-accordion","blocks":{"faq-1":{"type":"text","settings":{"title":"Do your custom pieces come with a warranty?","heading_font_size":"heading-small","text":"<p>Yes, all of our custom pieces come with a warranty.<br\/>If there are any manufacturing defects, we’ll repair or replace it at no cost.<br\/>For full details, please refer to our warranty policy or contact our support team.<\/p>"}},"text_wCNEX9":{"type":"text","settings":{"title":"When will I receive my custom design?","heading_font_size":"heading-small","text":"<p>You’ll receive an initial design within 3 days of placing your order. Once the design is approved, production typically takes 5–7 days, and up to 10 days depending on the complexity of your request.<\/p>"}},"text_MEEaGK":{"type":"text","settings":{"title":"Can you design from a photo or video I found online?","heading_font_size":"heading-small","text":"<p>Absolutely. Just show us what she’s been tagging or saving, and we’ll use it as inspiration. We’ll take what she loves and make it better—more custom, better priced, and made just for her. <\/p>"}},"text_d7qpEX":{"type":"text","disabled":true,"settings":{"title":"Will moissanite test as a diamond?","heading_font_size":"heading-small","text":"<p>Moissanite can be detected as a diamond by standard diamond testers. However, more advanced equipment can easily distinguish between moissanite and diamonds.<\/p>"}},"text_KqkMnP":{"type":"text","disabled":true,"settings":{"title":"Is moissanite hypoallergenic?","heading_font_size":"heading-small","text":"<p>Yes, moissanite is typically set in hypoallergenic metals like 925 sterling silver or other non-reactive metals, making it suitable for most people, even those with sensitive skin.<\/p>"}},"text_t7GyjL":{"type":"text","disabled":true,"settings":{"title":"Have more questions?","heading_font_size":"heading-small","text":"<p>We’ve highlighted the 5 most common questions here, but if you have more, feel free to check out our full<a href=\"https:\/\/solariijewelry.com\/pages\/faq\" title=\"FAQ\"><em><strong>FAQ<\/strong><\/em><\/a>section for additional details.<\/p>"}}},"block_order":["faq-1","text_wCNEX9","text_MEEaGK","text_d7qpEX","text_KqkMnP","text_t7GyjL"],"settings":{"default_open":false,"title":"Frequently Asked Questions","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-fast-shipment","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_PCmrb3":{"type":"section-accordion","blocks":{"text_wQLh7F":{"type":"text","settings":{"title":"100% Handcrafted, No Matter the Order Size","heading_font_size":"heading-small","text":"<p>We promise that every piece—regardless of price or quantity—is carefully handcrafted by our skilled artisans with the highest level of craftsmanship.<\/p>"}},"text_PYxhzN":{"type":"text","settings":{"title":"What You See Is Exactly What You Get","heading_font_size":"heading-small","text":"<p>We guarantee our videos and images match the real product. No exaggeration, no surprises.<\/p>"}},"text_eNqhWM":{"type":"text","settings":{"title":"Hassle-Free After-Sales Support","heading_font_size":"heading-small","text":"<p>Enjoy 30-day easy returns, 1-year warranty, and full customer support around the clock. Shop with confidence.<\/p>"}},"text_cdMpHQ":{"type":"text","settings":{"title":"Eco-Friendly & Sustainable Materials","heading_font_size":"heading-small","text":"<p>Our pieces are made with sustainability in mind. All stones are lab-grown, and our packaging is made from biodegradable materials.<\/p>"}},"text_JNQXTT":{"type":"text","settings":{"title":"Premium Quality Like Works of Art","heading_font_size":"heading-small","text":"<p>We use only the finest materials. Every product is crafted to the highest standard—each one a wearable piece of art.<\/p>"}},"text_KVAk7C":{"type":"text","settings":{"title":"Free Customization on All Orders","heading_font_size":"heading-small","text":"<p>We offer free customization with every product. You can request any adjustment without extra labor fees—we only charge for material upgrades if needed. No hidden costs, ever.<\/p>"}}},"block_order":["text_wQLh7F","text_PYxhzN","text_eNqhWM","text_cdMpHQ","text_JNQXTT","text_KVAk7C"],"settings":{"default_open":false,"title":"About Us","heading_font_size":"heading-small","show_icon":false,"icon_name":"icon-shield","icon_size":20,"width":"wrapper","color_scheme":"scheme-1","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_hero_Ud83fb":{"type":"section-hero","disabled":true,"settings":{"image_1":"shopify:\/\/shop_images\/20241024-210857.gif","link":"","width":"wrapper--full","height":"image-height","flex_align_desktop":"align--middle-center-desktop","content_width":50,"mobile_height":"image-height--mobile","flex_align_mobile":"align--middle-center-mobile","color_scheme":"","show_text_background":false,"padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_rich_text_rThDCY":{"type":"section-rich-text","blocks":{"heading_AmbFQd":{"type":"heading","settings":{"title":"Only the finest, premium-grade gemstones make it into our collection.","heading_font_size":"heading-medium","padding_bottom":16,"heading_tag":"automatic"}}},"block_order":["heading_AmbFQd"],"settings":{"align_text":"text-center","width":"wrapper","color_scheme":"scheme-9c9f1fe6-23f9-471e-b2f3-03a31f5fb70d","padding_top":14,"padding_bottom":0}},"section_video_FakCBe":{"type":"section-video","name":"Video","settings":{"video":"shopify:\/\/files\/videos\/未命名的设计 (1) (1) (1).mp4","show_video_popup":false,"video_popup_social":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","title":"","heading_font_size":"heading-large","text":"","text_font_size":"body-medium","flex_align":"align--middle-center","link_text":"","link":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"desktop_height":"image-height","mobile_he