humbnails","image_size":"normal","mobile_image_style":"thumbs","padding_top":90,"padding_bottom":30}},"faq":{"type":"section-accordion","blocks":{"faq-1":{"type":"text","settings":{"title":"Free shipping & Free package gifts","text":"<p>We do our best to process and ship your order as soon as we can! Below you'll find our shipping options and their estimated shipping times.<br\/><br\/>• Free Shipping - (6-12 Business Days)<br\/>• Express Shipping - (5-8 Business Days)<br\/>• Rush Shipping - (3-5 Business Days)<\/p><p><a href=\"\/policies\/shipping-policy\" title=\"Shipping Policy\"><em><strong>Learn More<\/strong><\/em><\/a><\/p>"}}},"block_order":["faq-1"],"settings":{"default_open":false,"title":"Delivery & Shipping","show_icon":true,"icon_name":"icon-fast-shipment","icon_size":20,"width":"wrapper","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_kNiVya":{"type":"section-accordion","blocks":{"text_WtjXfb":{"type":"text","settings":{"title":"Easy Return or Exchange within 30 days","text":"<p>At solariijewelry, your satisfaction is our top priority. Therefore, if for any reason, you're not completely happy with your purchase, we offer a hassle-free Return & Exchange policy.<\/p><p><a href=\"\/policies\/refund-policy\" title=\"Refund Policy\"><em><strong>Learn More<\/strong><\/em><\/a><\/p>"}}},"block_order":["text_WtjXfb"],"settings":{"default_open":false,"title":"30-day Return & Exchange","show_icon":true,"icon_name":"icon-smile","icon_size":20,"width":"wrapper","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_accordion_PCmrb3":{"type":"section-accordion","blocks":{"text_k6TVNY":{"type":"text","settings":{"title":"","text":"<p>Solarii Jewelry fully stands behind the products we sell. Therefore, all of our products are covered by a <strong>one year warranty <\/strong>starting from the day when the original order was received.<\/p><p><a href=\"\/pages\/our-warranty\" title=\"Our Warranty\"><em><strong>Learn More<\/strong><\/em><\/a><\/p>"}}},"block_order":["text_k6TVNY"],"settings":{"default_open":false,"title":"One year warranty","show_icon":true,"icon_name":"icon-shield","icon_size":20,"width":"wrapper","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"shipping":{"type":"section-accordion","blocks":{"shipping-0":{"type":"icon","settings":{"icon_name":"icon-fast-shipment","icon_size":20,"icon_color":"#545454","title":"Fast shipping","text":"<p>Use this to answer some common questions you hear from your customers. You could discuss product details, size fit, shipping policies, or anything you think would help merchants make an informed decision about your products. This section will appear across all products.<\/p>"}},"shipping-1":{"type":"icon","settings":{"icon_name":"icon-box","icon_size":20,"icon_color":"#545454","title":"Order tracking","text":"<p>Use this to answer some common questions you hear from your customers. You could discuss product details, size fit, shipping policies, or anything you think would help merchants make an informed decision about your products. This section will appear across all products.<\/p>"}},"shipping-2":{"type":"icon","settings":{"icon_name":"icon-chat","icon_size":20,"icon_color":"#545454","title":"Get in touch","text":"<p>Use this to answer some common questions you hear from your customers. You could discuss product details, size fit, shipping policies, or anything you think would help merchants make an informed decision about your products. This section will appear across all products.<\/p>"}}},"block_order":["shipping-0","shipping-1","shipping-2"],"disabled":true,"settings":{"default_open":false,"title":"Shipping","show_icon":false,"icon_name":"icon-award","icon_size":20,"width":"wrapper","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"about":{"type":"section-accordion","blocks":{"about-0":{"type":"image","settings":{"title":"Quality Verified By International Institution SGS","text":"<p>SGS:The world's largest and oldest product quality control and technical<br\/>identification multinational company.<br\/>Sterling Silver (S925)Report Resuits:Silver Content Test ≥925.3‰<\/p>","image":"shopify:\/\/shop_images\/26a388394a0105ac7f89fc22b946902e.jpg","aspect_ratio":1.4}},"about-1":{"type":"image","settings":{"title":"Lead and Cadmium Release: PASS","text":"<p>Indicates our commitment to safety and quality. Our products undergo rigorous testing to ensure no harmful trace metals are released, providing not only utility but health assurance for our consumers.<\/p>","image":"shopify:\/\/shop_images\/8e59106fa06f696721ee3e93724da05b.jpg","aspect_ratio":1.4}},"about-2":{"type":"image","settings":{"title":"Nickel Release: PASS","text":"<p>Signifies our dedication to consumer safety. This means our products comply with stringent nickel release regulations to prevent potential allergic reactions, ensuring our commitment to health as well as functionality.<\/p>","image":"shopify:\/\/shop_images\/e3952e2e2ab7ade292a1fea03ecb392b.jpg","aspect_ratio":1.4}}},"block_order":["about-0","about-1","about-2"],"settings":{"default_open":false,"title":"Certificate","show_icon":true,"icon_name":"icon-award","icon_size":20,"width":"wrapper","icon_color":"#545454","padding_top":0,"padding_bottom":0}},"section_hero_Ud83fb":{"type":"section-hero","settings":{"image_1":"shopify:\/\/shop_images\/20241024-210857.gif","link":"","width":"wrapper--full","height":"image-height","flex_align_desktop":"align--middle-center-desktop","mobile_height":"image-height--mobile","flex_align_mobile":"align--middle-center-mobile","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_rich_text_8iMbx7":{"type":"section-rich-text","blocks":{"subheading_qTqBNE":{"type":"subheading","disabled":true,"settings":{"subheading":"Introducing","padding_bottom":16}},"heading_qT9EtY":{"type":"heading","settings":{"title":"It’s Not Diamond. It’s Solarii Moissanite Stone","padding_bottom":16}},"text_akixgP":{"type":"text","settings":{"text":"<p>Our premium-quality moissanite is visually indistinguishable from diamonds, even to the naked eye. With its incredible brilliance and fire, moissanite outshines diamonds, while costing just a fraction—less than 1% of the price. Experience luxury without compromise.<\/p>","padding_bottom":16}}},"block_order":["subheading_qTqBNE","heading_qT9EtY","text_akixgP"],"settings":{"align_text":"text-center","width":"wrapper","padding_top":30,"padding_bottom":0}},"section_columns_8ejR6x":{"type":"section-columns","blocks":{"image_TLXtjg":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/20241024-101444.gif","image_shape":"normal","title":"Unmatched Durability","text":"<p>Moissanite is built to last. Even the toughest tools can't leave a scratch on its surface, showcasing its superior hardness and resilience.<\/p>","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"image_aspect_ratio":1,"mobile_image_aspect_ratio":1}},"image_nU7PXt":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/fc6bac0d-e63a-47e0-9abf-d9400942a7d4.jpg","image_shape":"normal","title":"Brilliant Fire, Beyond Compare","text":"<p>Moissanite delivers unparalleled brilliance. Its dazzling fire surpasses that of diamonds, making it the more vibrant and radiant choice.<\/p>","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"image_aspect_ratio":1,"mobile_image_aspect_ratio":1}},"image_iWkdaF":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/20241024-101436.gif","image_shape":"normal","title":"Passes the Diamond Tester","text":"<p>Our moissanite effortlessly passes diamond tester checks, offering the same authenticity and quality as diamonds at a fraction of the cost.<\/p>","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"image_aspect_ratio":1,"mobile_image_aspect_ratio":1}}},"block_order":["image_TLXtjg","image_nU7PXt","image_iWkdaF"],"settings":{"title":"","align_heading":"text-left","align_text":"text-left","width":"wrapper--full-padded","align_columns":"flex-align-top","layout":"grid","grid":3,"layout_mobile":"1","padding_top":50,"padding_bottom":20}},"section_accordion_group_aHpB9X":{"type":"section-accordion-group","blocks":{"heading_yg4GJP":{"type":"heading","settings":{"title":"Jewelry FAQs"}},"question_XQhW7B":{"type":"question","settings":{"default_open":false,"title":"What are your stones made of?","content":"<p>We use high-quality <a href=\"\/pages\/about-moissanite\" title=\"About Moissanite\"><em><strong>moissanite<\/strong><\/em><\/a> and <a href=\"\/pages\/about-cubic-zirconia\" title=\"About Cubic Zirconia\"><em><strong>5A cubic zirconia<\/strong><\/em><\/a>, both ethically and sustainably lab-created. These stones sparkle just as brilliantly as diamonds.<\/p>","show_icon":false,"icon_name":"icon-award","icon_size":20,"icon_color":"#545454"}},"question_qAAXCb":{"type":"question","settings":{"default_open":false,"title":"Will your jewelry turn my finger green?","content":"<p>No, it won’t! We can guarantee this.Our jewelry is made from 925 sterling silver plated with 18K gold, so it won’t discolor your skin, and it's hypoallergenic too.<\/p>","show_icon":false,"icon_name":"icon-award","icon_size":20,"icon_color":"#545454"}},"question_iNwfr6":{"type":"question","settings":{"default_open":false,"title":"How should I care for my jewelry?","content":"<p>When you’re not wearing it, store your jewelry in a jewelry box or pouch. A quick polish with a silver cloth will keep it shining. We recommend taking it off when showering, applying lotions, or during workouts to prevent oxidation. And while it's tempting, it's best not to wear it to bed!<\/p><p><a href=\"\/pages\/jewelry-care\" title=\"Jewelry care\"><em><strong>Jewelry Care Tips<\/strong><\/em><\/a><\/p>","show_icon":false,"icon_name":"icon-award","icon_size":20,"icon_color":"#545454"}},"question_xi9WAL":{"type":"question","settings":{"default_open":false,"title":"Do I get anything extra with my order?","content":"<p>Yes! Along with your jewelry and a gift box, you’ll receive a free surprise jewelry piece and a good luck <a href=\"\/pages\/mystery-box-promotion\" title=\"Mystery Box Promotion\"><em><strong>crystal<\/strong><\/em><\/a>. Plus, we <a href=\"\/pages\/planting-trees-together\" title=\"Planting Trees Together\"><em><strong>plant a tree<\/strong><\/em><\/a> in your name as part of our commitment to the planet.<\/p>","show_icon":false,"icon_name":"icon-award","icon_size":20,"icon_color":"#545454"}},"question_BqAf44":{"type":"question","settings":{"default_open":false,"title":"Can I customize my jewelry?","content":"<p>Yes, we offer <a href=\"\/pages\/custom-design\" title=\"Custom Design\"><em><strong>custom jewelry<\/strong><\/em><\/a>, and the design process is completely free! You can share any of your ideas with us, and we’ll bring them to life. Just reach out to us at service@solariijewelry.com, and we’ll make sure your vision becomes reality.<\/p>","show_icon":false,"icon_name":"icon-award","icon_size":20,"icon_color":"#545454"}},"question_tnt4BL":{"type":"question","settings":{"default_open":false,"title":"Have more questions?","content":"<p>We’ve highlighted the 5 most common questions here, but if you have more, feel free to check out our full <a href=\"\/pages\/faq\" title=\"FAQ\"><em><strong>FAQ<\/strong><\/em><\/a> section for additional details.<\/p>","show_icon":false,"icon_name":"icon-award","icon_size":20,"icon_color":"#545454"}}},"block_order":["heading_yg4GJP","question_XQhW7B","question_qAAXCb","question_iNwfr6","question_xi9WAL","question_BqAf44","question_tnt4BL"],"settings":{"width":"wrapper--narrow","columns":"1","padding_top":50,"padding_bottom":50}},"section_custom_content_WnhfzA":{"type":"section-custom-content","blocks":{"image_9LANb4":{"type":"image","setting