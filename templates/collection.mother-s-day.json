atured_image_M7iEjh":{"type":"featured_image","disabled":true,"settings":{"featured_image":"shopify:\/\/shop_images\/b864149beaa1fe324640b70f0fabf581.jpg","position":10,"featured_heading":"","featured_text":"","featured_button_text":"","featured_button_link":"","button_type":"btn--primary","button_size":"","button_style":"btn--outline","show_arrow":false,"featured_color_text":"#ffffff"}},"featured_image_XHLipe":{"type":"featured_image","settings":{"featured_image":"shopify:\/\/shop_images\/100.jpg","position":15,"featured_heading":"","featured_text":"","featured_button_text":"","featured_button_link":"","button_type":"btn--primary","button_size":"","button_style":"btn--outline","show_arrow":false,"featured_color_text":"#ffffff"}}},"block_order":["featured_image_BwjGHq","featured_image_M7iEjh","featured_image_XHLipe"],"settings":{"enable_sort":true,"enable_filters":true,"filter_layout":"inline-open","collection_linklist":"","grid":4,"grid_mobile":"2","products_per_page":24,"padding_top":0,"padding_bottom":0}},"sparqAppBlock":{"type":"apps","disabled":true,"settings":{"include_margins":true}},"section_rich_text_pAjDTM":{"type":"section-rich-text","blocks":{"heading_6y9Fmi":{"type":"heading","settings":{"title":"Beautiful & Affordable Jewelry","padding_bottom":16}},"text_GHHwpD":{"type":"text","settings":{"text":"<p>At Solarii, we believe that beauty should never come at the cost of affordability. Our jewelry collection—whether it’s engagement rings, necklaces, or other timeless pieces—offers stunning craftsmanship at accessible prices. You deserve to own jewelry that not only enhances your look but also fits your values. Explore our carefully curated designs that balance elegance with a reasonable price tag, proving that the most beautiful things in life don’t have to be out of reach.<\/p>","padding_bottom":16}}},"block_order":["heading_6y9Fmi","text_GHHwpD"],"settings":{"align_text":"text-center","width":"wrapper","padding_top":10,"padding_bottom":0}},"section_rich_text_BCKyfy":{"type":"section-rich-text","blocks":{"heading_FTfaVk":{"type":"heading","settings":{"title":"Why Choose Us","padding_bottom":16}},"text_ACJGz4":{"type":"text","settings":{"text":"<p>With over a decade of experience in handcrafted jewelry, Solarii is committed to delivering quality, value, and peace of mind. Our jewelry is made with care and precision, backed by our 100% refund guarantee, 24\/7 customer support, and hassle-free 30-day return policy. We stand by the excellence of every piece we create, and we pride ourselves on offering a seamless, fulfilling shopping experience. Your trust in Solarii means everything to us.<\/p>","padding_bottom":16}}},"block_order":["heading_FTfaVk","text_ACJGz4"],"settings":{"align_text":"text-center","width":"wrapper","padding_top":10,"padding_bottom":0}},"section_rich_text_whpQPV":{"type":"section-rich-text","blocks":{"heading_nRkjHX":{"type":"heading","settings":{"title":"Solarii's Ethical Excellence","padding_bottom":16}},"text_8XtxkN":{"type":"text","settings":{"text":"<p>Choosing the right engagement ring and wedding band is a reflection of your values and beliefs. At Solarii, we understand the importance of ethical sourcing. Sadly, many traditional jewelers still use conflict minerals and blood diamonds, materials linked to human suffering. We reject this practice. Every piece of jewelry we craft is made from 100% responsibly sourced materials. With our human-made stones, you get the beauty and brilliance of a traditional wedding ring without the ethical compromise. Our commitment to ethical excellence ensures your love story is not just beautiful—it’s conscientious.<\/p>","padding_bottom":16}}},"block_order":["heading_nRkjHX","text_8XtxkN"],"settings":{"align_text":"text-center","width":"wrapper","padding_top":10,"padding_bottom":0}}},"order":["hero","section_rich_text_9iUjkB","subcollections","section_highlights_eGKwzP","main","sparqAppBlock","section_rich_text_pAjDTM","section_rich_text_BCKyfy","section_rich_text_whpQPV"]}