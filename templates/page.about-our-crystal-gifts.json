{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"subheading":"","show_title":true,"heading_font_size":"heading-large","show_content":true,"text_font_size":"body-medium","align_text":"text-left","width":"wrapper","color_scheme":"","padding_top":50,"padding_bottom":50,"heading_tag":"automatic"}},"section_hero_BfdyxV":{"type":"section-hero","blocks":{"heading_GN7G9P":{"type":"heading","settings":{"title":"About Our Crystal Gifts","heading_font_size":"heading-x-large","heading_tag":"automatic"}}},"block_order":["heading_GN7G9P"],"settings":{"image_1":"shopify:\/\/shop_images\/istockphoto-1244089846-1024x1024.jpg","link":"","width":"wrapper--full","height":"screen-height-full","flex_align_desktop":"align--bottom-right-desktop","content_width":50,"mobile_height":"screen-height-three-quarters--mobile","flex_align_mobile":"align--bottom-right-mobile","color_scheme":"scheme-2","show_text_background":false,"padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_text_with_products_AaBYjn":{"type":"section-text-with-products","settings":{"subheading":"","heading":"Welcome to our world! We are a group of young adventurers with a deep love for stones and crystals, traveling the globe in search of treasures that carry meaning and beauty. From the serene deserts to the rhythmic waves of distant shores, we collect stones that not only captivate the eye but also tell stories.","width":"wrapper","text_font_size_px_desktop":26,"text_align_desktop":"text-left","text_font_size_px_mobile":19,"text_align_mobile":"text-left--mobile","color_scheme":"","padding_top":32,"padding_bottom":32}},"section_double_slider_cyYC7j":{"type":"section-double-slider","blocks":{"text_slide_ieKBKM":{"type":"text-slide","settings":{"subheading":"For us","title":"Each stone is more than just a natural wonder","heading_font_size":"heading-large","text":"<p>It’s a memory, a connection to the Earth, and a reminder of life’s beautiful mysteries. We believe that when you hold one of our stones, you can feel that energy too—a sense of calm, inspiration, or perhaps even a spark of joy. <br\/><br\/>Each piece is a chance for you to reconnect with nature and discover something new about yourself.<\/p>","text_font_size":"body-medium","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"heading_tag":"automatic"}}},"block_order":["text_slide_ieKBKM"],"settings":{"image_1":"shopify:\/\/shop_images\/istockphoto-1067431158-1024x1024.jpg","image_width":"one-half","autoplay":true,"autoplay_speed":4,"text_alignment":"text-left","layout":"","width":"wrapper--full","height":"screen-height-three-quarters","mobile_height":"screen-height-one-half--mobile","reverse_blocks":false,"color_scheme":"","padding_top":0,"padding_bottom":0,"show_placeholder":true}},"section_double_slider_MUDAV9":{"type":"section-double-slider","blocks":{"text_slide_W4RNwD":{"type":"text-slide","settings":{"subheading":"To share this magic with you","title":"We’ve created our Mystery Crystal Box","heading_font_size":"heading-large","text":"<p>An exciting way to experience the mystery and wonder of the natural world. <br\/><br\/>Each box is carefully curated, and while you might not know exactly what you’ll receive, we can guarantee that every crystal carries a unique positive energy that’s meant just for you.<\/p>","text_font_size":"body-medium","button_text":"","button_url":"","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"heading_tag":"automatic"}}},"block_order":["text_slide_W4RNwD"],"settings":{"image_1":"shopify:\/\/shop_images\/istockphoto-1893527144-1024x1024.jpg","image_width":"one-half","autoplay":true,"autoplay_speed":4,"text_alignment":"text-left","layout":"is-reversed","width":"wrapper--full","height":"screen-height-three-quarters","mobile_height":"screen-height-one-half--mobile","reverse_blocks":false,"color_scheme":"","padding_top":0,"padding_bottom":0,"sh